{%- style -%}
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
        background: var(--Gradient, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, rgba(244, 239, 253, 0.60) 0.38%, rgba(255, 245, 191, 0.60) 100%), #FFF);
      }
    .new-qes-content {
        max-width: 500px;
        margin: 0 auto;
    }
    .start-step-single {
      display: flex;
      gap: 12px;
          align-items: start;
  }
  .active-step {
      border-radius: 16px;
      background: #FFF;
      padding: 16px;
  }
  .start-step-texts h3{
      margin: 0;
      color: #111;
      leading-trim: both;
      text-edge: cap;
      font-family: SF Pro;
      font-size: 18px;
      font-style: normal;
      font-weight: 500;
      line-height: normal;
      letter-spacing: -0.5px;
  }
  .start-step-texts p{
      margin: 0;
      color: var(--Gray, #545454);
      leading-trim: both;
      text-edge: cap;
      font-family: "SF Pro";
      font-size: 14px;
      font-style: normal;
      font-weight: 400;
      line-height: 130%;
      letter-spacing: -0.5px;
      padding-top: 16px;
  }
  .non-active-step h3{
      color: var(--Gray, #545454);
  leading-trim: both;
  text-edge: cap;
  font-family: "SF Pro";
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: normal;
  }
  .active-step-2  img{
      margin-top: 15px;
  }
      @media screen and (min-width: 750px) {
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
        }
        h3.qes-heading {
          font-size: 20px;
        }
        .start-step-texts h3 {
          font-size: 16px;
        }
        .start-step-texts p {
          padding-top: 14px;
        }

      }
{%- endstyle -%}

<section class="new-qes-section section-{{ section.id }}-padding" data-step = '{{ section.settings.step-name }}' next-step = '{{ section.settings.next-step }}'>
  <div class="page-width">
    <div class="new-qes-content">
      <h3 class="qes-heading">
        {{ section.settings.heading }}
      </h3>
         <div class="starting-content-wrapper">
        {% for block in section.blocks %}
          <div class="start-step-single {% if block.settings.step-des != blank  %} active-step-2 {% else %} non-active-step-2{% endif %}">
            {% if block.settings['side-img'] %}
              <img src="{{ block.settings.side-img | image_url }}" width="auto" height="auto">
            {% endif %}
            <div class="start-step-texts {% if block.settings.step-des != blank  %} active-step {% else %} non-active-step{% endif %}">
              <h3>
                {{ block.settings['step-heading'] }}
              </h3>
              <p>
                {{ block.settings['step-des'] }}
              </p>
            </div>
          </div>
        {% endfor %}
      </div>
       <button class="submitt-btn">
         {{ section.settings.button-text }}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "questionaire step 1",
  "settings": [
    {
      "type": "range",
      "id": "btm_spacing",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Header Bottom space",
      "default": 30
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading",
      "default": "Check Our Featured Products And Deals"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "text",
      "id": "heading",
      "label": "heading"
    },
    {
        "type": "text",
        "id": "button-text",
        "label": "button text"
    },
     {
      "type": "text",
      "id": "step-name",
      "label": "step name"
    },
    {
      "type": "text",
      "id": "next-step",
      "label": "next step"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "question",
      "settings": [
        {
          "type": "image_picker",
          "id": "side-img",
          "label": "image"
        },
        {
          "type": "text",
          "id": "step-heading",
          "label": "step heading"
        },
        {
          "type": "text",
          "id": "step-des",
          "label": "step des"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "questionaire step 1"
    }
  ]
}
{% endschema %}
