#cs-weightSlider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px; /* Line ki thickness */
    background: #f1f1f1; /* Khali track ka color */
    border-radius: 5px;
    outline: none;
    margin: 0px 0;
    /* Is se yellow line banti hai */
    background-image: linear-gradient(#FFD700, #FFD700);
    background-size: var(--progress, 50%) 100%;
    background-repeat: no-repeat;
}

/* Chrome, Safari, Edge aur Opera ke liye thumb (Purple Button) */
#cs-weightSlider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 50px; /* Purple pill ki width */
    height: 18px; /* Purple pill ki height */
    background: #4C3E79;
    border-radius: 25px;
    cursor: pointer;
    border: 1px solid #fff;
    /* Andar ke arrows < > */
