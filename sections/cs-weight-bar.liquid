{% comment %} <script>
let el = document.querySelector(".cs_weight_bar_numbre");
let target = parseFloat(el.innerText);
el.innerText = "0%";

let duration = 2000;
let startTime = null;
let hasAnimated = false;

function animateCounter(timestamp) {
  if (!startTime) startTime = timestamp;

  let progress = timestamp - startTime;
  let value = Math.min(progress / duration * target, target);

  el.innerText = value.toFixed(2) + "%";

  if (progress < duration) {
    requestAnimationFrame(animateCounter);
  }
}

let observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting && !hasAnimated) {
      hasAnimated = true;
      requestAnimationFrame(animateCounter);
    }
  });
}, { threshold: 0.5 }); // 50% visible hone par start

observer.observe(el);
</script> {% endcomment %}
<script>
document.addEventListener("DOMContentLoaded", function(){
  const KG_TO_LB = 2.20462;
  const LOSS_PERCENTAGE = 0.2155; 

  const slider = document.getElementById("cs-weightSlider");
  const weightValue = document.getElementById("cs-weightValue");
  const lossValue = document.getElementById("cs-lossValue");
  const weightUnitDisplay = document.getElementById("cs-weightUnitDisplay");
  const lossUnit = document.getElementById("cs-lossUnit");
  const buttons = document.querySelectorAll(".cs-unit-btn");

  function updateValues() {
    let val = parseFloat(slider.value);
    weightValue.innerText = Math.round(val);
    
    // Yellow Progress Bar Update logic
    const min = slider.min || 0;
    const max = slider.max || 100;
    const percent = ((val - min) / (max - min)) * 100;
    slider.style.setProperty('--progress', percent + '%');

    // Calculate potential loss
    let loss = val * LOSS_PERCENTAGE;
    lossValue.innerText = Math.round(loss);
  }

  slider.addEventListener("input", updateValues);

  buttons.forEach(btn => {
    btn.addEventListener("click", function() {
      if (this.classList.contains("active")) return;

      const newUnit = this.dataset.unit;
      let val = parseFloat(slider.value);

      buttons.forEach(b => b.classList.remove("active"));
      this.classList.add("active");

      // Slider range conversion
      if (newUnit === "lb") {
        slider.min = Math.round(slider.min * KG_TO_LB);
        slider.max = Math.round(slider.max * KG_TO_LB);
        slider.value = Math.round(val * KG_TO_LB);
        weightUnitDisplay.innerText = "lb";
        lossUnit.innerText = "lb";
      } else {
        slider.min = Math.round(slider.min / KG_TO_LB);
        slider.max = Math.round(slider.max / KG_TO_LB);
        slider.value = Math.round(val / KG_TO_LB);
        weightUnitDisplay.innerText = "kg";
        lossUnit.innerText = "kg";
      }

      updateValues();
    });
  });

  updateValues(); // Initial trigger
});

</script>

