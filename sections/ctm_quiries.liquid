$('body').on('click', '.button_swich', function () {
  var $toolbar = $(this).closest('.radio-toolbar'); // Parent toolbar
  var $siblings = $toolbar.siblings(); // Sibling toolbars
  var $parts = $toolbar.find('.cent_kilo_part'); // Inside parent
  var $siblingParts = $siblings.find('.cent_kilo_part'); // Inside siblings

  // Toggle inside current toolbar
  $parts.each(function () {
    $(this).toggleClass('hidden');
  });

  // Toggle inside sibling toolbars
  $siblingParts.each(function () {
    $(this).toggleClass('hidden');
  });

  // Toggle spans inside the clicked button
  $(this).find('span').each(function () {
    $(this).toggleClass('hidden');
  });
});


$('body').on('input', '.cent_kilo_part input[type="number"]:visible', function () {
  // ----- Try Metric Units -----
  const heightCmInput = $('.cent_kilo_part input.height_part:visible');
  const weightKgInput = $('.cent_kilo_part input.weight_part:visible');

  const heightCm = parseFloat(heightCmInput.val());
  const weightKg = parseFloat(weightKgInput.val());

  if (!isNaN(heightCm) && !isNaN(weightKg) && heightCm > 0) {
    const heightM = heightCm / 100;
    const bmi = weightKg / (heightM * heightM);

    console.log('BMI:', bmi);

    $('.total_bmi_claculation').text("Your BMI : " + bmi.toFixed(2));
    if (bmi >= 28) {
      $('#bmi-error').addClass('hidden').text('');
      $('.bmi_output').val(bmi.toFixed(2));
    } else {
      $('#bmi-error').removeClass('hidden').text('You are not eligible with this height and weight');
      $('.bmi_output').val('');
    }
    return;
  }

  // ----- Try Imperial Units -----
  const feet = parseFloat($('.height_feet:visible').val()) || 0;
  const inches = parseFloat($('.height_inches:visible').val()) || 0;
  const stones = parseFloat($('.weight_stones:visible').val()) || 0;
  const pounds = parseFloat($('.weight_pounds:visible').val()) || 0;

  const totalInches = (feet * 12) + inches;
  const totalPounds = (stones * 14) + pounds;

  if (totalInches > 0 && totalPounds > 0) {
    const bmi = (totalPounds / (totalInches * totalInches)) * 703;

    console.log('BMI:', bmi);
    $('.total_bmi_claculation').text("Your BMI : " + bmi.toFixed(2));
    if (bmi >= 28) {
      $('#bmi-error').addClass('hidden').text('');
      $('.bmi_output').val(bmi.toFixed(2));
    } else {
      $('#bmi-error').removeClass('hidden').text('You are not eligible with this height and weight');
      $('.bmi_output').val('');
    }
  } else {
    $('#bmi-error').addClass('hidden').text('');
    $('.bmi_output').val('');
  }
});

  

