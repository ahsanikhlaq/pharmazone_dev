                      <!-- Centimeters -->
                      <div class="cent_kilo_part">
                        <div>
                          <input
                            class="height_part"
                            type="number"
                            placeholder="0"
                            min="140"
                            max="270"
                          >
                        </div>
                        <p>Centimeters</p>
                      </div>
                      <!-- Feet-Inches -->
                      <div class="cent_kilo_part hidden">
                        <div>
                          <input
                            class="height_feet"
                            placeholder="0"
                            min="0"
                            max="8"
                            type="number"
                          >
                        </div>
                        <p>Feet</p>
                        <div>
                          <input
                            class="height_inches"
                            placeholder="0"
                            min="0"
                            max="11"
                            type="number"
                          >
                        </div>
                        <p>Inches</p>
                      </div>
                      <input type="hidden" class="bmi_output" name="properties[{{ block.settings.question }}-BMI]">
                    </div>
                  </p>
                {% elsif block.settings.weight and block.settings.question != blank %}
