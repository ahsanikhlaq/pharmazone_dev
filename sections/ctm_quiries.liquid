function checkFormErrors() {
  let hasError = false;

  $('form .alert-danger').each(function () {
    if (!$(this).hasClass('hidden')) {
      hasError = true;
      return false; 
    }
  });

  if (!$('#confirm_terms').is(':checked')) {
    hasError = true;
    $('#terms-error').removeClass('hidden');
  } else {
    $('#terms-error').addClass('hidden');
  }

  
  if (!$('#confirm_terms_nd').is(':checked')) {
    hasError = true;
    $('#terms-error_nd').removeClass('hidden');
  } else {
    $('#terms-error_nd').addClass('hidden');
  }
}


document.querySelector('.custom_add_to_cart_button.new--form--ppup').addEventListener('click', function (event) {
  event.preventDefault();

  $('body').on('change', 'input[type="radio"]', function () {
    var $toolbar = $(this).closest('.radio-toolbar');
    $toolbar.find('.custom-error-msg').remove();
  });

  
  $('body').on('change', 'input[type="checkbox"]', function () {
    var $toolbar = $(this).closest('.multiple_checkboxes');
    $toolbar.find('.custom-error-msg').remove();
  });


  $('body').on('input', 'textarea[name^="properties["], input[name^="properties["][type="number"]:visible, input[type="number"]', function () {
    const $el = $(this);
    $el.css({ border: '' });
    $el.next('.custom-error-msg').remove();

    const $wrapper = $el.closest('.ctm_text_area');
    $wrapper.find('input[type="number"]:visible').css({ border: '' });
    $wrapper.find('.custom-error-msg').remove();
  });

  
    var isValid = true;
    var checkedRadioGroups = new Set();
    var checkedCheckboxGroups = new Set();
    // var textAreaGroups = new Set();
    
    // RADIO VALIDATION + ERROR CHECK
    $("input:radio:visible").each(function () {
        var name = $(this).attr("name");
    
        if (!checkedRadioGroups.has(name)) {
            var $group = $("input:radio[name='" + name + "']:visible");
            var $checked = $group.filter(":checked");
    
            if ($checked.length === 0) {
                isValid = false;
            } else {
                // Check if any .alert:not(.hidden) exists in the group
                var $alert = $group.first().closest('.radio-toolbar').find('.alert:not(.hidden)');
                if ($alert.length > 0) {
                    isValid = false;
                }
            }
    
            checkedRadioGroups.add(name);
        }
    });
    
    // CHECKBOX VALIDATION + ERROR CHECK
    $("input:checkbox").each(function () {
        var name = $(this).attr("name");
    
        if (!checkedCheckboxGroups.has(name)) {
            var $group = $("input:checkbox[name='" + name + "']");
            var $checked = $group.filter(":checked");
    
            if ($checked.length === 0) {
                isValid = false;
            } else {
                // Check if any .alert:not(.hidden) exists in the group
                var $alert = $group.first().closest('.multiple_checkboxes').find('.alert:not(.hidden)');
                if ($alert.length > 0) {
                    isValid = false;
                }
            }
    
            checkedCheckboxGroups.add(name);
        }
    });

    $('textarea[name^="properties["]:visible, input[name^="properties["][type="number"]:visible, input[name^="properties["][type="hidden"]').each(function () {
      const $el = $(this);
      const value = $el.val().trim();
      
      if (!value) {
        isValid = false; 
      }
    });


    if (isValid) {
      var targetButton = event.target.closest('.custom_add_to_cart_button');
      if (!targetButton) return;
    
      var elementAttr = targetButton.getAttribute('data_id_attr');
      var quantityAttr = targetButton.getAttribute('data_quantity');
    
      let properties = {};
    
      document.querySelectorAll(
        'input[name^="properties["]:checked, textarea[name^="properties["], input[name^="properties["][type="number"], input[name^="properties["][type="hidden"]'
      ).forEach((input) => {
        const nameAttr = input.getAttribute('name');
        const matches = nameAttr.match(/^properties\[(.+?)\]$/);
        const value = input.value;
    
        if (matches && matches[1] && value !== '') {
          const propName = matches[1];
    
          if (properties[propName]) {
            if (!Array.isArray(properties[propName])) {
              properties[propName] = [properties[propName]];
            }
            if (!properties[propName].includes(value)) {
              properties[propName].push(value);
            }
          } else {
            properties[propName] = value;
          }
        }
      });
    
      if (!elementAttr || !quantityAttr || Object.keys(properties).length === 0) {
        console.warn("Missing elementAttr or properties");
        return;
      }
    
      let formData = {
        items: [{
          id: elementAttr,
          quantity: parseInt(quantityAttr),
          properties: properties
        }]
      };
    
      console.log("Sending formData:", formData);
    
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/cart';
          console.log("Added to cart:", data);
        })
        .catch((error) => {
          console.error('Error:', error);
        });
    }
   else {
    var $btnBlockShown = false;
    var $btnBlock = $(".new--form--ppup").siblings('.button_block_ctm');
    var firstInvalidInput = null;
    var checkedRadioGroups = new Set();
    var checkedCheckboxGroups = new Set();
  
    // RADIO VALIDATION
    $("input:radio:visible").each(function () {
      var name = $(this).attr("name");
      if (!checkedRadioGroups.has(name)) {
        var $group = $("input:radio[name='" + name + "']:visible");
        var $checked = $group.filter(":checked");
        var $alert = $group.first().closest('.radio-toolbar').find('.alert:not(.hidden)');
  
        if ($checked.length === 0) {
          if (!firstInvalidInput) {
            firstInvalidInput = $group.first()[0];
          }
  
          var $toolbar = $group.first().closest('.radio-toolbar');
          if ($toolbar.find('.custom-error-msg').length === 0) {
            $toolbar.append('<div class="custom-error-msg">This field is required</div>');
          }
  
          if (!$btnBlockShown) {
            $btnBlock.removeClass('custom_hidden');
            setTimeout(() => $btnBlock.addClass('custom_hidden'), 6000);
            $btnBlockShown = true;
          }
        } else if ($alert.length > 0 && !firstInvalidInput) {
          firstInvalidInput = $group.first()[0];
        }
  
        checkedRadioGroups.add(name);
      }
    });
  
    // CHECKBOX VALIDATION
    $("input:checkbox").each(function () {
      var name = $(this).attr("name");
      if (!checkedCheckboxGroups.has(name)) {
        var $group = $("input:checkbox[name='" + name + "']");
        var $checked = $group.filter(":checked");
        var $alert = $group.first().closest('.multiple_checkboxes').find('.alert:not(.hidden)');
  
        if ($checked.length === 0) {
          if (!firstInvalidInput) {
            firstInvalidInput = $group.first()[0];
          }
  
          var $toolbar = $group.first().closest('.multiple_checkboxes');
          if ($toolbar.find('.custom-error-msg').length === 0) {
            $toolbar.append('<div class="custom-error-msg">This field is required</div>');
          }
  
          if (!$btnBlockShown) {
            $btnBlock.removeClass('custom_hidden');
            setTimeout(() => $btnBlock.addClass('custom_hidden'), 6000);
            $btnBlockShown = true;
          }
        } else if ($alert.length > 0 && !firstInvalidInput) {
          firstInvalidInput = $group.first()[0];
        }
  
        checkedCheckboxGroups.add(name);
      }
    });


    // TEXTAREA VALIDATION
     $('textarea[name^="properties["]:visible, input[name^="properties["][type="number"]:visible, input[name^="properties["][type="hidden"]').each(function () {
        const $el = $(this);
        const value = $el.val().trim();
        const $visibleSibling = $el.siblings('.cent_kilo_part').find('input[type="number"]:visible');
        if (!value) {
      
          if (!firstInvalidInput) {
            firstInvalidInput = $el[0];
            firstInvalidInput = $visibleSibling[0];
          }
      
          if (!$el.next('.custom-error-msg').length) {
            $el.after('<div class="custom-error-msg">This field is required</div>');
          }
      
          if (!$btnBlockShown) {
            $btnBlock.removeClass('custom_hidden');
            setTimeout(() => $btnBlock.addClass('custom_hidden'), 6000);
            $btnBlockShown = true;
          }
      
          // Optional: highlight
          $el.css({ border: '2px solid red' });
          $visibleSibling.css({ border: '2px solid red' });
        }
      });


    // SCROLL TO FIRST INVALID OR ALERT FIELD
    if (firstInvalidInput) {
      setTimeout(() => {
        firstInvalidInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        firstInvalidInput.focus();
      }, 1500);
    }
  }

});
</script>

