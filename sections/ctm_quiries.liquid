                        <div>
                          <input
                            class="weight_part"
                            type="number"
                            placeholder="0"
                            min="0"
                            max="680"
                          >
                        </div>
                        <p>Kilograms</p>
                      </div>
                      <!-- Stones/Pounds -->
                      <div class="cent_kilo_part hidden">
                        <div>
                          <input
                            class="weight_stones"
                            placeholder="0"
                            min="0"
                            max="100"
