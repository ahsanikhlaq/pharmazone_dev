       document.getElementById('product-title').textContent = product.title;
       document.getElementById('product-price').textContent = product.price / 100 + ' ' + Shopify.currency.active;
       document.getElementById('product-image').src = product.images[0];
       // document.getElementById('variant-i').textContent = product.title;
     })
    .catch(error => console.error("Error loading product:", error));
  }
  if(variantId){
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.setAttribute('data_id_attr', variantId);
  }
  
 // Multi step form value end
$('input.input_yes_change_error').change(function () {
  if ($(this).val() == "Yes") {
    $(this).siblings('.alert-danger').removeClass('hidden');
  } else {
    $(this).siblings('.alert-danger').addClass('hidden');
  }


  checkFormErrors();
});
  

  
$('input.non_change_error').change(function () {
  if ($(this).val() == "No") {
    $(this).siblings('.alert-danger').removeClass('hidden');
  } else {
    $(this).siblings('.alert-danger').addClass('hidden');
  }

  checkFormErrors();
});

  

$('input.below_checkbox_enable').change(function () {
  if ($(this).val() == "Yes") {
    $(this).siblings('.ctm--inner--options').removeClass('hidden');
    $(this).siblings('.ctm--inner--options').addClass('show_checkboxes');
    $(this).siblings('.ctm--inner--options').find('input').attr('required', 'true');
  } else {
    $(this).siblings('.ctm--inner--options').addClass('hidden');
    $(this).siblings('.ctm--inner--options').removeClass('show_checkboxes');
    $(this).siblings('.ctm--inner--options').find('input').removeAttr('required');
  }

  checkFormErrors();
});


  
$('.multiple_checkboxes input').on('change', function () {
 
  $('.multiple_checkboxes input').not(this).prop('checked', false);

  $(this).find('.alert-danger').addClass('hidden');

  const isSpecial = $(this).hasClass('reg_option_more');
  const index = $('input.reg_option_more').index(this);

  if (isSpecial && $(this).is(':checked') && index >= 0 && index <= 3) {
    $(this).siblings('.alert-danger').removeClass('hidden');
  }else{
    $(this).siblings('.alert-danger').addClass('hidden');
  }


  checkFormErrors();
});


$('#confirm_terms').on('change', function () {
  if ($(this).is(':checked')) {
    $('#terms-error').addClass('hidden');
  } else {
    $('#terms-error').removeClass('hidden');
  }

  checkFormErrors(); 
});
  

function checkFormErrors() {
  let hasError = false;

  $('form .alert-danger').each(function () {
    if (!$(this).hasClass('hidden')) {
      hasError = true;
      return false; 
    }
  });

  if (!$('#confirm_terms').is(':checked')) {
    hasError = true;
    $('#terms-error').removeClass('hidden');
  } else {
    $('#terms-error').addClass('hidden');
  }
}

