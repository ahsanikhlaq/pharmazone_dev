{%- style -%}
    html {
    scroll-behavior: smooth;
  }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
{%- endstyle -%}
<style>
    @font-face {
    font-family: Lato;
    src: url(https://cdn.shopify.com/s/files/1/0902/7823/2430/files/Lato-Regular.ttf?v=1749465921);
  }
    .custom-form-container p{
      font-family: Lato;
    }
    /* General Styles */


    /* Container for the form */
    .custom-form-container  .content {
        max-width: 900px;
        margin: 30px auto;
        background-color: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
    }


    .customize--product-poppup .product-details{
      display: flex;
    }

    .customize--product-poppup .both--btn-final .new--form--ppup{
          margin-left: 12px;
    }
    /* Form Title */
    .custom-form-container  .form-head {
        font-size: 24px;
        color: #1e3d58;
        text-align: center;
        margin-bottom: 20px;
    }

    /* Fieldset and Legend */
    .custom-form-container  fieldset {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
        background-color: #fafafa;
    }

    .custom-form-container  legend {
        font-size: 18px;
        font-weight: bold;
        color: #1e3d58;
        margin-bottom: 20px;
        display: contents;
      font-family: Lato;
    }

    /* Question labels */
    .custom-form-container  label {
        font-size: 16px;
        color: #333;
        margin-bottom: 10px;
        display: block;
      font-weight: 600;
      font-family: Lato;
    }

    /* Radio buttons and checkboxes */
    .custom-form-container  input[type="radio"],
    .custom-form-container  input[type="checkbox"] {
        margin-right: 10px;
    }

    /* Input and Textarea Fields */
    .custom-form-container  input[type="radio"],
    .custom-form-container  input[type="checkbox"] {
        accent-color: #4ad6c9; /* Orange accent for checkboxes and radio buttons */
        cursor: pointer;
    }

    /* Styling for hidden alert messages */

     .custom-form-container .custom_hidden{
      display: none !important;
    }

    .custom-form-container  .alert {
        display: block;
        margin-top: 10px;
        padding: 10px;
        border-radius: 5px;
        font-size: 14px;
    }

    .custom-error-msg{
       margin-top: 10px;
        padding: 10px;
        border-radius: 5px;
        font-size: 14px;
    }

    .custom-form-container  .alert-danger,
    .custom-form-container  .button_block_ctm,
    .custom-error-msg{
        background-color: #f8d7da;
        color: #721c24;
    }

    .custom-form-container  .alert-warning {
        background-color: #fff3cd;
        color: #856404;
    }

    .custom-form-container  .hidden {
        display: none;
    }



    /* Button styles */
   /* .custom-form-container  button {
        padding: 12px 20px;
        font-size: 16px;
        background-color: #ff9900;
        color: #fff;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    } */


    /* Input group for radio buttons and checkboxes */
    .custom-form-container  input[type="radio"]:checked,
    .custom-form-container  input[type="checkbox"]:checked {
        accent-color: #4ad6c9;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .custom-form-container  .content {
            padding: 15px;
        }

        .custom-form-container  .form-head {
            font-size: 20px;
        }

        .custom-form-container  label {
            font-size: 14px;
        }

        .custom-form-container  input[type="radio"],
      .custom-form-container  input[type="checkbox"] {
            margin-right: 8px;
        }
    }

    /* Style for the checkbox for final consent */
    .custom-form-container  #confirm_terms {
        margin-right: 10px;
    }

    /* Style for the Terms and Conditions error message */
    .custom-form-container  #terms-error {
        font-size: 14px;
        color: #721c24;
        margin-top: 10px;
    }

    /* Styling for the medication list */
    .custom-form-container  #medication-list {
        margin-top: 15px;
        padding-left: 20px;
    }

    .custom-form-container  #medication-list p {
        font-size: 14px;
        margin-bottom: 10px;
    }

    .custom-form-container  #medication-list input[type="checkbox"] {
        margin-right: 10px;
    }

    /* Alert styling for "You must agree..." messages */
    .custom-form-container  #q1-error,
    .custom-form-container  #q2-warning,
    .custom-form-container  #q3-error,
    .custom-form-container  #q4-error,
    .custom-form-container  #q6-error,
    .custom-form-container  #q7-error,
    .custom-form-container  #q8-error,
    .custom-form-container  #q9-error,
    .custom-form-container  #q11-error,
    .custom-form-container  #q12-error,
    .custom-form-container  #q13-error,
    .custom-form-container  #q14-error {
        margin-top: 10px;
    }

    .custom-form-container  hr {
      margin: 29px 0;
  }

    .custom-form-container   .product-images img{
      width: 100%;
    }
     .custom-form-container   .product-images{
    flex: 0 0 150px;
      margin-right: 20px;
      max-width: 150px;
     }



    /* Custom style for submit button */
    .custom-form-container  #submitBtn {
        width: 100%;
        padding: 15px;
        font-size: 15px;
        /* background-color: #51c3be; */
        color: white;
        border: none;
        /* border-radius: 5px; */
        cursor: pointer;
        transition: background-color 0.3s ease;
        height:auto;
        margin-top: 15px;
        position: relative;
        border: 2px solid #5DC5C2;
        overflow: hidden;
        z-index: 1;
    }

  .custom-form-container #submitBtn::before{
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #5DC5C2;
    z-index: -1;
    transition: height 0.3s ease-out;
  }

  .custom-form-container #submitBtn:hover{
    color: #5DC5C2;
    background-color:white;
  }

    .custom-form-container #submitBtn:hover::before {
      height: 0%;
    }

    .custom-form-container .next:disabled{
      opacity: 0.4;
       cursor: not-allowed;
    }

   .custom-form-container  #submitBtn:disabled {
        background-color: #ccc;
        cursor: not-allowed;
    }

    .custom-form-container  .show_checkboxes{
      display: block;
    }

    .custom-form-container  .ctm--inner--options{
      padding-left:15px;
    }

  .form-container.custom-form-container button {
    padding: 10px 20px;
    /* background-color: #51c3be; */
    color: #fff;
    border: none;
    /* border-radius: 4px; */
    cursor: pointer;
    width: 100%;
  }
    @media screen and (min-width: 750px){
      .custom-form-container  #submitBtn {
        width: 50%;
    }
      .form-container.custom-form-container button {
        width: 50%;
      }
    }

  /* general-enquiry-page-css */

  .form_step-product-card {
      display: flex;
    flex-direction:row-reverse;
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px 20px;
        justify-content: center;
  }
    .form_step-product-card .form-step {
      width: 70%;
      padding: 0 20px 20px 0;
  }
  .main-heading {
      margin: 0 0 10px;
      font-family: Lato;
      font-size: 31px;
      padding: 10px 20px;
      background-color: #51c3be;
      color: white;
      display: flex;
      align-items: center;
      gap: 20px;
      font-weight: bold;
  }
    .product_info-other_info{
       width: 30%;
      font-family: Lato;

    }
    .product-card-block {
      padding: 20px;
      box-shadow: 0px 0px 1px #000000;
          height: max-content;
  }
    .product-image-wrap img {
      width: 100%;
  }
    .product-details {
      display: flex;
      flex-direction: column;
      gap: 10px;
      text-align: center;
  }
     .other-info-wrapper {
      padding: 20px;
      background: #51c3be24;
          margin-top: 20px;
  }
    .other-info-container h3 {
      font-size: 22px;
      margin: 0;
      margin-bottom: 15px;
      padding-bottom: 15px;
      font-family: Lato;
      border-bottom: 1px solid #00000021;
  }
  .sub_heading_text h4 {
      font-size: 16px;
      margin: 30px 0 10px;
      position: relative;
      padding-left: 30px;
    font-family: Lato;
  }
    span.num-count {
      position: absolute;
      top: 1px;
      left: 0;
      width: 20px;
      height: 20px;
      text-align: center;
      line-height: 20px;
      background: #51c3be;
      color: #fff;
      display: block;
      border-radius: 50%;
      font-size: 12px;
      /* font-size: .75rem; */
  }
    .num-count.tick-mark{
      background: none;;
    }
    .num-count svg{
      width :100%;
      height:100%;
      fill: #30ba87;
    }
    .other-info_text{
      font-size:14px;
      margin:0;
      line-height:1.5;
    }

    .form-container.custom-form-container .progressbar li::before {
      display: flex;
      align-items: center;
      justify-content: center;
  }
    .form-container.custom-form-container button {
      padding: 20px 20px;
  }
    .form-container.custom-form-container .both--btn-final {
      margin-left: 0;
      gap: 10px;
      max-width: 500px;
      margin: 0 auto;
  }
     @media screen and (min-width: 750px){
       .custom-form-container fieldset{
         padding-left:0;
       }
     }
    @media screen and (max-width: 749px){
      .custom-form-container .form-step fieldset {
      padding: 10px 0;
  }
      .main-heading {
      font-size: 22px;
  }
      .form_step-product-card {
      padding: 30px 20px;
  }
      .form_step-product-card {
    flex-direction:column;
  }
       .form_step-product-card .form-step {
      width: 100%;
  }
    .product_info-other_info{
       width: 100%;
    }
      .main-heading{
      margin:15px 0;;
    }
      .custom-form-container  fieldset {
      margin-top: 20px;
  }
    }
    .custom-form-container  fieldset {
      background-color: #fff;
  }
    .radio-toolbar input[type="radio"] {
    opacity: 0;
    position: absolute;
    width: 0;
    height: 0;
  }

  .radio-toolbar label {
    display: inline-block;
    /* background-color: #eee; */
    height:40px;
    line-height: 40px;
    color: #333;
    font-family: Arial, sans-serif;
    font-size: 14px;
    font-family: Lato;
    padding: 0px 20px;
    border: 2px solid #51c3be40;
    border-radius: 4px; /* use 0 for sharp edges */
    cursor: pointer;
    margin-right: 8px;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .radio-toolbar input[type="radio"]:checked + label {
    background-color: #51c3be;
    border-color: #51c3be40;
    color: white;
    pointer-events:none;
  }
  .radio-toolbar label:hover{
     background-color: #51c3be40;
    /* box-shadow: 0 2px 5px rgba(0,0,0,0.1); */
    border-color:#51c3be40;
  }
  .radio-toolbar input[type="radio"]:focus + label {
    /* outline: 2px dashed #4caf50; */
    outline-offset: 2px;
  }
    .radio-toolbar {
      border-bottom: 1px solid #d8e5e8;
      padding-bottom: 10px;
  }
  .multiple_checkboxes.question-block {
      padding-bottom: 10px;
      border-bottom: 1px solid #d8e5e8;
  }
    .card_product-title {
      font-size: 16px;
      font-family: Lato;
      letter-spacing: normal;
  }
    .radio-toolbar .cstm-label-css {
      display: block;
      background-color: #fff;
      height: unset;
      line-height: unset;
      color: unset;
      font-family: unset;
      font-size: unset;
      padding: unset;
      border: unset;
      border-radius: 0;
      cursor: auto;
      margin-right: unset;
      transition: unset;
          margin-top: 10px;
  }
    .radio-toolbar .cstm-label-css:hover{
     background-color: unset;
    /* box-shadow: 0 2px 5px rgba(0,0,0,0.1); */
    border-color: unset;
  }
    .radio-toolbar .sub-opt-border{
      border:0;
    }
    .form_step-product-card input[type=checkbox] {
      width: 20px;
      height: 20px;
      vertical-align: middle;
      margin-left: 0;
  }
</style>
<div class="section-{{ section.id }}-padding">
  <div class="page_width">
    <div class="form-container custom-form-container" id="formContainer">
      <!--
        <ul class="progressbar">
          {% if section.settings.details_progress != blank %}
            <li class="active">{{ section.settings.details_progress }}</li>
          {% endif %}
          {% if section.settings.finish_progress != blank %}
            <li>{{ section.settings.finish_progress }}</li>
          {% endif %}
        </ul>
        <div class="progress">
          <div class="progress-bar" id="progressBar"></div>
        </div>
      -->
      <form id="multiStepForm" class="form_step-product-card">
        <div class="product_info-other_info">
          <div class="product-card-block">
            <div class="product-details">
              <div class="product-image-wrap">
                <img id="product-image" alt="pharmazondirect">
              </div>
              <div id="product-title" class="card_product-title card__heading h5"></div>
              <div class="product-price price">£<span id="product-price"></span></div>
            </div>
          </div>
          <div class="other-info-wrapper">
            {% for block in section.blocks %}
              {% if block.settings.heading != blank %}
                <div class="other-info-container">
                  <h3 class="h3">{{ block.settings.heading }}</h3>
                  <div class="sub_headings-texts-wrapper">
                    {% if block.settings.sub_heading_1 != blank %}
                      <div class="sub_heading_text">
                        <h4 class="h4">
                          <span class="num-count tick-mark">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="176"
                              height="176"
                              viewBox="0 0 176 176"
                              xml:space="preserve"
                            >
                              <path d="M88 0C39.4 0 0 39.4 0 88s39.4 88 88 88 88-39.4 88-88S136.6 0 88 0zm51.35 58.15-64.29 66.26C71.12 129 64.56 129 61.94 129c-4.59 0-9.18-2.62-12.46-5.9l-13.12-15.09c-2.62-2.62-1.97-6.56.66-9.18 2.62-2.62 6.56-1.97 9.18.66l13.78 15.74c.66.66 1.31 1.31 1.97 1.31h2.62l.66-.66 64.94-66.91c2.62-2.62 6.56-2.62 9.18 0s2.62 6.56 0 9.18z"></path>
                            </svg>
                          </span>
                          {{- block.settings.sub_heading_1 }}
                        </h4>
                        <div class="other-info_text">{{ block.settings.text_1 }}</div>
                      </div>
                    {% endif %}
                    {% if block.settings.sub_heading_2 != blank %}
                      <div class="sub_heading_text">
                        <h4 class="h4"><span class="num-count">2</span>{{ block.settings.sub_heading_2 }}</h4>
                        <div class="other-info_text">{{ block.settings.text_2 }}</div>
                      </div>
                    {% endif %}
                    {% if block.settings.sub_heading_3 != blank %}
                      <div class="sub_heading_text">
                        <h4 class="h4"><span class="num-count">3</span>{{ block.settings.sub_heading_3 }}</h4>
                        <div class="other-info_text">{{ block.settings.text_3 }}</div>
                      </div>
                    {% endif %}
                    {% if block.settings.sub_heading_4 != blank %}
                      <div class="sub_heading_text">
                        <h4 class="h4"><span class="num-count">4</span>{{ block.settings.sub_heading_4 }}</h4>
                        <div class="other-info_text">{{ block.settings.text_4 }}</div>
                      </div>
                    {% endif %}
                    {% if block.settings.sub_heading_5 != blank %}
                      <div class="sub_heading_text">
                        <h4 class="h4"><span class="num-count">5</span>{{ block.settings.sub_heading_5 }}</h4>
                        <div class="other-info_text">{{ block.settings.text_5 }}</div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <!-- Step 1: Account + Personal -->
        <fieldset class="form-step active">
          {% if section.settings.custom_heading_form != blank %}
            <h2 class="main-heading">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                shape-rendering="geometricPrecision"
                text-rendering="geometricPrecision"
                image-rendering="optimizeQuality"
                fill-rule="evenodd"
                clip-rule="evenodd"
                viewBox="0 0 512 512"
                width="50px"
                height="50px"
              >
