16.79l15.93-9.2zM98.96 360.87c-5.89 3.38-13.42 1.35-16.8-4.53-3.37-5.89-1.35-13.42 4.54-16.8l15.93-9.19c5.89-3.38 13.42-1.35 16.79 4.53 3.38 5.89 1.35 13.42-4.53 16.8l-15.93 9.19zM339.54 86.7c3.37-5.89 10.9-7.91 16.79-4.54 5.88 3.38 7.91 10.91 4.53 16.8l-9.19 15.93c-3.38 5.88-10.91 7.91-16.79 4.53-5.89-3.37-7.92-10.9-4.54-16.79l9.2-15.93zM172.45 425.35c-3.41 5.89-10.96 7.9-16.84 4.49-5.89-3.41-7.9-10.96-4.49-16.84l9.21-15.94c3.41-5.88 10.95-7.89 16.84-4.48 5.88 3.41 7.89 10.95 4.48 16.84l-9.2 15.93zm71.18-357.76c0-6.82 5.54-12.36 12.36-12.36 6.82 0 12.35 5.54 12.35 12.36v18.39c0 6.82-5.53 12.36-12.35 12.36-6.82 0-12.36-5.54-12.36-12.36V67.59zm24.72 376.83c0 6.82-5.53 12.36-12.35 12.36-6.82 0-12.36-5.54-12.36-12.36v-18.4c0-6.82 5.54-12.36 12.36-12.36 6.82 0 12.35 5.54 12.35 12.36v18.4zM416.62 95.38C375.53 54.28 318.73 28.85 256 28.85c-62.72 0-119.53 25.43-160.62 66.53-41.1 41.1-66.53 97.9-66.53 160.62 0 62.73 25.43 119.53 66.53 160.62 41.09 41.11 97.9 66.53 160.62 66.53 62.73 0 119.53-25.42 160.62-66.53 41.11-41.09 66.53-97.89 66.53-160.62 0-62.72-25.42-119.53-66.53-160.62z"/>
              </svg>
              {{ section.settings.custom_heading_form }}
