document.querySelector('.new--form--ppup').addEventListener('click', function (event) {
  event.preventDefault();

  $('body').on('change', 'input[type="radio"]', function () {
    var $toolbar = $(this).closest('.radio-toolbar');
    $toolbar.find('.custom-error-msg').remove();
  });

  
  $('body').on('change', 'input[type="checkbox"]', function () {
    var $toolbar = $(this).closest('.multiple_checkboxes');
    $toolbar.find('.custom-error-msg').remove();
  });
  
    var elementAttr = event.target.getAttribute('data_id_attr');

    var isValid = true;
    var checkedRadioGroups = new Set();
    var checkedCheckboxGroups = new Set();
    
    // RADIO VALIDATION + ERROR CHECK
    $("input:radio:visible").each(function () {
        var name = $(this).attr("name");
    
        if (!checkedRadioGroups.has(name)) {
            var $group = $("input:radio[name='" + name + "']:visible");
            var $checked = $group.filter(":checked");
    
            if ($checked.length === 0) {
                isValid = false;
            } else {
                // Check if any .alert:not(.hidden) exists in the group
                var $alert = $group.first().closest('.radio-toolbar').find('.alert:not(.hidden)');
                if ($alert.length > 0) {
                    isValid = false;
                }
            }
    
            checkedRadioGroups.add(name);
        }
    });
    
    // CHECKBOX VALIDATION + ERROR CHECK
    $("input:checkbox").each(function () {
        var name = $(this).attr("name");
    
        if (!checkedCheckboxGroups.has(name)) {
            var $group = $("input:checkbox[name='" + name + "']");
            var $checked = $group.filter(":checked");
    
            if ($checked.length === 0) {
                isValid = false;
            } else {
                // Check if any .alert:not(.hidden) exists in the group
                var $alert = $group.first().closest('.multiple_checkboxes').find('.alert:not(.hidden)');
                if ($alert.length > 0) {
                    isValid = false;
                }
            }
    
            checkedCheckboxGroups.add(name);
        }
    });

  if (isValid) {
    const input = params.get('quantity');
    if(quantity){
      var quantity = input ? parseInt(input.value, 10) : 0;
    }



  let properties = {};

   var genderAnswer = document.querySelector('input[name="properties[Gender]"]:checked');
   var ageAnswer = document.querySelector('input[name="properties[Age]"]:checked');
   var Smoke_drink = document.querySelector('input[name="properties[Smoke drink]"]:checked');
   var sexual_performance = document.querySelector('input[name="properties[Sexual performance]"]:checked');
   var medication_for_erectile = document.querySelector('input[name="properties[Medication for erectile]"]:checked'); 
   var DidItWork = document.querySelector('input[name="properties[Did it work]"]:checked'); 
   var Did_you_experience = document.querySelector('input[name="properties[Did you experience]"]:checked'); 
   var ingredients = document.querySelector('input[name="properties[Ingredients]"]:checked');  
   var aalergic_medicines = document.querySelector('input[name="properties[Allergic to any medicines]"]:checked'); 
   var sexual_activity = document.querySelector('input[name="properties[Sexual activity]"]:checked'); 
   var breathless_chestPain = document.querySelector('input[name="properties[Breathless or chest pain]"]:checked'); 
   var heart_attack = document.querySelector('input[name="properties[Heart attack or stroke]"]:checked'); 
   var low_blood_pressure = document.querySelector('input[name="properties[Suffer from low blood pressure]"]:checked'); 
   var high_blood_pressure = document.querySelector('input[name="properties[High blood pressure]"]:checked'); 
   var OtherHeartProblems = document.querySelector('input[name="properties[Other heart problems]"]:checked'); 
   var Peyronies_disease = document.querySelector('input[name="properties[Peyronies disease]"]:checked'); 
   var Inherited_eye_disease = document.querySelector('input[name="properties[Inherited eye disease]"]:checked'); 
   var GalactoseIntolerance = document.querySelector('input[name="properties[Galactose intolerance]"]:checked'); 
   var DiagnosedLiver = document.querySelector('input[name="properties[Diagnosed liver, kidney or urinary problems]"]:checked'); 
   var AbnormalSugarLevels = document.querySelector('input[name="properties[Abnormal sugar levels]"]:checked'); 
   var HealthConditions = document.querySelector('input[name="properties[Health conditions]"]:checked'); 
   var currently_medication = document.querySelector('input[name="properties[Currently using any other medication]"]:checked'); 
   var RecreationalDrug = document.querySelector('input[name="properties[Recreational drug]"]:checked'); 
   var awarefollow = document.querySelector('input[name="properties[Aware of the following]"]:checked'); 


  
    if (genderAnswer) {
      properties['Are you male?'] = genderAnswer.value;
    }

    if (ageAnswer) {
      properties['Are you under 18 years of age?'] = ageAnswer.value;
    }

    if (Smoke_drink) {
      properties['Are you a smoker and do you consume more than 2 cigarettes a day?'] = Smoke_drink.value;
    }

    if (sexual_performance) {
      properties['Are you having difficulty in getting and/or maintaining an erection satisfactory for sexual performance'] = sexual_performance.value;
    }

    if (medication_for_erectile) {
      properties['Have you used any medication for erectile dysfunction before?'] = medication_for_erectile.value;
    }

    if (DidItWork) {
      properties['Did It Work'] = DidItWork.value;
    }

    if (Did_you_experience) {
      properties['Did you experience any side effects?'] = Did_you_experience.value;
    }

    if (ingredients) {
      properties['Do you have any allergy to Sildenafil, tadalafil and vardenafil or any of its ingredients?'] = ingredients.value;
    }

    if (aalergic_medicines) {
      properties['Are you allergic to any medicines or other substances, for example peanuts or soya?'] = aalergic_medicines.value;
    }

    if (sexual_activity) {
      properties['Has your doctor advised that you are not fit enough for any physical and/or sexual activity?'] = sexual_activity.value;
    }

     if (breathless_chestPain) {
      properties['Do you feel very breathless or experience chest pain with light or moderate physical activity, such as walking briskly for 20 minutes or climbing two flights of stairs?'] = breathless_chestPain.value;
    }

   if (heart_attack) {
      properties['Have you had a heart attack or stroke within the last 6 months?'] = heart_attack.value;
    }

    if (low_blood_pressure) {
      properties['Do you suffer from low blood pressure (i.e. less than 90/50mmHg), and/or are prone to faints or collapses? If you are unsure, check with your GP or local pharmacy'] = low_blood_pressure.value;
    }

    if (high_blood_pressure) {
      properties['Do you have high blood pressure (i.e. above 150/90mmHg)? If you are unsure, check with your GP or local pharmacy?'] = high_blood_pressure.value;
    }
  
    if (OtherHeartProblems) {
      properties['Do you have any other heart problems or are you under a doctor’s care for any of the following'] = OtherHeartProblems.value;
    }

    if (Peyronies_disease) {
      properties['Do you have Peyronies disease, angulation or any other deformation of the penis?'] = Peyronies_disease.value;
    }
  
    if (Inherited_eye_disease) {
      properties['Have ever had loss of vision because of damage to the optic nerve (such as non-arteritic anterior ischaemic optic neuropathy [NAION]) or have an inherited eye disease?'] = Inherited_eye_disease.value;
    }

    if (GalactoseIntolerance) {
      properties['Do you have galactose intolerance, Lapp lactase deficiency or glucose-galactose malabsorption?'] = GalactoseIntolerance.value;
    }

   if (DiagnosedLiver) {
      properties['Do you have previously diagnosed liver, kidney or urinary problems?'] = DiagnosedLiver.value;
   }

   if (AbnormalSugarLevels) {
      properties['Do you currently suffer from diabetes or abnormal sugar levels?'] = AbnormalSugarLevels.value;
   }

  if (HealthConditions) {
      properties['Do you have any of the following health conditions'] = HealthConditions.value;
   }

  if (currently_medication) {
      properties['Are you currently using any other medication, even if you’re not taking it regularly? Select from list below'] = currently_medication.value;
   }

   if (RecreationalDrug) {
      properties['Do you take any recreational drug such as Amyl Nitrate (poppers) or cocaine?'] = RecreationalDrug.value;
   }

    if (awarefollow) {
      properties['Please confirm that you are aware of the following'] = awarefollow.value;
   }
  
  

    if (Object.keys(properties).length === 0) {
      return;
    }
  
    let formData = {
      'items': [{
        'id': elementAttr,
        'quantity': quantity,
        'properties': properties
      }]
    };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
      window.location.href = '/cart';
    })
    .catch((error) => {
      console.error('Error:', error);
    });
    }
  else {
  var $btnBlockShown = false;
  var $btnBlock = $(".new--form--ppup").siblings('.button_block_ctm');
  var firstInvalidInput = null;
  var checkedRadioGroups = new Set();
  var checkedCheckboxGroups = new Set();

  // RADIO VALIDATION
  $("input:radio:visible").each(function () {
    var name = $(this).attr("name");
    if (!checkedRadioGroups.has(name)) {
      var $group = $("input:radio[name='" + name + "']:visible");
      var $checked = $group.filter(":checked");
      var $alert = $group.first().closest('.radio-toolbar').find('.alert:not(.hidden)');

      if ($checked.length === 0) {
        if (!firstInvalidInput) {
          firstInvalidInput = $group.first()[0];
        }

        var $toolbar = $group.first().closest('.radio-toolbar');
        if ($toolbar.find('.custom-error-msg').length === 0) {
          $toolbar.append('<div class="custom-error-msg">This field is required</div>');
        }

        if (!$btnBlockShown) {
          $btnBlock.removeClass('custom_hidden');
          setTimeout(() => $btnBlock.addClass('custom_hidden'), 6000);
          $btnBlockShown = true;
        }
      } else if ($alert.length > 0 && !firstInvalidInput) {
        firstInvalidInput = $group.first()[0];
      }

      checkedRadioGroups.add(name);
    }
  });

  // CHECKBOX VALIDATION
  $("input:checkbox").each(function () {
    var name = $(this).attr("name");
    if (!checkedCheckboxGroups.has(name)) {
      var $group = $("input:checkbox[name='" + name + "']");
      var $checked = $group.filter(":checked");
      var $alert = $group.first().closest('.multiple_checkboxes').find('.alert:not(.hidden)');

      if ($checked.length === 0) {
        if (!firstInvalidInput) {
          firstInvalidInput = $group.first()[0];
        }

        var $toolbar = $group.first().closest('.multiple_checkboxes');
        if ($toolbar.find('.custom-error-msg').length === 0) {
          $toolbar.append('<div class="custom-error-msg">This field is required</div>');
        }

        if (!$btnBlockShown) {
          $btnBlock.removeClass('custom_hidden');
          setTimeout(() => $btnBlock.addClass('custom_hidden'), 6000);
          $btnBlockShown = true;
        }
      } else if ($alert.length > 0 && !firstInvalidInput) {
        firstInvalidInput = $group.first()[0];
      }

      checkedCheckboxGroups.add(name);
    }
  });

  // SCROLL TO FIRST INVALID OR ALERT FIELD
  if (firstInvalidInput) {
    setTimeout(() => {
      firstInvalidInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      firstInvalidInput.focus();
    }, 1500);
  }
}

});
</script>

