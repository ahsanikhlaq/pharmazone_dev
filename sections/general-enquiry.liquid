                  {%- endif %}
                </div>
              </p>
            </fieldset>

            <fieldset>
              {% if section.settings.heading10_block != blank %}
                <legend>{{ section.settings.heading10_block }}</legend>
              {% endif %}

              <!-- Question 1 -->
              <p class="question-block">
                {% if section.settings.questconsent1_block != blank %}
                  <label>{{ section.settings.questconsent1_block }}</label>
                {%- endif %}
                {% if section.settings.paragraph_list3_text != blank %}
                  {{ section.settings.paragraph_list3_text -}}
                {%- endif %}
                <div class="radio-toolbar">
                  <input
                    id="aware_following_yes"
                    type="radio"
                    name="properties[Aware of the following]"
                    value="Yes"
                    class="non_change_error"
                  >
                  <label class="cstm-label" for="aware_following_yes">Yes</label>
                  <input
                    id="aware_following_no"
                    type="radio"
                    name="properties[Aware of the following]"
                    value="No"
                    class="non_change_error"
                  >
                  <label class="cstm-label" for="aware_following_no">No</label>
                  <!-- if no -->
                  {% if section.settings.alert24q_text != blank -%}
                    <span class="hidden alert alert-danger">{{ section.settings.alert24q_text }}</span>
                  {%- endif %}
                </div>
              </p>

              <p class="question-block">
                <input type="checkbox" id="confirm_terms" name="confirm_terms" value="Yes">
                {% if section.settings.inline_custom_terms != blank -%}
                  {{- section.settings.inline_custom_terms -}}
                {%- endif %}
                {% if section.settings.alert25q_text != blank -%}
                  <span id="terms-error" class="alert alert-danger">{{ section.settings.alert25q_text }}</span>
                {%- endif %}
              </p>

              {% if section.settings.alert26q_text != blank -%}
                <span class="custom_hidden alert button_block_ctm">{{ section.settings.alert26q_text }}</span>
              {%- endif %}

              {% if section.settings.check_my_btn != blank %}
                <button
                  type="submit"
                  id="submitBtn"

                  class="buy_btn custom_add_to_cart_button new--form--ppup"
                >
                  <span>{{ section.settings.check_my_btn }}</span>
                </button>
              {%- endif %}
            </fieldset>
            {% comment %}
              <div class="btns">
                {% if section.settings.next_btn != blank -%}
                  <button type="button" class="next" disabled>{{ section.settings.next_btn }}</button>
                {%- endif %}
              </div>
            {% endcomment %}
          </form>
        </fieldset>
      </form>
    </div>
  </div>
</div>

<script>
   const params = new URLSearchParams(window.location.search);
   const handle = params.get('handle');
   const variantId = params.get('variant');

  if(handle){
    fetch(`/products/${handle}.js`)
     .then(response => response.json())
