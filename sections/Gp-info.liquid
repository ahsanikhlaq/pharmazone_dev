    </div>
    <p class="gp-upload-maxsize-{{ section.id }}">{{ section.settings.upload_size_text }}</p>
    <input type="file" accept="image/*,.pdf" style="display:none;" id="gp-file-{{ section.id }}">
    <span class="gp-upload-btn-{{ section.id }}" onclick="document.getElementById('gp-file-{{ section.id }}').click()">
      {{ section.settings.upload_btn_text }}
    </span>
  </div>

  <!-- Preview UI (hidden until file selected) -->
  <div id="gp-preview-ui-{{ section.id }}" style="display:none; flex-direction:column; align-items:center; gap:10px; width:100%;">
    <img id="gp-preview-img-{{ section.id }}" src="" alt="Preview" style="display:none; max-width:100%; max-height:140px; border-radius:10px; object-fit:cover;">
    <p id="gp-preview-name-{{ section.id }}" style="font-size:13px; color:#4C3E79; font-weight:500; word-break:break-all; text-align:center;"></p>
    <div id="gp-remove-{{ section.id }}" style="background:none; border:1px solid #DDD; border-radius:20px; padding:4px 14px; font-size:12px; color:#888; cursor:pointer; font-family:'SF Pro',sans-serif;">✕ Remove</div>
  </div>

</div>

        <!-- Note -->
        {% if section.settings.note_text != blank %}
          <p class="gp-note-{{ section.id }}">
            <strong>Note:</strong> {{ section.settings.note_text }}
          </p>
        {% endif %}
      {% endif %}

    </div>

      <!-- Submit -->
      <button class="gp-submit-btn-{{ section.id }}">{{ section.settings.button_text }}</button>

    </div>
  </div>
</section>

<script>
(function() {
  // ── Tab toggle ──
  var tab1 = document.getElementById('tab-passport-{{ section.id }}');
  var tab2 = document.getElementById('tab-driving-{{ section.id }}');
  if (tab1 && tab2) {
    [tab1, tab2].forEach(function(tab) {
      tab.addEventListener('click', function() {
        [tab1, tab2].forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
      });
    });
  }

  // ── Upload preview (same logic as evidence section) ──
  var fileInput  = document.getElementById('gp-file-{{ section.id }}');
  var defaultUi  = document.getElementById('gp-default-ui-{{ section.id }}');
  var previewUi  = document.getElementById('gp-preview-ui-{{ section.id }}');
  var previewImg = document.getElementById('gp-preview-img-{{ section.id }}');
  var previewName= document.getElementById('gp-preview-name-{{ section.id }}');
  var removeBtn  = document.getElementById('gp-remove-{{ section.id }}');
  var dropzone   = document.getElementById('gp-dropzone-{{ section.id }}');

  if (!fileInput) return;

  function showPreview(file) {
    previewName.textContent = file.name;
    defaultUi.style.display = 'none';
    previewUi.style.display = 'flex';

    if (file.type.startsWith('image/')) {
      var reader = new FileReader();
      reader.onload = function(e) {
        previewImg.src = e.target.result;
        previewImg.style.display = 'block';
      };
      reader.readAsDataURL(file);
    } else {
      previewImg.style.display = 'none';
    }
  }

  function resetUpload() {
    fileInput.value = '';
    previewImg.src = '';
    previewImg.style.display = 'none';
    previewName.textContent = '';
    previewUi.style.display = 'none';
    defaultUi.style.display = '';
  }

  fileInput.addEventListener('change', function() {
    if (this.files && this.files[0]) showPreview(this.files[0]);
  });

  removeBtn.addEventListener('click', resetUpload);

  // Drag & drop
  dropzone.addEventListener('dragover', function(e) {
    e.preventDefault();
    dropzone.style.borderColor = '#4C3E79';
  });
  dropzone.addEventListener('dragleave', function() {
    dropzone.style.borderColor = '#D8D8D8';
  });
  dropzone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropzone.style.borderColor = '#D8D8D8';
    var file = e.dataTransfer.files[0];
    if (file) {
      var dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      showPreview(file);
    }
  });
})();
</script>

{% schema %}
{
  "name": "GP Information Form",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Weight Loss Profile"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Enter Your GP Information"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Card Title",
      "default": "Enter Your Detail"
    },
    {
      "type": "header",
      "content": "Upload Section"
    },
    {
      "type": "checkbox",
      "id": "show_upload",
      "label": "Show Upload Section?",
      "default": true
    },
    {
      "type": "text",
      "id": "upload_title",
      "label": "Upload Section Title",
      "default": "Upload A Valid Photo ID To Verify Your Identity."
    },
    {
      "type": "text",
      "id": "tab1_text",
      "label": "ID Tab 1 Text",
      "default": "Passport"
    },
    {
      "type": "text",
      "id": "tab2_text",
      "label": "ID Tab 2 Text",
      "default": "UK Driving License"
    },
    {
      "type": "text",
      "id": "upload_size_text",
      "label": "Upload Size Text",
      "default": "Maximum file size: 5MB."
    },
    {
      "type": "text",
      "id": "upload_btn_text",
      "label": "Upload Button Text",
      "default": "Upload File"
    },
    {
      "type": "textarea",
      "id": "note_text",
      "label": "Note Text",
      "default": "Please make sure your Photo ID is clear and shows your face, name, and date of birth for verification."
    },
    {
      "type": "header",
      "content": "Submit Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SUBMIT DETAILS"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "text",
      "id": "step-name",
      "label": "step name"
    },
    {
      "type": "text",
      "id": "next-step",
      "label": "next step"
    },
    {
      "type": "checkbox",
      "id": "new-class",
      "label": "add new class",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "field",
      "name": "Input Field",
      "settings": [
        {
          "type": "text",
          "id": "placeholder",
          "label": "Placeholder Text",
          "default": "Full Name"
        },
        {
          "type": "select",
          "id": "field_type",
          "label": "Field Type",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "number", "label": "Number" },
            { "value": "tel", "label": "Phone" },
            { "value": "email", "label": "Email" }
          ],
          "default": "text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GP Information Form",
      "blocks": [
