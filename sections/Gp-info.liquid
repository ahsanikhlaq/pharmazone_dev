{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: linear-gradient(0deg, rgba(255,255,255,0.50) 0%, rgba(255,255,255,0.50) 100%), linear-gradient(107deg, rgba(244,239,253,0.60) 0.38%, rgba(255,245,191,0.60) 100%), #FFF;
  }

  .gp-wrap-{{ section.id }} {
    max-width: 500px;
    margin: 0 auto;
    font-family: "SF Pro", -apple-system, sans-serif;
  }
.all-gp-wrapper {
    border-radius: 10px;
    background: #FFF;
    padding: 16px;
    margin-bottom: 40px;
}
  /* Progress bar */
  .gp-progress-{{ section.id }} {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .gp-progress-bar-{{ section.id }} {
    height: 3px;
    flex: 1;
    border-radius: 10px;
    background: #E0E0E0;
  }

  .gp-progress-bar-{{ section.id }}.active {
    background: #4C3E79;
  }

  /* Badge */
  .gp-badge-{{ section.id }} {
    border-radius: 66px;
    border: 0.5px solid #4C3E79;
    background: #FFF;
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    color: #4C3E79;
    font-size: 12px;
    font-weight: 400;
    margin-bottom: 12px;
  }

  /* Heading */
  .gp-heading-{{ section.id }} {
   color: var(--Black, #111);
font-family: "SF Pro";
font-size: 24px;
font-style: normal;
font-weight: 510;
line-height: 120%; /* 28.8px */
letter-spacing: -0.24px;
margin: 0;
padding-bottom: 24px;
  }

  /* Card */
  .gp-card-{{ section.id }} {
    margin-bottom: 20px;
  }

  .gp-card-title-{{ section.id }} {
   color: var(--Black, #111);
font-family: "SF Pro";
font-size: 20px;
font-style: normal;
font-weight: 510;
line-height: 120%; /* 24px */
letter-spacing: -0.8px;
text-transform: capitalize;
padding-bottom: 20px;
  }

  /* Inputs */
  .gp-fields-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  input.gp-inp-{{ section.id }} {
    width: 100%;
    box-sizing: border-box;
    padding: 20px 12px;
    color: var(--Gray, #767676);
    text-align: right;
    font-family: "SF Pro";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: -0.32px;
    text-align: start;
    background: transparent;
    border-radius: 8px;
    border: 1px solid var(--light-gray-20, #E0E0E0);
    background: var(--White, #FFF);
  }

  input.gp-inp-{{ section.id }}::placeholder {
    color: #ABABAB;
  }

  input.gp-inp-{{ section.id }}:focus {
    border-color: #4C3E79;
    background: #FFF;
  }

  /* Upload section */
  .gp-upload-title-{{ section.id }} {
    color: #111;
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 14px;
  }

  /* ID type toggle */
  .gp-id-toggle-{{ section.id }} {
    display: flex;
    background: #F2F2F2;
    border-radius: 60px;
    padding: 5px;
    gap: 4px;
    margin-bottom: 16px;
    height: 44px;
    box-sizing: border-box;
    border-radius: 60px;
background: linear-gradient(0deg, #FDFDFD 0%, #FDFDFD 100%), #FFF;
  }

  .gp-id-tab-{{ section.id }} {
    flex: 1;
    border: none;
    border-radius: 36px;
    background: transparent;
    color: #4C3E79;
    font-family: "SF Pro", -apple-system, sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .gp-id-tab-{{ section.id }}.active {
    background: linear-gradient(0deg, rgba(255,255,255,0.50) 0%, rgba(255,255,255,0.50) 100%), linear-gradient(107deg, #F4EFFD 0.38%, #FFF5BF 100%);
    color: #111;
    font-weight: 600;
  }

  /* Upload box */
  .gp-upload-box-{{ section.id }} {
    border-radius: 8px;
border: 1px solid var(--light-gray-20, #E0E0E0);
background: var(--White, #FFF);
    padding: 28px 20px;
    text-align: center;
    margin-bottom: 10px;
  }

  .gp-upload-icon-{{ section.id }} {
    margin-bottom: 8px;
  }

  .gp-upload-maxsize-{{ section.id }} {
    color: #ABABAB;
    font-size: 12px;
    margin-bottom: 14px;
  }

  .gp-upload-btn-{{ section.id }} {
    border-radius: 8px;
    background: #4C3E79;
    border: none;
    padding: 10px 24px;
    color: #FFF;
    font-family: "SF Pro", -apple-system, sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
  }

  /* Note */
  .gp-note-{{ section.id }} {
    color: #888;
    font-size: 12px;
    line-height: 1.5;
    margin-bottom: 5px;
  }

  .gp-note-{{ section.id }} strong {
    color: #555;
  }

  /* Submit */
  .gp-submit-btn-{{ section.id }} {
    display: block;
    width: 100%;
    border-radius: 45px;
    background: #4C3E79;
    border: none;
    padding: 16px;
    color: #FFF;
    font-family: "SF Pro", -apple-system, sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    box-sizing: border-box;
  }

   .m-gp .gp-card-{{ section.id }} {
    margin: 0;
   }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .gp-heading-{{ section.id }} {
      font-size: 20px;
    }
  }
{%- endstyle -%}

<section class="new-qes-section {% if section.settings.new-class %}m-gp{% endif %} section-{{ section.id }}-padding" data-step = '{{ section.settings.step-name }}' next-step = '{{ section.settings.next-step }}'>
  <div class="page-width">
    <div class="gp-wrap-{{ section.id }}">
      <!-- Badge -->
      {% if section.settings.badge_text != blank %}
        <div class="wl-profile">{{ section.settings.badge_text }}</div>
      {% endif %}

      <!-- Heading -->
      <h2 class="gp-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        <div class="all-gp-wrapper">
      <!-- Form Card -->
      <div class="gp-card-{{ section.id }}">
        {% if section.settings.card_title != blank %}
          <p class="gp-card-title-{{ section.id }}">{{ section.settings.card_title }}</p>
        {% endif %}

        <div class="gp-fields-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'field' %}
              <input
                type="{{ block.settings.field_type }}"
                placeholder="{{ block.settings.placeholder }}"
                class="gp-inp-{{ section.id }}"
              >
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <!-- Upload Section -->
      {% if section.settings.show_upload %}
        <p class="gp-upload-title-{{ section.id }}">{{ section.settings.upload_title }}</p>

        <!-- ID type toggle -->
        <div class="gp-id-toggle-{{ section.id }}">
          <button class="gp-id-tab-{{ section.id }} active" id="tab-passport-{{ section.id }}">
            {{ section.settings.tab1_text }}
          </button>
          <button class="gp-id-tab-{{ section.id }}" id="tab-driving-{{ section.id }}">
            {{ section.settings.tab2_text }}
          </button>
        </div>

        <!-- Upload box -->
       <!-- Upload box -->
