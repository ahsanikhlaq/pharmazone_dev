

{% style %}
.custom--{{ section.id }}--review .reviews-header{
  margin-bottom: {{ section.settings.btm_spacing }}px;
}

{% endstyle %}  


<section class="reviews-wrapper page-width custom--{{ section.id }}--review">
  <div class="reviews-header">

    <h2
          id="SectionHeading-{{ section.id }}"
          class="collection-list-title custom--section--heading inline-richtext {{ section.settings.heading_size }}"
        >
          {{ section.settings.heading }}
        </h2>

    {% if section.settings.subheading != blank %}
    <div class="collection__description ctm-section-subheading {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.subheading }}
        </div>
    {% endif %}
    
  </div>
  <div class="reviews-blocks">
    {% for block in section.blocks %}
      <div class="review-block">
       {% if block.settings.review_url != blank %} <a href="{{ block.settings.review_url }}" target="_blank"> {% endif %}
          {% if block.settings.review_image %}
            <img src="{{ block.settings.review_image | img_url: 'master' }}" alt="Review Image">
          {% endif %}
       {% if block.settings.review_url != blank %}  </a>   {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Reviews Section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "⭐ Your Reviews, Our Pride",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "range",
      "id": "btm_spacing",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Heading Bottom space",
      "default": 30
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Step-by-Step Overview"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.featured-collection.settings.description_style.label",
      "options": [
        {
          "value": "body",
          "label": "t:sections.featured-collection.settings.description_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.featured-collection.settings.description_style.options__2.label"
        },
        {
          "value": "uppercase",
          "label": "t:sections.featured-collection.settings.description_style.options__3.label"
        }
      ],
      "default": "body"
    },
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Review Platform Image"
        },
        {
          "type": "url",
          "id": "review_url",
          "label": "Review Platform URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
.reviews-wrapper {
  text-align: center;
  padding-top:{{section.settings.padding_top}}px;
  padding-bottom:{{section.settings.padding_bottom}}px;
}

/* .reviews-header h2 {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 0px;
} */

.reviews-header p {
  font-size: 14px;
  color: #555;
  margin-bottom: 30px;
  margin-top: 0px;
}

.reviews-blocks {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
}

.review-block {
  background: #f3f3f3;
  padding: 20px;
  width: 100%;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
}

.review-block img {
  max-width: 100%;
  height: auto;
  width: 212px;
}
  @media screen and (max-width: 600px){
    .reviews-blocks{
      gap: 10px;
      grid-template-columns: repeat(1, 1fr);
    }
    .review-block{
      padding: 15px;
    }
  }
</style>
