    padding-top: {{ section.settings.mbl_padding_top }}px;
    padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
  }
  .cs_app_blocks_main{
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 24px;
}
.cs_app_block_on_title{
    font-size: 20px;
    line-height: 120%; /* 24px */
    letter-spacing: 0px;
    font-weight: 600;
}
.cs_app_block_title_rictext p{
    font-size: 14px;
    line-height: 120%; /* 16.8px */
    letter-spacing: 0px;
    font-weight: 300;
}
.cs-app_progress-container {
      margin-top: 24px;
}
.cs_app_block_text_loss{
    font-size: 14px;9
}
.cs-app_block_loss_weight_num{
font-size: 32px;
line-height: 28px;
}
.cs-app_block_loss_weight_unit{
    font-size: 14px;
}
.cs_app_title p{
font-size: 30px;
line-height: 120%; /* 36px */
max-width: 300px;
}
.cs_app_title p strong{
font-size: 30px;
line-height: 120%; /* 36px */
} 

.cs_app_block_on_text {
    bottom: 8px;
    left: 8px;
    right: 8px;
    border-radius: 16px;
    height: auto;
    padding: 16px;
}
.cs_app_block_on_butt_mbl{
    display: block;
    margin: 24px auto 0 auto;
    padding: 16px;
    font-size: 16px;
}
.cs_app_block_on_butt_des{
   display: none;
}
.cs-app_block_on_text_richtext{
    font-size: 14px;
    line-height: 120%; /* 16.8px */
    letter-spacing: 0px;
    padding-top: 8px;
