<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.back_color }};
     position: relative;
}   
.cs_app_title p{
    margin: 0; 
    color: var(--Black, #111);
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 74.4px */
    letter-spacing: -1.24px;
    max-width: 610px;
    margin: 0 auto;
}
.cs_app_title p strong{
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: -1.24px;
}
.cs_app_blocks_main{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
}
.cs_app_block_img{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
    border-radius: 20px;
}
.cs_app_block_on_title{
    margin: 0;
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 26px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 33.6px */
    letter-spacing: 0px;
    text-transform: capitalize;
    max-width: 340px;
}
.cs_app_block_on_butt{
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: 0px;
    text-transform: capitalize;
    border-radius: 75px;
    background: var(--Yellow, #FFD902);
    border: 1px solid #FFD902;
    display: flex;
    padding: 16px 24px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    min-width: fit-content;
    margin-right: 20px;
    cursor: pointer;
}
.cs_app_block_text_loss{
    color: #FFF;
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%; /* 19.2px */
}
.cs-app_block_loss_weight{
    display: flex;
    align-items: end;
    gap: 4px;
}
.cs-app_block_loss_weight_num{
    color: #FFF;
    font-family: var(--custom-fonts);
    font-size: 40px;
    font-style: normal;
    font-weight: 400;
    line-height: 37px; /* 48px */
    letter-spacing: 1px;
}
.cs-app_block_loss_weight_unit{
    color: #FFF;
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: 1px;
}
.cs-app_block_on_text_richtext{
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 19.2px */
    letter-spacing: 0px;
    text-transform: capitalize;
    padding-top: 24px;
}
.cs-app_block_on_text_richtext p{
 margin: 0;
}
.cs_app_block_in{
    position: relative;
}
.cs_app_block_on_text{
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px; 
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.13);
    backdrop-filter: blur(20px);
    {% comment %} display: flex; {% endcomment %}
    height: 204px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: start;
}
.cs_block_on_title_butt {
    display: flex;
    justify-content: space-between;
    align-items: start;
        width: 100%;
}
.cs_app_block_title_rictext p{
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 19.2px */
    letter-spacing: -0.64px;
    text-transform: math-auto;
    padding-top: 10px;
        max-width: 340px;
        margin: 0;
        text-transform: capitalize;
}
.cs-app_progress-container {
  width: 100%;
      margin-top: 29px;
}
.cs-app_progress-track {
  width: 100%;
  height: 20px;
  border-radius: 60px;
  background: var(--Warm-color, #FAF8ED);
  overflow: hidden;
  position: relative;
}
.cs-app_progress-fill {
  width: 0%;
  height: 100%;
  border-radius: 60px;
  background: var(--Yellow, #FFD902);
  transition: width 1.5s ease-in-out;
}

.cs-app_labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
}
.cs-app_labels_text{
    color: #FFF;
    font-family: var(--custom-fonts);
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%; /* 16.8px */
    letter-spacing: -0.5px;
}
.cs_app_block_on_butt_mbl{
    display: none;
}
.cs_app_block_on_butt_des{
   display: block;
}
 @media screen and (max-width:768px){
