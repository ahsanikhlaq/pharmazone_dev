/* TOP STEP BADGE */
.step-badge {
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.19);
    background: rgba(255, 255, 255, 0.20);
    position: absolute;
    left: 17.358px;
    top: 14.956px;
    transform: rotate(-0.043deg);
    padding: 16px 30px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 125%; /* 20px */
    letter-spacing: 0px;
}

/* BOTTOM TABS */
.step-tabs {
  position: absolute;
  bottom: 20px;
  left: 24px;
  right: 24px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.step-tab {
    color: var(--Light-Gray, #F9F9F9);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%; /* 19.2px */
    letter-spacing: -0.32px;
    border-radius: 70px;
    border: 0.5px solid #FFF;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(20px);
    padding: 16px;
}
/* ===== ONE TAB → CENTER ===== */
.step-tabs:has(.step-tab:only-child) {
  justify-content: center;
}


.step-tabs:has(.step-tab:nth-child(4)) .step-tab:first-child {
    max-width:100%;
  width:100%;
  text-align: center;
}
.step-tabs:has(.step-tab:nth-child(4)) .step-tab:not(:first-child) {
  flex: 0 0 calc(33.333% - 7px);
  max-width: calc(33.333% - 7px);
  text-align: center;
}



.step-tabs:has(.step-tab:nth-child(4)) .step-tab:not(:first-child) {
  flex: 0 0 auto;
}

.step-tabs:has(.step-tab:nth-child(4)) .step-tab:not(:first-child) {
  flex: 1 1 calc((100% - 120px) / 3);
  max-width: calc((100% - 125px) / 3);
}

