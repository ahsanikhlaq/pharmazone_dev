<section class="three-step-section-{{ section.id }}">

  <div class="page-width">
    <div class="main-wrapper-content">

    {% if section.settings.heading != blank %}
      <div class="three-step-heading">
        {{ section.settings.heading }}
      </div>
    {% endif %}
     {% if section.settings.tag != blank %}
                  <div class="step-tag mob">{{ section.settings.tag }}</div>
                {% endif %}

    <div class="swiper threeStepSwiper-{{ section.id }}">
      <div class="swiper-wrapper">

        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }} id="slide-{{ forloop.index }}">
            <div class="step-card">

              <div class="step-left">
                {% if block.settings.tag != blank %}
                  <div class="step-tag des">{{ block.settings.tag }}</div>
                {% endif %}

                <div class="step-title">
                  {{ block.settings.title }}
                </div>

                <div class="step-desc des">
                  {{ block.settings.description }}
                </div>

                <div class="step-desc mob">
                  {{ block.settings.description_mob }}
                </div>
              </div>

              <div class="step-right">
               

                {% if block.settings.image != blank %}
                    <div class="step-image cs_card_scale_animation">
                        {{
                            block.settings.image
                            | image_url: width: 800
                            | image_tag: class: 'step-image-img'
                        }}

                        {% if block.settings.step_label != blank %}
                    <div class="step-badge">
                        {{ block.settings.step_label }}
                    </div>
                {% endif %} 

                <div class="step-tabs">
                  {% if block.settings.tab1 != blank %}
                    <div class="step-tab">{{ block.settings.tab1 }}</div>
                  {% endif %}
                  {% if block.settings.tab2 != blank %}
                    <div class="step-tab">{{ block.settings.tab2 }}</div>
                  {% endif %}
                  {% if block.settings.tab3 != blank %}
                    <div class="step-tab">{{ block.settings.tab3 }}</div>
                  {% endif %}
                  {% if block.settings.tab4 != blank %}
                    <div class="step-tab">{{ block.settings.tab4 }}</div>
                  {% endif %}
                  {% if block.settings.tab5 != blank or  block.settings.image_5 != blank%}
                    <div class="step-tab step-tab-5">

                        <span class="step-tab-text">
                        {{ block.settings.tab5 }}
                        </span>

                        {% if block.settings.image_5 != blank %}
                        <span class="step-tab--image">
                            {{
                            block.settings.image_5
                            | image_url: width: 60
                            | image_tag: alt: block.settings.tab5
                            }}
                        </span>
                        {% endif %}

                    </div>
                    {% endif %}

                </div>


                  </div>
                {% endif %}

                

              </div>

            </div>
          </div>
        {% endfor %}

      </div>
      <div class="swiper-pagination cs-pag"></div>
    </div>

     {% if section.settings.icon != blank %}
                    <img src="{{ section.settings.icon | image_url }}" alt="" class="abs-image">
    {% endif %}
      {% if section.settings.icon_mob != blank %}
                    <img src="{{ section.settings.icon_mob | image_url }}" alt="" class="abs-image-mob">
    {% endif %}
    
</div>


</div>

 
</section>


<script>
document.addEventListener("DOMContentLoaded", function () {

  const sectionId = "{{ section.id }}";
  const swiperSelector = ".threeStepSwiper-" + sectionId;
  const paginationSelector = ".threeStepPagination";

  function initSwiper() {

    const el = document.querySelector(swiperSelector);
    if (!el) return;

    if (window.innerWidth > 768) {

      if (!el.classList.contains("swiper-initialized")) {
        new Swiper(swiperSelector, {
          slidesPerView: 1,
          spaceBetween: 0,
          loop: false,

          pagination: {
            el: '.swiper-pagination',
            clickable: true,
          },

        });
      }

    } else {

      if (el.swiper) {
        el.swiper.destroy(true, true);
      }

    }
  }

  initSwiper();
  window.addEventListener("resize", initSwiper);

});

</script>
