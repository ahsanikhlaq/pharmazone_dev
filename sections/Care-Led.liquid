<section class="section-{{ section.id }}">
  <div class="{% if section.settings.page_width %}page-width{% endif %}">

    {% if section.settings.heading != blank %}
      <div class="main-header">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    <div class="clinical-wrapper">

     <!-- LEFT SIDE -->
      <div class="left-media">

        {% if section.settings.image_desktop != blank %}
          <picture>
            {% if section.settings.image_mobile != blank %}
              <source media="(max-width:768px)" srcset="{{ section.settings.image_mobile | image_url }}">
            {% endif %}
            <img src="{{ section.settings.image_desktop | image_url }}" alt="">
          </picture>
        {% endif %}

        <div class="abs-content">

        {% if section.settings.overlay_text != blank %}
          <div class="left-overlay-text">
            {{ section.settings.overlay_text }}
          </div>
        {% endif %}

        {% if section.settings.overlay_number != blank %}
          <div class="left-overlay-number">
            {{ section.settings.overlay_number }}
          </div>
        {% endif %}

      </div>
      </div>


      <!-- RIGHT SIDE -->
      <div class="right-clinical">

        {% for block in section.blocks %}
          <div class="clinical-card" {{ block.shopify_attributes }}>

            {% if block.settings.avatar != blank or block.settings.avatar_mobile != blank %}
          <div class="clinical-avatar">
           <a href="{{ block.settings.link }}">
            {% if block.settings.avatar != blank %}
                    <img 
                        src="{{ block.settings.avatar | image_url }}" 
                        alt=""
                        class="avatar-desktop"
                    >
                    {% endif %}

                    {% if block.settings.avatar_mobile != blank %}
                    <img 
                        src="{{ block.settings.avatar_mobile | image_url }}" 
                        alt=""
                        class="avatar-mobile"
                    >
                    {% endif %}

                    <h4 class="proff-name mob">{{ block.settings.name }}</h4>
                  </a>
                </div>
            {% endif %}


            <div class="clinical-content">
              <h4 class="proff-name des">{{ block.settings.name }}</h4>
              <p class="proff-desc"><span>{{ block.settings.description }}</span><span>{% if block.settings.full_bio != blank %}
                <sapn 
                  class="read-more-btnnn"
                  data-modal-id="cp-modal-{{ block.id }}"
                >Read more</span>
              {% endif %}</span></p>
              <div class="proff-position">{{ block.settings.position }}</div>

              
            </div>

            {% if block.settings.icon != blank %}
                    <img src="{{ block.settings.icon | image_url }}" alt="" class="bas-image">
            {% endif %}
              {% if block.settings.icon_mob != blank %}
                            <img src="{{ block.settings.icon_mob | image_url }}" alt="" class="bas-image-mob">
            {% endif %}

          </div>
        {% endfor %}

        {% if section.settings.button_label != blank %}
          <div class="section-btn">
            <a class="cs_faq_sec_button_des_hover" href="{{ section.settings.button_link }}">
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}

      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════
     MODALS — one per block
══════════════════════════════════════ -->
{% for block in section.blocks %}
  {% if block.settings.full_bio != blank %}
  <div class="cp-modal-overlay" id="cp-modal-{{ block.id }}" role="dialog" aria-modal="true">
    <div class="cp-modal-box">

      <!-- Close -->
      <button class="cp-modal-close" aria-label="Close">&#x2715;</button>

      <!-- Header -->
      <div class="cp-modal-header">
        {% if block.settings.avatar != blank %}
        <div class="cp-modal-avatar">
          <img src="{{ block.settings.avatar | image_url }}" alt="">
        </div>
        {% endif %}
        <div class="cp-modal-title">
          <div class="cp-modal-name">{{ block.settings.name }}</div>
          <div class="cp-modal-position">{{ block.settings.position }}</div>
        </div>
      </div>

      <div class="cp-modal-divider"></div>

      <!-- Full bio -->
      <div class="cp-modal-body">
        {{ block.settings.full_bio }}
      </div>

    </div>
  </div>
  {% endif %}
{% endfor %}


<script>
(function() {
  // Open modal
  document.querySelectorAll('.read-more-btnnn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var id = btn.getAttribute('data-modal-id');
      var overlay = document.getElementById(id);
      if (overlay) {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  // Close on overlay click or close button
  document.querySelectorAll('.cp-modal-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) closeModal(overlay);
    });
    var closeBtn = overlay.querySelector('.cp-modal-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        closeModal(overlay);
      });
    }
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.cp-modal-overlay.active').forEach(closeModal);
    }
  });

  function closeModal(overlay) {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }
})();
</script>


{% schema %}
{
  "name": "Clinical Professionals",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "page_width",
      "label": "Enable Page Width",
      "default": true
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f7f7f7"
    },

    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },

    {
      "type": "richtext",
      "id": "overlay_text",
      "label": "Overlay Text"
    },
    {
      "type": "range",
      "id": "text_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay Text Top Position",
      "default": 10
    },
    {
      "type": "range",
      "id": "text_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay Text Left Position",
      "default": 10
    },

    {
      "type": "text",
      "id": "overlay_number",
      "label": "Overlay Number Text"
    },
    {
      "type": "range",
      "id": "number_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Number Bottom Position",
      "default": 10
    },
    {
      "type": "range",
      "id": "number_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Number Left Position",
      "default": 10
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Book A Free Consultation"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top Desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom Desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top Mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom Mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40
    }
  ],

  "blocks": [
    {
      "type": "person",
      "name": "Clinical Person",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "avatar",
