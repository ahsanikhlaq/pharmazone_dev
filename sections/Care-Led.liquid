{% style %}
.section-{{ section.id }} {
  background: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}
@media (max-width: 768px) {
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
}
.section-{{ section.id }} * {
    margin:0px;
}
.section-{{ section.id }} .page-width {
  margin:0 auto;
}

   .main-header  {
    max-width:660px;
    margin:0 auto 50px;
  
 }
   .main-header  p {
        color: #111;
        text-align: center;
        font-family: var(--custom-fonts);
        font-size: 62px;
        font-style: normal;
        font-weight: 600;
        line-height: 110%; /* 68.2px */
        letter-spacing: -1.24px;
        margin:0px;
  }
   .main-header strong {
        color: var(--Purple, #4C3E79);
        font-family: var(--custom-fonts);
        font-size: 62px;
        font-style: normal;
        font-weight: 600;
        line-height: 110%;
        letter-spacing: -1.24px;
  }
.clinical-wrapper {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: stretch;
}

@media (max-width: 900px) {
  .clinical-wrapper {
    grid-template-columns: 1fr;
  }
}

.left-media {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
}

.left-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  max-height: 850px;
}
.abs-content {
    display: flex;
    padding: 20px;
    justify-content: space-between;
    align-items: center;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.26);
    position: absolute;
    bottom: 20px;
    right: 22px;
    left: 22px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}
.left-overlay-text p {
    color: var(--White, #FFF);
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 26px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 31.2px */
    letter-spacing: -0.65px;
    text-transform: capitalize;
    z-index: 2;
    margin:0px;
}

.left-overlay-number {
  color: #FFF;
text-align: center;
font-family: var(--custom-fonts);
font-size: 28px;
font-style: normal;
font-weight: 700;
line-height: 120%; /* 33.6px */
letter-spacing: -0.56px;
margin:0px;
}

.right-clinical {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.clinical-card {
    border-radius: 12px;
    background: var(--Warm-color, #FAF8ED);
    display: flex;
    padding: 30px;
    display: flex;
    align-items: stretch;
    gap: 32px;
    align-self: stretch;
    position:relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    z-index: 1;
    
}
.clinical-card:hover{
  transform: scale(1);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
}
.section-{{ section.id }} .bas-image {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  height:100%;
   z-index: -1;
  
}
.section-{{ section.id }} .bas-image-mob {
  display:none;
}

.clinical-avatar {
    width: 150px;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
}
.clinical-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.clinical-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    align-self: stretch;
}
.clinical-content .proff-name {
    margin:0px;
}

.clinical-content .proff-name p {
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 27px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 32.4px */
    letter-spacing: -0.54px;
    margin:0px;
}
.clinical-content .proff-name strong {
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 27px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: -0.54px;
    margin:0px;
}
.proff-desc {
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 21.6px */
    letter-spacing: -0.5px;
    margin:0px;

    /* Clamp to 2 lines */
    /* display: -webkit-box; */
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.proff-position p {
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: -0.5px;
    margin:0px;
}
.proff-position strong {
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 21px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 28.8px */
    letter-spacing: -0.5px;
    margin:0px;
}
.section-btn {
  margin-top: 24px;
}

.section-btn a {
   color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: -1.08px;
    text-transform: capitalize;
    display: flex;
    padding: 16px 30px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    border-radius: 75px;
    background: var(--Yellow, #FFD902);
    text-decoration:none;
    max-width:max-content;
    border: 1px solid #FFD902;
    cursor: pointer;
    
}
.proff-name.mob {
    display:none;
}

/* ── Read More link ── */
.read-more-btnnn {
  display: inline-block;
  color: var(--Purple, #4C3E79);
  font-family: var(--custom-fonts);
  font-size: 15px;
  font-weight: 600;
  letter-spacing: -0.3px;
  text-decoration: underline;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  margin-top: 4px;
}
.read-more-btnnn:hover {
  opacity: 0.75;
}

/* ── Modal overlay ── */
.cp-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.cp-modal-overlay.active {
  display: flex;
}

/* ── Modal box ── */
.cp-modal-box {
  background: #fff;
  border-radius: 16px;
  padding: 32px;
  max-width: 690px;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  animation: cpModalIn 0.25s ease;
  border-radius: 12px;
background: var(--Warm-color, #FAF8ED);
}
@keyframes cpModalIn {
  from { opacity: 0; transform: translateY(16px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0)   scale(1); }
}

/* ── Modal close button ── */
.cp-modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 32px;
  height: 32px;
  background: #f0f0f0;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  line-height: 1;
  color: #333;
  transition: background 0.2s;
}
.cp-modal-close:hover { background: #e0e0e0; }

/* ── Modal header ── */
.cp-modal-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}
.cp-modal-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.cp-modal-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.cp-modal-title {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cp-modal-name {
  font-family: var(--custom-fonts);
  font-size: 20px;
  font-weight: 700;
  color: #111;
  margin: 0;
}
.cp-modal-name strong {
  color: var(--Purple, #4C3E79);
}
.cp-modal-position {
  font-family: var(--custom-fonts);
  font-size: 15px;
  font-weight: 500;
  color: #555;
  margin: 0;
}
.cp-modal-position strong {
  font-weight: 700;
  color: #111;
}
.cp-modal-position p{
  margin: 0;
}

/* ── Divider ── */
.cp-modal-divider {
  height: 1px;
  background: #eee;
  margin: 0 0 20px;
}

/* ── Modal body text ── */
.cp-modal-body {
  color: #000;
font-family: "SF Pro";
font-size: 18px;
font-style: normal;
font-weight: 400;
line-height: 140%; /* 25.2px */
letter-spacing: -0.5px;
border-top: 1px solid #E0E0E0;
padding-top: 7px;
}
