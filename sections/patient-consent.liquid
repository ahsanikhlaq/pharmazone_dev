              </svg>
          </div>
          <p class="wp-guide-title-{{ section.id }}">{{ section.settings.guide_title }}</p>
          <p class="wp-guide-text-{{ section.id }}">{{ section.settings.guide_text }}</p>
        </div>

        <!-- 2x2 example grid -->
        <div class="wp-examples-{{ section.id }}">

          <div class="wp-example-item-{{ section.id }}">
            {% if section.settings.example_good_1 != blank %}
              <img src="{{ section.settings.example_good_1 | image_url: width: 400 }}" alt="Good example front">
            {% else %}
              <div class="wp-example-placeholder-{{ section.id }}">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#CCC"/><path d="M8 17l3-3 2 2 3-4 4 5H4l4-5z" fill="#999"/></svg>
              </div>
            {% endif %}
            <span class="wp-example-badge-{{ section.id }} good">Good</span>
            <p class="wp-example-caption-{{ section.id }}">{{ section.settings.caption_good_1 | default: 'Full body, tight fitted clothing.' }}</p>
          </div>

          <div class="wp-example-item-{{ section.id }}">
            {% if section.settings.example_bad_1 != blank %}
              <img src="{{ section.settings.example_bad_1 | image_url: width: 400 }}" alt="Bad example">
            {% else %}
              <div class="wp-example-placeholder-{{ section.id }}">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#CCC"/><path d="M8 17l3-3 2 2 3-4 4 5H4l4-5z" fill="#999"/></svg>
              </div>
            {% endif %}
            <span class="wp-example-badge-{{ section.id }} bad">Bad</span>
            <p class="wp-example-caption-{{ section.id }}">{{ section.settings.caption_bad_1 | default: 'Close up of face, no body shown.' }}</p>
          </div>

          <div class="wp-example-item-{{ section.id }}">
            {% if section.settings.example_good_2 != blank %}
              <img src="{{ section.settings.example_good_2 | image_url: width: 400 }}" alt="Good example side">
            {% else %}
              <div class="wp-example-placeholder-{{ section.id }}">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#CCC"/><path d="M8 17l3-3 2 2 3-4 4 5H4l4-5z" fill="#999"/></svg>
              </div>
            {% endif %}
            <span class="wp-example-badge-{{ section.id }} good">Good</span>
            <p class="wp-example-caption-{{ section.id }}">{{ section.settings.caption_good_2 | default: 'Full body, tight fitted clothing.' }}</p>
          </div>

          <div class="wp-example-item-{{ section.id }}">
            {% if section.settings.example_bad_2 != blank %}
              <img src="{{ section.settings.example_bad_2 | image_url: width: 400 }}" alt="Bad example side">
            {% else %}
              <div class="wp-example-placeholder-{{ section.id }}">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#CCC"/><path d="M8 17l3-3 2 2 3-4 4 5H4l4-5z" fill="#999"/></svg>
              </div>
            {% endif %}
            <span class="wp-example-badge-{{ section.id }} bad">Bad</span>
            <p class="wp-example-caption-{{ section.id }}">{{ section.settings.caption_bad_2 | default: 'Dark clothing hides body shape.' }}</p>
          </div>

        </div>

        <!-- Upload boxes -->
        <div class='new-uplaod-wrapper'>
        <p class="wp-upload-heading-{{ section.id }}">{{ section.settings.upload_heading }}</p>

        <div class="wp-upload-row-{{ section.id }}">

<div class="wp-upload-box-{{ section.id }}" id="wp-box-front-{{ section.id }}" onclick="document.getElementById('wp-input-front-{{ section.id }}').click()">
    <input type="file" accept="image/*,.pdf" id="wp-input-front-{{ section.id }}" style="display:none;">             
            <div id="wp-icon-front-{{ section.id }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
  <g clip-path="url(#clip0_2303_11585)">
