<script>
(function() {
  var sId = '{{ section.id }}';

  /* ── Elements ── */
  var wpPhase        = document.getElementById('wp-phase-'           + sId);
  var consentPhase   = document.getElementById('consent-phase-'      + sId);
  var phase1Btn      = document.getElementById('pcc-submit-fixed-'   + sId);
  var phase1Wrap     = document.getElementById('pc-btn-fixedd-wrap-' + sId);
  var consentBtn     = document.getElementById('pc-submit-new-'      + sId);
  var mobileWpBtn    = document.getElementById('wp-submit-mobile-'   + sId);
  var mobileAgreeBtn = document.getElementById('pc-submit-mobile-'   + sId);

  /* ══════════════════════════════════════════
     PHASE 1: upload previews
  ══════════════════════════════════════════ */
  function setupUpload(inputId, previewId, filenameId, removeId, iconId, boxId, labelId) {
    var input     = document.getElementById(inputId);
    var preview   = document.getElementById(previewId);
    var filename  = document.getElementById(filenameId);
    var removeBtn = document.getElementById(removeId);
    var icon      = document.getElementById(iconId);
    var box       = document.getElementById(boxId);
    var label     = document.getElementById(labelId);
    if (!input) return;

    input.addEventListener('change', function() {
      var file = this.files && this.files[0];
      if (!file) return;
      filename.textContent    = file.name;
      filename.style.display  = 'block';
      removeBtn.style.display = 'inline-block';
      box.classList.add('has-file');
      label.style.display = 'none';
      icon.style.display  = 'none';
      if (file.type.startsWith('image/')) {
        var reader = new FileReader();
        reader.onload = function(e) { preview.src = e.target.result; preview.style.display = 'block'; };
        reader.readAsDataURL(file);
      }
      checkPhase1Ready();
    });

    removeBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      input.value = '';
      preview.src = ''; preview.style.display = 'none';
      filename.style.display = 'none'; filename.textContent = '';
      removeBtn.style.display = 'none';
      box.classList.remove('has-file');
      label.style.display = 'block';
      icon.style.display  = 'block';
      setTimeout(checkPhase1Ready, 50);
    });
  }

  setupUpload('wp-input-front-' + sId, 'wp-preview-front-' + sId, 'wp-filename-front-' + sId, 'wp-remove-front-' + sId, 'wp-icon-front-' + sId, 'wp-box-front-' + sId, 'wp-label-front-' + sId);
  setupUpload('wp-input-side-'  + sId, 'wp-preview-side-'  + sId, 'wp-filename-side-'  + sId, 'wp-remove-side-'  + sId, 'wp-icon-side-'  + sId, 'wp-box-side-'  + sId, 'wp-label-side-'  + sId);

 /* ── MediaRecorder video capture ── */
(function() {
  var stream      = null;
  var recorder    = null;
  var chunks      = [];
  var timerInt    = null;
  var seconds     = 0;
  var recordedFile = null;

  var cameraPreview = document.getElementById('wp-camera-preview-' + sId);
  var previewVideo  = document.getElementById('wp-preview-video-'  + sId);
  var filenameEl    = document.getElementById('wp-filename-video-' + sId);
  var defaultUI     = document.getElementById('wp-video-default-'  + sId);
  var recorderUI    = document.getElementById('wp-video-recorder-' + sId);
  var doneUI        = document.getElementById('wp-video-done-'     + sId);
  var startBtn      = document.getElementById('wp-btn-start-rec-'  + sId);
  var stopBtn       = document.getElementById('wp-btn-stop-rec-'   + sId);
  var timerEl       = document.getElementById('wp-rec-timer-'      + sId);
  var box           = document.getElementById('wp-box-video-'      + sId);

  /* Open camera */
 window['startVideoRecorder_' + sId] = function() {
    if (stream) return; // already open
    navigator.mediaDevices.getUserMedia({ video: true, audio: true })
      .then(function(s) {
        stream = s;
        cameraPreview.srcObject = s;
        defaultUI.style.display  = 'none';
        recorderUI.style.display = 'flex';
      })
      .catch(function(err) {
        alert('Camera access denied or not available: ' + err.message);
      });
  };

  /* Start recording */
  window['startRecording_' + sId] = function() {
    if (!stream) return;
    chunks = []; seconds = 0;
    recorder = new MediaRecorder(stream);
    recorder.ondataavailable = function(e) { if (e.data.size > 0) chunks.push(e.data); };
    recorder.onstop = function() {
      var blob = new Blob(chunks, { type: 'video/webm' });
      recordedFile = new File([blob], 'recorded_video_' + Date.now() + '.webm', { type: 'video/webm' });

      /* Stop camera stream */
      stream.getTracks().forEach(function(t) { t.stop(); });
      stream = null;

      /* Show preview */
      var url = URL.createObjectURL(blob);
      previewVideo.src = url;
      filenameEl.textContent   = recordedFile.name;
      recorderUI.style.display = 'none';
      doneUI.style.display     = 'flex';
      box.classList.add('has-file');

      /* Feed into quiz-flow checkPhotoForm */
      window['_videoFile_' + sId] = recordedFile;
      checkPhase1Ready();
    };

    recorder.start();
    startBtn.style.opacity        = '0.45';
startBtn.style.pointerEvents  = 'none';
stopBtn.style.opacity         = '1';
stopBtn.style.pointerEvents   = '';
    timerEl.style.display  = 'block';

    timerInt = setInterval(function() {
      seconds++;
      timerEl.textContent = '⏺ Recording: ' + seconds + 's';
    }, 1000);
  };

  /* Stop recording */
  window['stopRecording_' + sId] = function() {
    if (recorder && recorder.state !== 'inactive') recorder.stop();
    clearInterval(timerInt);
    timerEl.style.display  = 'none';
  startBtn.style.opacity        = '1';
startBtn.style.pointerEvents  = '';
stopBtn.style.opacity         = '0.45';
stopBtn.style.pointerEvents   = 'none';
  };

  /* Cancel camera */
  window['cancelCamera_' + sId] = function() {
    if (recorder && recorder.state !== 'inactive') recorder.stop();
    if (stream) { stream.getTracks().forEach(function(t) { t.stop(); }); stream = null; }
    clearInterval(timerInt);
    recorderUI.style.display = 'none';
    defaultUI.style.display  = 'block';
  };

  /* Re-record */
  window['removeRecording_' + sId] = function() {
    recordedFile = null;
    window['_videoFile_' + sId] = null;
    if (previewVideo.src) URL.revokeObjectURL(previewVideo.src);
    previewVideo.src = '';
    filenameEl.textContent   = '';
    doneUI.style.display     = 'none';
    defaultUI.style.display  = 'block';
    box.classList.remove('has-file');
    checkPhase1Ready();
  };
})();

  /* ══════════════════════════════════════════
     PHASE 1: require all 3 files before submit
  ══════════════════════════════════════════ */
 function checkPhase1Ready() {
    var frontInput = document.getElementById('wp-input-front-' + sId);
    var sideInput  = document.getElementById('wp-input-side-'  + sId);

    var hasAll = (frontInput && frontInput.files && frontInput.files.length > 0) &&
                 (sideInput  && sideInput.files  && sideInput.files.length  > 0) &&
                 !!window['_videoFile_' + sId];

    if (phase1Btn) {
      phase1Btn.style.opacity       = hasAll ? '1'       : '0.45';
      phase1Btn.style.cursor        = hasAll ? 'pointer' : 'not-allowed';
      phase1Btn.style.pointerEvents = hasAll ? ''        : 'none';
      phase1Btn.style.background    = hasAll ? '#4C3E79' : '#B0A8CC';
    }
  }

  /* Disable on load */
  checkPhase1Ready();

  /* ══════════════════════════════════════════
     PHASE 1 → PHASE 2: switch to consent
  ══════════════════════════════════════════ */
  function showConsent() {
    if (wpPhase)      wpPhase.style.display      = 'none';
    if (consentPhase) consentPhase.style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
    updateConsentBtn();
  }

  var skipPhotos = {{ section.settings.skip_photos | json }};

  if (skipPhotos) {
    if (mobileWpBtn) mobileWpBtn.style.display = 'none';
    updateConsentBtn();
  } else {
    if (phase1Btn) {
      phase1Btn.addEventListener('click', function() {
        showConsent();
      });
    }
    if (mobileWpBtn) mobileWpBtn.addEventListener('click', showConsent);
  }

  /* ══════════════════════════════════════════
     PHASE 2: checkboxes enable consent button
  ══════════════════════════════════════════ */
  function updateConsentBtn() {
    var checkboxes = document.querySelectorAll('.pc-card-check[data-section="' + sId + '"]');
    var allChecked = true;
    checkboxes.forEach(function(cb) { if (!cb.checked) allChecked = false; });

    if (consentBtn) {
      consentBtn.disabled            = !allChecked;
      consentBtn.style.opacity       = allChecked ? '1'       : '0.45';
      consentBtn.style.cursor        = allChecked ? 'pointer' : 'not-allowed';
    }
    if (mobileAgreeBtn) {
      mobileAgreeBtn.disabled  = !allChecked;
    }
  }

  /* Run on load */
  updateConsentBtn();

  document.querySelectorAll('.pc-card-check[data-section="' + sId + '"]').forEach(function(cb) {
    cb.addEventListener('change', updateConsentBtn);
  });

})();
</script>


