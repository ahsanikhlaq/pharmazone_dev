  <defs>
    <clipPath id="clip0_2303_11585">
      <rect width="40" height="40" fill="white"/>
    </clipPath>
  </defs>
</svg>
            </div>
            <img class="wp-upload-preview-{{ section.id }}" id="wp-preview-front-{{ section.id }}" src="" alt="">
            <p class="wp-upload-label-{{ section.id }}" id="wp-label-front-{{ section.id }}">{{ section.settings.front_label | default: 'Upload your full Front Image' }}</p>
            <p class="wp-upload-filename-{{ section.id }}" id="wp-filename-front-{{ section.id }}"></p>
            <button class="wp-upload-remove-{{ section.id }}" id="wp-remove-front-{{ section.id }}" onclick="event.stopPropagation()">✕ Remove</button>
          </div>

          <div class="wp-upload-box-{{ section.id }}" id="wp-box-side-{{ section.id }}" onclick="document.getElementById('wp-input-side-{{ section.id }}').click()">
            <input type="file" accept="image/*,.pdf" id="wp-input-side-{{ section.id }}" style="display:none;">
            <div id="wp-icon-side-{{ section.id }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
