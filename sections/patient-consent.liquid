    <path d="M35.8337 3.33398H10.8337C8.53699 3.33398 6.66699 5.20398 6.66699 7.50065V25.834C6.66699 28.1307 8.53699 30.0007 10.8337 30.0007H35.8337C38.1303 30.0007 40.0003 28.1307 40.0003 25.834V7.50065C40.0003 5.20398 38.1303 3.33398 35.8337 3.33398ZM10.8337 6.66732H35.8337C36.2937 6.66732 36.667 7.04065 36.667 7.50065V19.3323L31.402 13.189C30.8437 12.534 30.0353 12.184 29.167 12.164C28.3037 12.169 27.4937 12.5523 26.9403 13.2157L20.7503 20.6457L18.7337 18.634C17.5937 17.494 15.7387 17.494 14.6003 18.634L10.0003 23.2323V7.50065C10.0003 7.04065 10.3737 6.66732 10.8337 6.66732Z" fill="#4C3E79"/>
