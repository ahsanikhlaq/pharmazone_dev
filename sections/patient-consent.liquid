{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: linear-gradient(0deg, rgba(255,255,255,0.50) 0%, rgba(255,255,255,0.50) 100%), linear-gradient(107deg, rgba(244,239,253,0.60) 0.38%, rgba(255,245,191,0.60) 100%), #FFF;
    min-height: 100vh;
  }

  .pc-wrap-{{ section.id }} {
    max-width: 500px;
    margin: 0 auto;
    font-family: "SF Pro", -apple-system, sans-serif;
    padding-bottom: 40px;
  }

  /* ═══════════════════════════════════════
     WEIGHT PHOTO UPLOAD STYLES
  ═══════════════════════════════════════ */

  .wp-heading-{{ section.id }} {
    color: var(--Black, #111);
    font-family: "SF Pro";
    font-size: 24px;
    font-style: normal;
    font-weight: 590;
    line-height: 120%;
    letter-spacing: -0.24px;
    text-align: start;
    margin: 0 0 32px;
  }

  .wp-guide-card-{{ section.id }} {
   border-radius: 16px;
background: linear-gradient(0deg, #E1DEE9 0%, #E1DEE9 100%), #FFF;
padding: 20px;
    text-align: center;
    margin-bottom: 24px;
  }

  .wp-guide-icon-{{ section.id }} {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 10px;
  }

  .wp-guide-title-{{ section.id }} {
   color: var(--Black, #111);
leading-trim: both;
text-edge: cap;
font-family: "SF Pro";
font-size: 20px;
font-style: normal;
font-weight: 700;
line-height: normal;
letter-spacing: -0.5px;
    margin: 0 0 16px;
  }

  .wp-guide-text-{{ section.id }} {
   color: var(--Black, #111);
text-align: center;
leading-trim: both;
text-edge: cap;
font-family: "SF Pro";
font-size: 14px;
font-style: normal;
font-weight: 400;
line-height: normal;
letter-spacing: -0.5px;
margin: 0;
  }

  .wp-examples-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 24px;
  }

  .wp-example-item-{{ section.id }} {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background: #FFF;
    padding: 6px;
  }

  .wp-example-item-{{ section.id }} img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .wp-example-placeholder-{{ section.id }} {
    width: 100%;
    height: 160px;
    background: #E8E8E8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wp-example-badge-{{ section.id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    border-radius: 4px;
    padding: 3px 8px;
    font-size: 11px;
    font-weight: 700;
    font-family: "SF Pro", -apple-system, sans-serif;
    color: #FFF;
    display: none;
  }

  .wp-example-badge-{{ section.id }}.good { background: #4CAF50; }
  .wp-example-badge-{{ section.id }}.bad  { background: #F44336; }

  .wp-example-caption-{{ section.id }} {
    color: #000;
text-align: center;
leading-trim: both;
text-edge: cap;
font-family: "SF Pro";
font-size: 14px;
font-style: normal;
font-weight: 510;
line-height: normal;
letter-spacing: -0.5px;
padding-top: 4px;
margin: 0;
text-align: center;
  }

  .wp-upload-heading-{{ section.id }} {
    color: var(--Black, #111);
leading-trim: both;
text-edge: cap;
font-family: "SF Pro";
font-size: 20px;
font-style: normal;
font-weight: 700;
line-height: normal;
letter-spacing: -0.5px;
    margin: 0 0 24px;
  }

  .wp-upload-row-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 14px;
  }

  .wp-upload-box-{{ section.id }} {
    border-radius: 12px;
    background: #FFF;
    padding: 24px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: border-color 0.2s ease;
    text-align: center;
    box-sizing: border-box;
    border-radius: 8px;
background: #FEFBF0;
min-height: 225px;
justify-content: center;
  }

  .wp-upload-box-{{ section.id }}:hover { border-color: #4C3E79; }

  .wp-upload-box-{{ section.id }}.has-file {
    border-color: #4C3E79;
    background: linear-gradient(107deg, rgba(244,239,253,0.2) 0.38%, rgba(255,245,191,0.2) 100%), #FFF;
  }

  .wp-upload-label-{{ section.id }} {
    color: var(--Purple, #4C3E79);
text-align: center;
font-family: "SF Pro";
font-size: 16px;
font-style: normal;
font-weight: 400;
line-height: 120%; /* 19.2px */
letter-spacing: -0.32px;
text-decoration-line: underline;
text-decoration-style: solid;
text-decoration-skip-ink: none;
text-decoration-thickness: auto;
text-underline-offset: auto;
text-underline-position: from-font;
margin: 0;
max-width: 125px;
  }

  .wp-upload-preview-{{ section.id }} {
    display: none;
    max-width: 100%;
    max-height: 80px;
    border-radius: 6px;
    object-fit: cover;
  }

  .wp-upload-filename-{{ section.id }} {
    display: none;
    font-size: 11px;
    color: #4C3E79;
    word-break: break-all;
    text-align: center;
    margin: 0;
  }

  .wp-upload-remove-{{ section.id }} {
    display: none;
    background: none;
    border: 1px solid #DDD;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 11px;
    color: #888;
    cursor: pointer;
    font-family: "SF Pro", sans-serif;
  }

  .wp-note-{{ section.id }} {
    color: var(--Gray, #545454);
text-align: center;
leading-trim: both;
text-edge: cap;
font-family: "SF Pro";
font-size: 16px;
font-style: normal;
font-weight: 510;
line-height: normal;
letter-spacing: -1px;
margin: 0;
  }

  /* ═══════════════════════════════════════
     CONSENT STYLES
  ═══════════════════════════════════════ */

  .wl-profile-{{ section.id }} {
    border-radius: 66.67px;
    border: 0.5px solid #4C3E79;
    background: #FFF;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 4px 14px;
    color: #4C3E79;
    font-family: "SF Pro";
    font-size: 12px;
    font-weight: 400;
    text-transform: capitalize;
    margin-bottom: 16px;
  }

  .pc-page-heading-{{ section.id }} {
    color: #111;
    font-family: "SF Pro";
    font-size: 24px;
    font-weight: 510;
    line-height: 120%;
    letter-spacing: -0.24px;
    margin: 0;
    padding-bottom: 24px;
  }

  .pc-card-{{ section.id }} {
    background: #FFF;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
  }

  .pc-card-title-{{ section.id }} {
    color: #111;
    font-family: "SF Pro";
    font-size: 18px;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: -0.18px;
    text-transform: capitalize;
    margin: 0;
    padding-bottom: 28px;
  }

  .pc-list-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pc-list-{{ section.id }} li {
    display: flex;
    gap: 10px;
    color: #111;
    font-family: "SF Pro";
    font-size: 14px;
    font-weight: 400;
    line-height: normal;
  }

  .pc-list-{{ section.id }} li::before {
    content: "•";
    color: #4C3E79;
    font-size: 16px;
    flex-shrink: 0;
    margin-top: -1px;
  }

  .pc-checkbox-row-{{ section.id }} {
    display: flex;
    align-items: center;
    border-radius: 6px;
    background: #FFFADE;
    gap: 8px;
    cursor: pointer;
    padding: 10px;
  }

  .pc-checkbox-{{ section.id }} {
    min-width: 18px;
    height: 18px;
    border: 1.5px solid #BDBDBD;
    border-radius: 4px;
    background: #FFF;
    flex-shrink: 0;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    position: relative;
  }

  .pc-checkbox-{{ section.id }}:checked {
    background: #4C3E79;
    border-color: #4C3E79;
  }

  .pc-checkbox-{{ section.id }}:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 3px;
    width: 5px;
    height: 9px;
    border: 2px solid #FFF;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .pc-checkbox-label-{{ section.id }} {
    color: #111;
    font-size: 13.5px;
    font-weight: 600;
    line-height: 1.4;
    cursor: pointer;
  }

  /* ═══════════════════════════════════════
     SHARED BUTTON
  ═══════════════════════════════════════ */
  .pc-btn-fixeddd{
    display: block;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: linear-gradient(to top, rgba(255,255,255,1) 60%, rgba(255,255,255,0));
    padding: 16px 20px 24px;
    text-align: center;
  }

  .pc-btn-fixed-inner-{{ section.id }} {
    max-width: 500px;
    margin: 0 auto;
  }

  .pc-btn-fixed-inner-{{ section.id }} button {
    display: block;
    width: 100%;
    border-radius: 45px;
    background: #4C3E79;
    border: none;
    padding: 17px;
    color: #FFF;
    font-family: "SF Pro", -apple-system, sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    box-sizing: border-box;
    transition: opacity 0.15s ease;
  }

  .pc-btn-fixed-inner-{{ section.id }} button:disabled {
    background: #B0A8CC;
    cursor: not-allowed;
  }

  /* .pc-btn-mobile-{{ section.id }} { display: none; } */
.new-uplaod-wrapper{
  border-radius: 16px;
background: #FFF;
padding: 20px;
    margin-bottom: 30px;
}
  @media screen and (max-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .pc-page-heading-{{ section.id }} { font-size: 20px; padding-bottom: 20px; }
    .pc-card-{{ section.id }} { padding: 16px; margin-bottom: 20px; }
    .pc-card-title-{{ section.id }} { padding-bottom: 20px; }
    .pc-list-{{ section.id }} { gap: 16px; }
    .pc-checkbox-label-{{ section.id }} { font-size: 12px; }
    .wp-example-placeholder-{{ section.id }} { height: 130px; }

    .pc-btn-mobile-{{ section.id }} {
      display: block;
      width: 100%;
      border-radius: 45px;
      background: #4C3E79;
      border: none;
      padding: 17px;
      color: #FFF;
      font-family: "SF Pro", -apple-system, sans-serif;
      font-size: 16px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      box-sizing: border-box;
      margin-top: 8px;
      transition: opacity 0.15s ease;
    }
    .pc-btn-mobile-{{ section.id }}:disabled {
      background: #B0A8CC;
      cursor: not-allowed;
    }
    .pc-btn-fixed-{{ section.id }} { display: block; }
    .wp-heading-{{ section.id }} {
      font-size: 20px;
      margin: 0 0 12px;
      letter-spacing: -0.2px;
    }
    .wp-guide-title-{{ section.id }} {
      font-size: 13px;
    }
     .wp-example-caption-{{ section.id }} {
      text-align: start;
     }
      .wp-upload-heading-{{ section.id }} {
        font-size: 18px;
      }
      .wp-upload-box-{{ section.id }} {
        border-radius: 8px;
    border: 1px solid var(--light-gray-20, #E0E0E0);
    background: #FEFBF0;
        min-height: 170px;
      }
      .wp-upload-label-{{ section.id }}{
        font-size: 14px;
      }
      .wp-note-{{ section.id }}{
        font-size: 14px;
        letter-spacing: -0.5px;
    margin: 0;
    text-align: start;
      }
  }
{%- endstyle -%}

<section
  class="new-qes-section section-{{ section.id }}-padding"
  data-step="{{ section.settings.step_name }}"
  next-step="{{ section.settings.next_step }}"
>
  <div class="page-width">
    <div class="pc-wrap-{{ section.id }}">

      <!-- ══════════════════════════════════
           PHASE 1: WEIGHT PHOTO UPLOAD
      ══════════════════════════════════ -->
<div id="wp-phase-{{ section.id }}" {% if section.settings.skip_photos %}style="display:none;"{% endif %}>
        {% if section.settings.badge_text != blank %}
          <div class="wl-profile-{{ section.id }}">Eligibility Questions</div>
        {% endif %}

        <p class="wp-heading-{{ section.id }}">{{ section.settings.wp_heading }}</p>

        <!-- Photo guide card -->
        <div class="wp-guide-card-{{ section.id }}">
          <div class="wp-guide-icon-{{ section.id }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
          <path d="M20 26.25C22.7614 26.25 25 24.0114 25 21.25C25 18.4886 22.7614 16.25 20 16.25C17.2386 16.25 15 18.4886 15 21.25C15 24.0114 17.2386 26.25 20 26.25Z" fill="#FFD902"/>
