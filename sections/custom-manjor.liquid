}
.percentage-numbers{
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 48px;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
        min-width: 16%;
}
.percentage-text p{
    margin: 0;
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 19.2px */
    letter-spacing: 0;
}
ul.mounjaro-benefits {
    padding: 0;
    margin: 24px 0 30px 0;
    list-style-type: none;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr 1fr;
    max-width: 540px;
}
.mounjaro-benefits li {
