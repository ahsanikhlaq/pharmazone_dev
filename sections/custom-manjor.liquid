    background-color: {{ section.settings.bg_color }};
    
    padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }
  .mounjaro-card {
    display: grid;
    grid-template-columns: 51% auto;
    gap: 80px;
}
.mounjaro-heading p{
  margin: 0;
  color: #0C2421;
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 74.4px */
    letter-spacing: -1.24px;
}
span.benefit-icon {
    line-height: 0;
}
.mounjaro-heading p strong{
   margin: 0;
   color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: -1.24px;
}
.mounjaro-description p{
    margin: 0;
    color: var(--Gray, #545454);
    font-family: var(--custom-fonts);
    font-size: 18px;
