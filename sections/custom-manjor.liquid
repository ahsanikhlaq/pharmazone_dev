    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const svg = document.getElementById('weight-loss-chart');
            const svgWidth = 700;
            const svgHeight = 450;
            const padding = { left: 80, right: 40, top: 60, bottom: 80 };
            const chartAreaWidth = svgWidth - padding.left - padding.right;
            const chartAreaHeight = svgHeight - padding.top - padding.bottom;

            // Data with months instead of weeks
            const dataJood = [
                [0, 100], [1, 95], [2, 88], [3, 82], [4, 78], [5, 74], [6, 72]
            ];
            
            const dataPatients = [
                [0, 100], [1, 97], [2, 92], [3, 87], [4, 82], [5, 78], [6, 76]
            ];

            const maxMonths = 6;
            const minWeight = 70;
            const maxWeight = 100;
            const weightRange = maxWeight - minWeight;

            const xScale = (month) => padding.left + (month / maxMonths) * chartAreaWidth;
            const yScale = (weight) => {
                const normalizedWeight = (weight - minWeight) / weightRange;
                return padding.top + (1 - normalizedWeight) * chartAreaHeight;
            };

            const generatePathD = (data, closed = false) => {
                if (data.length === 0) return "";
                let path = `M ${xScale(data[0][0])} ${yScale(data[0][1])}`;
                for (let i = 1; i < data.length; i++) {
                    const [month, weight] = data[i];
                    path += ` L ${xScale(month)} ${yScale(weight)}`;
                }
                if (closed) {
                    const bottomY = yScale(minWeight);
                    path += ` L ${xScale(data[data.length - 1][0])} ${bottomY}`;
                    path += ` L ${xScale(0)} ${bottomY}`;
                    path += ` Z`;
                }
                return path;
            };

            const drawGrid = () => {
                const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');

                // Y-axis line
                const yAxis = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                yAxis.setAttribute('x1', padding.left);
                yAxis.setAttribute('y1', padding.top);
                yAxis.setAttribute('x2', padding.left);
                yAxis.setAttribute('y2', svgHeight - padding.bottom);
                yAxis.classList.add('axis-line');
                g.appendChild(yAxis);

                // X-axis line
                const xAxis = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                xAxis.setAttribute('x1', padding.left);
                xAxis.setAttribute('y1', svgHeight - padding.bottom);
                xAxis.setAttribute('x2', svgWidth - padding.right);
                xAxis.setAttribute('y2', svgHeight - padding.bottom);
                xAxis.classList.add('axis-line');
                g.appendChild(xAxis);

                // Horizontal Grid Lines - matching image (100, 94, 88, 82, 76, 70)
                const gridWeights = [100, 94, 88, 82, 76, 70];
                gridWeights.forEach(weight => {
                    const y = yScale(weight);
                    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                    line.setAttribute('x1', padding.left);
                    line.setAttribute('y1', y);
                    line.setAttribute('x2', svgWidth - padding.right);
                    line.setAttribute('y2', y);
                    line.classList.add('grid-line');
                    g.appendChild(line);
                });

                svg.appendChild(g);
            };

            const drawLabels = () => {
                const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');

                // Y-Axis Title
                const yTitle = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                yTitle.textContent = 'Weight (kg)';
                yTitle.setAttribute('x', padding.left);
                yTitle.setAttribute('y', padding.top - 30);
                yTitle.classList.add('axis-title');
                yTitle.setAttribute('text-anchor', 'start');
                g.appendChild(yTitle);

                // Y-axis labels - matching image (100, 94, 88, 82, 76, 70)
                const yLabels = [100, 94, 88, 82, 76, 70];
                yLabels.forEach(weight => {
                    const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    label.textContent = weight;
                    label.setAttribute('x', padding.left - 15);
                    label.setAttribute('y', yScale(weight) + 5);
                    label.classList.add('axis-label');
                    label.setAttribute('text-anchor', 'end');
                    g.appendChild(label);
                });

                // X-axis labels - matching image
                const xLabels = ['Start', 'Month 2', 'Month 3', 'Month 4', 'Month 5', 'Month 6'];
                xLabels.forEach((label, index) => {
                    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    text.textContent = label;
                    text.setAttribute('x', xScale(index));
                    text.setAttribute('y', svgHeight - padding.bottom + 30);
                    text.classList.add('axis-label');
                    text.setAttribute('text-anchor', 'middle');
                    g.appendChild(text);
                });

                svg.appendChild(g);
            };

            const drawCallout = () => {
                const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
                
                const calloutMonth = 5;
                const calloutWeight = 76;
                
                const cx = xScale(calloutMonth);
                const cy = yScale(calloutWeight);
                const boxWidth = 85;
                const boxHeight = 45;

                // Callout rounded box
                const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rect.setAttribute('x', cx - boxWidth / 2 + 20);
                rect.setAttribute('y', cy - boxHeight / 2);
                rect.setAttribute('width', boxWidth);
                rect.setAttribute('height', boxHeight);
                rect.setAttribute('rx', 22);
                rect.classList.add('callout-box');
                g.appendChild(rect);

                // Callout Text
                const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                text.textContent = '-21%';
                text.setAttribute('x', cx + 20);
                text.setAttribute('y', cy + 8);
                text.setAttribute('text-anchor', 'middle');
                text.classList.add('callout-text');
                g.appendChild(text);

                svg.appendChild(g);
                return { rect, text };
            };

            const drawAndAnimate = () => {
                svg.innerHTML = '';

                drawGrid();
                drawLabels();
                const calloutElements = drawCallout();

                // Clip-path setup
                const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
                const clipRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                clipRect.setAttribute('id', 'clip-rect');
                clipRect.setAttribute('x', padding.left);
                clipRect.setAttribute('y', padding.top);
                clipRect.setAttribute('height', chartAreaHeight);
                clipRect.setAttribute('width', 0);
                
                const clipPath = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
                clipPath.setAttribute('id', 'chart-clip');
                clipPath.appendChild(clipRect);
                defs.appendChild(clipPath);
                svg.appendChild(defs);

                // Clipped group for area
                const clippedGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
                clippedGroup.setAttribute('clip-path', 'url(#chart-clip)');
                svg.appendChild(clippedGroup);

                // Area fill
                const areaPath = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                areaPath.setAttribute('d', generatePathD(dataJood, true));
                areaPath.classList.add('area-jood');
                clippedGroup.appendChild(areaPath);

                // Lines
                const linePatients = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                linePatients.setAttribute('d', generatePathD(dataPatients));
                linePatients.classList.add('line-patients');
                svg.appendChild(linePatients);

                const lineJood = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                lineJood.setAttribute('d', generatePathD(dataJood));
                lineJood.classList.add('line-jood');
                svg.appendChild(lineJood);

                // Data points - only last points
                const joodPoints = [];
                const lastJoodIndex = dataJood.length - 1;
                const [lastJoodMonth, lastJoodWeight] = dataJood[lastJoodIndex];
                const joodCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                joodCircle.setAttribute('cx', xScale(lastJoodMonth));
                joodCircle.setAttribute('cy', yScale(lastJoodWeight));
                joodCircle.setAttribute('r', 8);
                joodCircle.classList.add('data-point');
                svg.appendChild(joodCircle);
                joodPoints.push(joodCircle);

                const patientPoints = [];
                const lastPatientIndex = dataPatients.length - 1;
                const [lastPatientMonth, lastPatientWeight] = dataPatients[lastPatientIndex];
                const patientCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                patientCircle.setAttribute('cx', xScale(lastPatientMonth));
                patientCircle.setAttribute('cy', yScale(lastPatientWeight));
                patientCircle.setAttribute('r', 8);
                patientCircle.classList.add('data-point-patients');
                svg.appendChild(patientCircle);
                patientPoints.push(patientCircle);

                // Animation
                const joodLength = lineJood.getTotalLength();
                const patientsLength = linePatients.getTotalLength();

                lineJood.style.strokeDasharray = joodLength;
                lineJood.style.strokeDashoffset = joodLength;
                linePatients.style.strokeDasharray = patientsLength;
                linePatients.style.strokeDashoffset = patientsLength;

                requestAnimationFrame(() => {
                    lineJood.style.strokeDashoffset = 0;
                    linePatients.style.strokeDashoffset = 0;
                    clipRect.style.width = `${chartAreaWidth}px`;

                    joodPoints.forEach((point, index) => {
                        setTimeout(() => { point.style.opacity = 1; }, index * 100 + 2000);
                    });
                    
                    patientPoints.forEach((point, index) => {
                        setTimeout(() => { point.style.opacity = 1; }, index * 100 + 2000);
                    });

                    calloutElements.rect.style.opacity = 1;
                    calloutElements.text.style.opacity = 1;
                });
            };

            drawAndAnimate();
        });
    </script>

<script>
  // Animate percentage counter
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target;
          const target = parseInt(counter.getAttribute('data-target'));
          let current = 0;
          const increment = target / 60;
          
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              counter.textContent = target + '%';
              clearInterval(timer);
            } else {
              counter.textContent = Math.ceil(current) + '%';
            }
          }, 25);
          
          observer.unobserve(counter);
        }
      });
    });

    {% comment %} const counter = document.querySelector('.percentage-number'); {% endcomment %}
    if (counter) {
      observer.observe(counter);
    }
  });
</script>