    align-items: center;
    gap: 6px;
    line-height: 0;
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 16.7px;
    font-style: normal;
    font-weight: 500;
    line-height: 22px; /* 131.737% */
    text-transform: capitalize;
}
.mounjaro-button{
    display: flex;
    padding: 16px 70px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    border-radius: 75px;
   background: var(--Yellow, #FFD902);
   color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    border: 1px solid #FFD902;
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: 0px;
    text-transform: capitalize;
    width: fit-content;
