<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="Achieve_cs_weight_bar_main">
    <div class="Achieve_cs_weight_bar_text">
        
        <div class="Achieve_cs_weight_bar_text_title">{{ section.settings.main-heading }}</div>
        <div class="Achieve_cs_weight_bar_text_par_num">
            <span class="Achieve_cs_weight_loss-up">{{ section.settings.loss-up }}</span>
            <span class="Achieve_cs_weight_bar_numbre">{{ section.settings.number }} {% render 'cs_arrow' %}</span>
        </div>
    
    <div class="Achieve_cs_weight_bar_richtext">{{ section.settings.richtext }}</div>
    </div>
<div class="Achieve_cs-weight-section">
  <div class="cs_achieve_bar_img">
    {{ section.settings.bar-img | image_url: width: 1440 | image_tag:
                class: 'cs_ach_bar_img',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "lezy"
              }}
              {{ section.settings.bar-img-mbl | image_url: width: 1440 | image_tag:
                class: 'cs_ach_bar_img_mbl',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "lezy"
              }}
  </div>

  <div class="Achieve_cs-weight-display">
    <span class="Achieve_cs-weightValue-text" id="Achieve_cs-weightValue"></span><span class="Achieve_cs-weightValue-text" id="Achieve_cs-weightUnitDisplay">kg</span>
    <div class="Achieve_cs_bar_side_curr_rich">{{ section.settings.richtext1 }}</div>
  </div>
<div>
  {% comment %} <div class="Achieve_cs-unit-toggle">
    <button class="Achieve_cs-unit-btn active" data-unit="kg">kg</button>
    <button class="Achieve_cs-unit-btn" data-unit="lb">lb</button>
  </div> {% endcomment %}

  <div class="Achieve_cs-result-card cs_card_scale_animations">
    <div class="Achieve_cs-loss-amount">
      -<span id="Achieve_cs-lossValue"></span><span id="Achieve_cs-lossUnit">kg</span>
    </div>
    <div class="Achieve_cs_bar_side_loss_weight_text">{{ section.settings.loss-text }}</div>
    
    <input type="range" id="Achieve_cs-weightSlider" 
           min="{{ section.settings.min_weight }}" 
           max="{{ section.settings.max_weight }}" 
           value="{{ section.settings.default_weight }}">
  </div>
  </div>
</div>
</div>
</div>
</section>
<script>
document.addEventListener("DOMContentLoaded", function(){
  const KG_TO_LB = 2.20462;
  const LOSS_PERCENTAGE = 0.2155; 

  const slider = document.getElementById("Achieve_cs-weightSlider");
  const weightValue = document.getElementById("Achieve_cs-weightValue");
  const lossValue = document.getElementById("Achieve_cs-lossValue");
  const weightUnitDisplay = document.getElementById("Achieve_cs-weightUnitDisplay");
  const lossUnit = document.getElementById("Achieve_cs-lossUnit");
  const buttons = document.querySelectorAll(".Achieve_cs-unit-btn");

  function updateValues() {
    let val = parseFloat(slider.value);
    weightValue.innerText = Math.round(val);
    
    // Yellow Progress Bar Update logic
    const min = slider.min || 0;
    const max = slider.max || 100;
    const percent = ((val - min) / (max - min)) * 100;
    slider.style.setProperty('--progress', percent + '%');

    // Calculate potential loss
    let loss = val * LOSS_PERCENTAGE;
    lossValue.innerText = Math.round(loss);
  }

  slider.addEventListener("input", updateValues);

  buttons.forEach(btn => {
    btn.addEventListener("click", function() {
      if (this.classList.contains("active")) return;

      const newUnit = this.dataset.unit;
      let val = parseFloat(slider.value);

      buttons.forEach(b => b.classList.remove("active"));
      this.classList.add("active");

      // Slider range conversion
      if (newUnit === "lb") {
        slider.min = Math.round(slider.min * KG_TO_LB);
        slider.max = Math.round(slider.max * KG_TO_LB);
        slider.value = Math.round(val * KG_TO_LB);
        weightUnitDisplay.innerText = "lb";
        lossUnit.innerText = "lb";
      } else {
        slider.min = Math.round(slider.min / KG_TO_LB);
        slider.max = Math.round(slider.max / KG_TO_LB);
        slider.value = Math.round(val / KG_TO_LB);
        weightUnitDisplay.innerText = "kg";
        lossUnit.innerText = "kg";
      }

      updateValues();
    });
  });

  updateValues(); // Initial trigger
});

</script>

