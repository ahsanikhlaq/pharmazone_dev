<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}  
.cs_Awards_main{
    background: {{ section.settings.back_color }};
    border-radius: 20px;
    padding: 40px;
    position: relative;
}
.cs_Awards_main_back-img{
    position: absolute;
    left: 0;
    z-index: 0;
    right: 0;
    bottom: 0;
}
img.cs_Awards_main_back-image {
    display: block;
    width: 100%;
    height: 100%;
}
.cs_award_content_main{
    max-width: 670px;
    margin: 0 auto;
        position: relative;
}
.cs_award_block_main{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
}
.cs_award_title p{
    margin: 0;
    color: #000;
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 110%;
    letter-spacing: -1.24px;
    text-align: center;
}
.cs_award_title p em{
    color: #000;
    font-family: var(--custom-fonts);
    font-size: 50px;
    font-style: normal;
    font-weight: 500;
    line-height: 110%;
    letter-spacing: -1px;
}
.cs_award_title p strong{
    color: var(--Purple, #4C3E79);
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 110%; /* 68.2px */
    letter-spacing: -1.24px;
}
.cs_award_richtext p{
    margin: 0;
    color: #000;
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 130%;
    letter-spacing: -0.18px;
    padding: 25px 0 40px 0;
    text-align: center;
    max-width: 610px;
    margin: 0 auto;
}
.cs_award_richtext p strong{
    color: #000;
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 130%; /* 23.4px */
    letter-spacing: -0.18px;
}
.cs_Awards_block-image{
    display: block;
    max-height: 46px;
}
.cs_award_block_title{
    margin: 0;
    color: var(--Black, #111);
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: -0.54px;
   padding-bottom: 8px;
       max-width: 116px;
    margin: 0 auto;
}
.cs_award_block_content_main {
    margin-top: 20px;
}
.cs_award_block_sub_title{
    margin: 0;
    color: var(--Black, #111);
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%; /* 16.8px */
    max-width: 170px;
    margin: 0 auto;
}
.cs_award_block{
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    border-radius: 10px;
    background: #FFF;
    box-shadow: 0 4px 32px 0 rgba(76, 62, 121, 0.15);
    padding: 20px;
}
 @media screen and (max-width:768px){
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mbl_padding_top }}px;
    padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
  }
  .cs_award_block_main{
    grid-template-columns: 1fr;
    gap: 12px;
}
.cs_award_title p{
    font-size: 30px;
    line-height: 36px;
}
.cs_award_title p em{
    font-size: 30px;
    line-height: 36px;
}
.cs_award_title p strong{
    font-size: 30px;
    line-height: 36px;
}
.cs_award_richtext p{
    padding: 12px 0 24px 0;
    font-size: 14px;
    line-height: 18px;
    letter-spacing: -0.5px;
}
.cs_award_richtext p strong{
    font-size: 14px;
    line-height: 18px;
    letter-spacing: -0.5px;
}
.cs_award_block {
    gap: 25px;
    padding: 16px;
}
.cs_Awards_main {
    border-radius: 10px;
    padding: 16px;
}
.cs_award_block_content_main{
    display: flex;
    flex-direction: column-reverse;
}
.cs_award_block_title{
    padding: 0;
    font-size: 22px;
    line-height: 28px;
    max-width: 100%;
}
.cs_award_block_sub_title{
    font-size: 16px;
    line-height: 19px;
    padding-bottom: 5px;
    max-width: 200px;
    letter-spacing: -0.64px;
}
  } 
</style>
<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="cs_Awards_main">
        <div class="cs_Awards_main_back-img">
                    {{ section.settings.back-img | image_url: width: 1440 | image_tag:
                                class: 'cs_Awards_main_back-image',
                                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                                height: 100,
                                width: 100,
                                alt: logo_alt,
                                loading: "lazy"
                            }}
                </div>
                <div class="cs_award_content_main">
                    <div class="cs_award_title">{{ section.settings.heading }}</div>
                    <div class="cs_award_richtext">{{ section.settings.sub-heading }}</div>
                    <div class="cs_award_block_main"> 
                        {% for block in section.blocks %}
                            <div class="cs_card_scale_animation cs_award_block block-{{ block.id }}">
                                <a href="{{ block.settings.card-url }}">
                                <div class="cs_Awards_block-img">
                                    {{ block.settings.image | image_url: width: 1440 | image_tag:
                                                class: 'cs_Awards_block-image',
                                                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                                                height: 100,
                                                width: 100,
                                                alt: logo_alt,
                                                loading: "lazy"
                                            }}
                                </div>
                                <div class="cs_award_block_content_main">
                                <h4 class="cs_award_block_title">{{ block.settings.text }}</h4>
                                <h5 class="cs_award_block_sub_title">{{ block.settings.rich-text }}</h5>
                                </div>
                            </a>
                            </div>
                            {% style %}
                              .block-{{ block.id }} .cs_Awards_block-image{
                                width: {{ block.settings.max-width-img }}px;
                                margin: 0 auto;
                              }
                            {% endstyle %}
                        {% endfor %}
                    </div>
                </div>
    </div>
</div>
</section>

{% schema %}
{
  "name": "Awards & Recognition",
  "settings": [
    {
        "type": "richtext",
        "id": "heading",
        "label": "Heading"
    },
    {
        "type": "richtext",
        "id": "sub-heading",
        "label": "Rich Text"
    },
    {
        "type": "image_picker",
        "id": "back-img",
        "label": "Background Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
       "type": "color_background",
        "id": "back_color",
        "label": "Background Color"
    }
  ],
  "blocks": [
      {
        "type": "best-sellers",
        "name": "Add Tab",
         "settings": [
            {
            "type": "url",
            "id": "card-url",
            "label": "Card Url"
          },
            {
                "type": "image_picker",
                "id": "image",
                "label": "Image"
            },
            {
                "type": "range",
                "id": "max-width-img",
                "min": 0,
                "max": 200,
                "step": 2,
                "unit": "px",
                "label": "Image Max Width",
                "default": 20
                },
            {
                "type": "text",
                "id": "text",
                "label": "Text"
            },
            {
                "type": "text",
                "id": "rich-text",
                "label": "Rich Text"
            },
         ]
         }
        ],
  "presets": [
    {
      "name": "Awards & Recognition",
      "category": "Custom"
    }
  ]
}
{% endschema %}