                loading: "egar"
              }}
              {{ section.settings.review-image-mbl | image_url: width: 1440 | image_tag:
                class: 'cs_banner_rev-image_mbl',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
