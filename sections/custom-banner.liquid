    </div>
    <h1 class="cs_banner_title">{{ section.settings.title-text }}</h1>
</div>
<div class="cs_banner_weight_text_butt">
    <div class="cS_banner_weight_number_main cs_card_scale_animation">
        <div class="cs_banner_weight_text">
            <h3 class="cs_banner_weight_sub_title">{{ section.settings.weight-sub-title }}</h3>
            <div class="cs_banner_weight_title">{{ section.settings.weight-text }}</div>  
            <div class="cs_banner_weight_kg_mian">
                <div class="cs_banner_weight_kg_before">
                    <span class="cs_banner_wight_num cs_banner_wight_num1">{{ section.settings.weight1 }}</span>
                    <span class="cs_banner_weight_unit">{{ section.settings.weight-unit1 }}</span>
                </div>
                <div class="cs_banner_weight_kg_svg">{% render 'banner_weight_comp_svg' %}</div>
                <div class="cs_banner_weight_kg_before">
                    <span class="cs_banner_wight_num cs_banner_wight_num2">{{ section.settings.weight2 }}</span>
                    <sapn class="cs_banner_weight_unit">{{ section.settings.weight-unit2 }}</sapn>
                </div>
            </div>
        </div>
        <div class="cs_banner_weight_image">
            {{ section.settings.weight-image | image_url: width: 1440 | image_tag:
                class: 'cs_banner_weight-image',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "eager"
              }}
        </div>
    </div>
    <div class="cs_banner_weight_des">{{ section.settings.weight-des }}</div>
    <a class="cs_banner_button cs_button_hover" href="{{ section.settings.butt-url }}">{{ section.settings.butt-text }}</a>
</div>
  </div>
  <div class="cs_banner_image_main">
    {{ section.settings.image | image_url: width: 1440 | image_tag:
                class: 'cs_banner-img',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "eager"
              }}
  </div>
  </div>
</div>
</section>
<script>
    document.querySelectorAll(".cs_banner_wight_num").forEach((el) => {
  let target = parseInt(el.innerText);
  el.innerText = "0";

  let observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCount(el, target);
        observer.unobserve(el);
      }
    });
  });

  observer.observe(el);
});

function animateCount(element, target) {
  let current = 0;
  let speed = target / 100; // animation smoothness

  let interval = setInterval(() => {
    current += speed;
    if (current >= target) {
      element.innerText = target;
      clearInterval(interval);
    } else {
      element.innerText = Math.floor(current);
    }
  }, 20);
}

</script>
