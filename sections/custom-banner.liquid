    font-size: 30px;
    font-style: normal;
    font-weight: 700;
    line-height: 90%; /* 27px */
    letter-spacing: -0.9px;
    
}
.cs_banner_wight_num1{
width: 50px;
 }
 .cs_banner_wight_num2{
width: 37px;
 }
.cs_banner_weight_unit{
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 15.237px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
}
.cs_banner_weight-image{
    display: block;
