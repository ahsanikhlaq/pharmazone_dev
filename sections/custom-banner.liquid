<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    
}
.cs_banner-img{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
    border-radius: 0 16px 16px 0;
}
.cs_banner_img_content_main{
    display: grid;
    grid-template-columns: 40% auto;
    align-items: end;
    justify-content: space-between;
    background-color: {{ section.settings.back_color }};
     border-radius: 16px;
   
}
.cs_banner_content_main{
    padding: 40px 0 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 100px;
}
.cs_banner_reviews_main{
    display: flex;
    align-items: center;
    gap: 9px;
}
.cs_banner_rev-image_des{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
    max-width: 236px;
    max-height: 23px;
}
.cs_banner_rev-image_mbl{
display: none;
    object-fit: cover;
    width: 100%;
    height: auto;
}
.cs_banner-reivew_richtext p{
    margin: 0;
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 16px;
}
.cs_banner-reivew_richtext p strong{
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 16px; /* 100% */
}
.cs_banner_title{
    margin: 0;
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 101%; /* 67.67px */
    letter-spacing: -1.4px;
    padding-top: 17px;
    min-width: 650px;
    text-transform: capitalize;
}
.cS_banner_weight_number_main{
    border-radius: 8.541px;
    border: 1.058px solid rgba(255, 255, 255, 0.10);
    background: var(--Linear, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, #F4EFFD 0.38%, #FFF5BF 100%));
