    text-edge: cap;
    font-family: var(--custom-fonts);
    font-size: 17px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: 0px;
}
.cs_banner_weight_title p strong{
    color: #2A2A2A;
    leading-trim: both;
    text-edge: cap;
    font-family: var(--custom-fonts);
    font-size: 17px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: 0px;
}
.cs_banner_weight_kg_mian{
    border-radius: 4.838px;
    background: #FFF;
    display: flex;
    padding: 12px;
    justify-content: center;
    align-items: center;
    gap: 8px;
}
.cs_banner_weight_kg_before{
    display: flex;
