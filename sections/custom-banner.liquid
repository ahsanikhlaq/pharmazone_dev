    width: 100%;
    height: auto;
    border-radius: 3.386px; 
}
.cs_banner_weight_des p{
    margin: 0;
    color: var(--White, #FFF);
    leading-trim: both;
    text-edge: cap;
    font-family: var(--custom-fonts);
    font-size: 21px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 25.2px */
}
.cs_banner_button{
