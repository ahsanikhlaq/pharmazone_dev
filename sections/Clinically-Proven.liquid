{% style %}

.section-{{ section.id }}{
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.section-{{ section.id }} .clinical-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.clinical-images {
    width: 100%;
    max-width: 100%;
}

.clinical-images img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 24px;
}

.clinical-content {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
}

.clinical-content-head {
    max-width: calc(50% - 40px);
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 40px;
}

h2.clinical-title,
h2.clinical-title strong {
    font-family: var(--custom-fonts);
    font-weight: 600;
    font-size: 62px;
    line-height: 120%;
    letter-spacing: -1.2px;
    /* vertical-align: middle; */
    margin: 0;
    color: #111111;
}
h2.clinical-title{
  max-width: 637px;
}
h2.clinical-title strong {
    color: #4C3E79;
}

.clinical-btn {
    padding: 16px 30px;
    background-color: #FFD902;
    display: inline-flex;
    border: 1px solid #FFD902;
    max-width: fit-content;
    border-radius: 75px;
    font-family: var(--custom-fonts);
    font-weight: 700;
    font-size: 18px;
    line-height: 120%;
    letter-spacing: 0;
    text-transform: capitalize;
    text-decoration: none;
    color: #4C3E79;
    transition: all 0.3s ease;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}



.clinical-block-wrapper {
    max-width: 50%;
    width: 100%;
}

h3.clinical-block_title {
    font-family: var(--custom-fonts);
    font-weight: 700;
    font-size: 32px;
    line-height: 120%;
    letter-spacing: -0.3px;
    vertical-align: middle;
    text-align: start;
    margin: 0 0 28px;
    color: #4C3E79;
}

.clinical_blocks_list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.clinical-block_list-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.clinical-block_icon {
    min-width: 24px;
    width: 24px;
    min-height: 24px;
}

.clinical-block_icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.clinical-block_text {
    font-family: var(--custom-fonts);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: -0.36px;
    vertical-align: middle;
    color: #111111;
}

@media screen and (max-width: 768px) {
    .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }

    .clinical-content {
        gap: 28px;
    }

    .clinical-btn_desk {
    display: none;
    }

    .clinical-btn_mob {
    display: inline-flex !important;
    }

    .clinical-image_desk {
    display: none;
    }

    .clinical-image_mob {
    display: block !important;
    }

    .section-{{ section.id }} .clinical-wrapper {
        gap: 20px;
    }
    .clinical-btn{
        padding: 14px 0;
    }
    .clinical-content-head,
    .clinical-block-wrapper {
        max-width: 100%;
    }

    h2.clinical-title, 
    h2.clinical-title strong {
        font-family: var(--custom-fonts);
        font-weight: 600;
        font-size: 30px;
        line-height: 120%;
        letter-spacing: -0.6px;
        text-transform: capitalize;
    }

    h3.clinical-block_title {
        font-size: 24px;
        line-height: 120%;
        margin-bottom: 16px;
    }

    .clinical-block_text {
        font-size: 14px;
        line-height: 120%;
    }

    .clinical-block-wrapper {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .clinical-btn {
        max-width: 100%;
    }
}

{% endstyle %}


<section class="clinical-section section-{{ section.id }}" >

  <div class="page-width">
    <div class="clinical-wrapper">
      
      <!-- Images -->
      <div class="clinical-images">
        <div class="clinical-image_desk">
          {% if section.settings.desktop_image != blank %}
            <img 
              src="{{ section.settings.desktop_image | image_url: width: 1200 }}" 
              alt="{{ section.settings.title | escape }}"
              loading="lazy"
              width="100%"
              height="auto"
            >
          {% endif %}
        </div>

        <div class="clinical-image_mob" style="display: none;">
          {% if section.settings.mobile_image != blank %}
            <img 
              src="{{ section.settings.mobile_image | image_url: width: 750 }}" 
              alt="{{ section.settings.title | escape }}"
              loading="lazy"
              width="100%"
              height="auto"
            >
          {% endif %}
        </div>
      </div>

      <!-- Content -->
      <div class="clinical-content">
        <div class="clinical-content-head">
          
          {% if section.settings.title != blank %}
            <h2 class="clinical-title">
              {{ section.settings.title }}
            </h2>
          {% endif %}

          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="clinical-btn_desk clinical-btn cs_faq_sec_button_des_hover">
              {{ section.settings.button_label }}
            </a>
          {% endif %}

        </div>

        <div class="clinical-block-wrapper">
          <div class="clinical-block_inner">

            {% if section.settings.block_heading != blank %}
              <h3 class="clinical-block_title">
                {{ section.settings.block_heading }}
              </h3>
            {% endif %}

            <div class="clinical_blocks_list">
              {% for block in section.blocks %}
                <div class="clinical-block_list-item" {{ block.shopify_attributes }}>
                  
                  <div class="clinical-block_icon">
                    {% if block.settings.icon != blank %}
                      <img 
                        src="{{ block.settings.icon | image_url: width: 100 }}" 
                        alt="icon"
                        loading="lazy"
                        width="50"
                        height="50"
                      >
                    {% endif %}
                  </div>

                  <div class="clinical-block_text">
                    {{ block.settings.text }}
                  </div>

                </div>
              {% endfor %}
            </div>

          </div>

          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="clinical-btn_mob clinical-btn" style="display: none;">
              {{ section.settings.button_label }}
            </a>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Clinical Section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Main Heading",
      "default": "Clinical Study Results"
    },
    {
      "type": "inline_richtext",
      "id": "block_heading",
      "label": "Block Heading",
      "default": "Why It Works"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "clinical_block",
      "name": "Clinical Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "Clinically proven results backed by research."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clinical Section",
      "category": "Custom",
      "blocks": [
        {
          "type": "clinical_block"
        }
      ]
    }
  ]
}
{% endschema %}