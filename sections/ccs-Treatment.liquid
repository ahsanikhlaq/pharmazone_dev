<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    
}
.cs_treat_heading p{
    margin: 0;
    color: #111;
    text-align: center;
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 74.4px */
    letter-spacing: -1.24px;
            max-width: 900px;
    margin: 0 auto;
    text-transform: capitalize;
}
.cs_treat_heading p strong{
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 62px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: -1.24px;
}
.cs_treat_block_main{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
}
.cs_treat_block_in{
     border-radius: 18px;
     display: flex;
     align-items: end; 
    justify-content: space-between;
    position: relative;
}
.cs_treat_block_contet{
    padding: 0 0 20px 20px;
}
.cs_treat_list_text ul{
    list-style-type: none;
}
.cs_treat_block_title{
    margin: 0;
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 30px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 36px */
    letter-spacing: -0.6px;
    text-transform: capitalize;
}
.cs_treat_list_text ul li{
    color: var(--White, #FFF);
    font-family: var(--custom-fonts);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%; /* 19.2px */
    letter-spacing: 0px;
}
.cs_treat_button{
    text-decoration: none;
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 21.6px */
    letter-spacing: -1.08px;
    text-transform: capitalize;
    display: flex;
    padding: 16px 24px;
    justify-content: center;
    align-items: center;
    gap: 10px;  
    border-radius: 75px;
    background: var(--Yellow, #FFD902);
    border: 1px solid #FFD902;
    max-width: fit-content;
    cursor: pointer;
}
.cs_treat_list_text{
    padding: 9px 0 11px 0;
}
.cs_treat_block_img_des{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
        max-width: 400px;
    max-height: 340px;
    border-radius: 20px;
}
.cs_treat_block_img_mbl{
    display: none;
    object-fit: cover;
}
.cs_treat_list_text ul {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

.cs_treat_list_text li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 9px;
}


 @media screen and (max-width:768px){
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mbl_padding_top }}px;
    padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
  }
  .cs_treat_block_main{
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 24px;
}
.cs_treat_heading p{
    font-size: 28px;
    line-height: 120%; /* 36px */
    letter-spacing: -0.6px;
    max-width: 100%;
}
.cs_treat_heading p strong{
    font-size: 30px;
    line-height: 120%; /* 36px */
    letter-spacing: -0.6px;
}
.cs_treat_block_title {
    font-size: 20px;
            max-width: 103px;
}
.cs_treat_list_text li {
    margin-bottom: 8px;
    font-size: 14px;
}
.cs_treat_list_text {
    padding: 20px 0;
}
.cs_treat_button {
    font-size: 16px;
}
.cs_treat_block_image {
    position: absolute;
    right: 0;
    bottom: 0;
}
.cs_treat_block_img {
    
}
.cs_treat_block_img_des{
    display: none;
}
.cs_treat_block_img_mbl{
    display: block;
    width: 100%;
        height: auto;
        max-width: 210px;
        border-radius: 16px;
}
.cs_treat_block_contet {
    padding: 20px 0 20px 20px;
}
.cs_treat_list_text ul li {
    font-size: 14px;
    font-weight: 300;
   
}
  }
</style>


<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    <h3 class="cs_treat_heading">{{ section.settings.heading }}</h3>
    <div class="cs_treat_block_main">
        {% for block in section.blocks %}
            <div class="cs_card_scale_animations cs_treat_block_in block-{{ block.id }}">
                <div class="cs_treat_block_contet">
                    <h3 class="cs_treat_block_title">{{ block.settings.title }}</h3>
                    <div class="cs_treat_list_text">{{ block.settings.rich_title }}</div>
                    <a class="cs_treat_button cs_button_hover" href="{{ block.settings.butt_url }}">{{ block.settings.butt_text }}</a>
                </div>
                <div class="cs_treat_block_image">
                     {{ block.settings.image | image_url: width: 1440 | image_tag:
                class: 'cs_treat_block_img_des',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "lazy"
              }}
              {{ block.settings.image-mbl | image_url: width: 1440 | image_tag:
                class: 'cs_treat_block_img_mbl',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "lazy"
              }}
                </div>
            </div>
            {% style %}
              .block-{{ block.id }}{
                background: {{ block.settings.block-back_color }};
              }
              .block-{{ block.id }} .cs_treat_list_text li::before {
                    content: "";
                    position: absolute;
                    left: 0;
                    top: 2px;
                    width: 16px;
                    height: 16px;
                    background-image: url({{ block.settings.svg | image_url  }});
                    background-size: contain;
                    }
            {% endstyle %}
        {% endfor %}
    </div>
</div>
</section>
{% schema %}
{
  "name": "Trusted Treatment",
  "settings": [
    {
        "type": "richtext",
        "id": "heading",
        "label": "Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back_color",
      "label": "Background Color"
    }
  ],
  "blocks": [
      {
        "type": "best-sellers",
        "name": "Add Tab",
         "settings": [
             {
                "type": "color_background",
                "id": "block-back_color",
                "label": "Background Color"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image Desktop"
                },
                {
                    "type": "image_picker",
                    "id": "image-mbl",
                    "label": "Image Mobile"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title"
                },
                {
                    "type": "richtext",
                    "id": "rich_title",
                    "label": "List Text"
                },
                {
                    "type": "image_picker",
                    "id": "svg",
                    "label": "Svg"
                },
                {
                    "type": "text",
                    "id": "butt_text",
                    "label": "Button Text"
                },
                {
                    "type": "url",
                    "id": "butt_url",
                    "label": "Button Url"
                }
         ]
         }
        ],
  "presets": [
    {
      "name": "Trusted Treatment",
      "category": "Custom"
    }
  ]
}
{% endschema %}