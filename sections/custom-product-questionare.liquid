<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

{% style %}
.section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  background: {{ section.settings.bg_color }};
  background: var(--Gradient, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, rgba(244, 239, 253, 0.60) 0.38%, rgba(255, 245, 191, 0.60) 100%), #FFF);
}
.section-{{ section.id }} .page-width { max-width: {{ section.settings.page_width }}px; margin: 0 auto; padding: 0 20px; }
.section-{{ section.id }} .page-width { max-width:560px; margin:0 auto; }
.product-section { display: none !important; }
.product-section.active { display: block !important; }
.weight-title { color: var(--Black, #111); text-align: center; font-family: "SF Pro"; font-size: 42px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.42px; margin:0px; }
.weight-header-img { width: 324px; height: 324px; margin: 0 auto; text-align: center; }
.weight-header-img img { object-fit: cover; aspect-ratio: 1 / 1; width:100%; height:100%; max-width: 324px; max-height: 324px; margin: 0 auto; }
.media-sub-heading { color: var(--Purple, #4C3E79); font-family: "SF Pro"; font-size: 12px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.12px; text-transform: capitalize; margin:0 0 12px; }
.media-heading { color: var(--Black, #111); font-family: "SF Pro"; font-size: 18px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.18px; text-transform: capitalize; margin:0 0 20px; }
.media-part { padding: 20px; border-radius: 10px; background: #FFF; }
.pg-wrap { max-width: 100%; margin: 0 auto; }
.pg-main .swiper-slide img { width: 100%; height: 100%; object-fit: contain; max-height: 400px; }
.pg-thumbs { margin-top: 12px; }
.pg-thumbs .swiper-slide { width: 80px !important; height: 80px; border-radius: 8px; overflow: hidden; cursor: pointer; border: 2px solid transparent; background: #fff; box-shadow: 0 1px 6px rgba(0,0,0,.07); transition: border-color .2s; }
.pg-thumbs .swiper-slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pg-thumbs .swiper-slide-thumb-active { border-radius: 8px; border: 1px solid var(--Purple, #4C3E79); }
.step-heading { color: var(--Black, #111); font-family: "SF Pro"; font-size: 18px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.18px; text-transform: capitalize; margin:0 0 12px; }
.step-des p { color: var(--Gray, #545454); font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.14px; margin:0 0; }
.step-box { display: flex; padding: 12px 16px; align-items: flex-start; gap: 14px; align-self: stretch; border-radius: 12px; background: linear-gradient(0deg, rgba(255, 255, 255, 0.60) 0%, rgba(255, 255, 255, 0.60) 100%), linear-gradient(107deg, #F4EFFD 0.38%, #FFF5BF 100%); }
.box-img { width: 50px; height: 50px; aspect-ratio: 1/1; object-fit:cover; border-radius:8px; }
.steps-content { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; align-self: stretch; }
.step-number { line-height:normal; }
.step-number * { color: var(--Black, #111); font-family: "SF Pro"; font-size: 16px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.16px; margin:0px; }
.step-titled { color: var(--Gray, #545454); font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.14px; margin:0px; }
.step-grid { display: flex; flex-direction: column-reverse; align-items: flex-start; gap: 12px; align-self: stretch; margin:20px 0 0; }
.usage-steps { padding:20px; border-radius: 10px; background: #FFF; margin:20px 0; }
.testimonial-subheading * { color: var(--Black, #111); font-family: "SF Pro"; font-size: 12px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.12px; text-transform: capitalize; margin:0 0 12px; }
.testimonial-heading { margin:0 0 24px; }
.testimonial-heading * { color: var(--Black, #111); font-family: "SF Pro"; font-size: 18px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.18px; text-transform: capitalize; margin:0 0; }
.testimonial-content { display: flex; padding: 12px 16px; flex-direction: column; align-items: flex-start; gap: 14px; border-radius: 12px; background: linear-gradient(0deg, rgba(255, 255, 255, 0.60) 0%, rgba(255, 255, 255, 0.60) 100%), linear-gradient(107deg, #F4EFFD 0.38%, #FFF5BF 100%); }
.testimonial-name { margin:0px; color: var(--purple-20, #26295D); font-family: "SF Pro"; font-size: 18px; font-style: normal; font-weight: 700; line-height: 120%; letter-spacing: -0.18px; text-transform: capitalize; }
.testimonial-headline { color: var(--purple-20, #26295D); font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.14px; text-transform: capitalize; margin:0px; }
.testimonial-info { margin:0px; }
.testimonial-info * { color: var(--purple-20, #26295D); font-family: "SF Pro"; font-size: 10px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.12px; text-transform: capitalize; margin:0px; }
.testimonial-section { padding: 20px; border-radius: 10px; background: #FFF; margin: 0 0 20px; padding-right:0px; }
.testimonialSwiper .swiper-wrapper { padding:0 0 36px; display:flex; height:auto; }
.testimonialSwiper .swiper-slide { display:flex; height:auto; }
.testimonialSwiper .swiper-horizontal>.swiper-pagination-bullets, .swiper-pagination-bullets.swiper-pagination-horizontal { bottom:0px; }
.cs-pag .swiper-pagination-bullet { background:white; border:1.5px solid #4C3E79; width:10px; height:10px; opacity:1; }
.cs-pag .swiper-pagination-bullet-active { background:#4C3E79; }
.benefits-grid { display: flex; flex-direction: column-reverse; align-items: flex-start; gap: 12px; margin:0 0 24px; }
.benefit-img { width: 26px; height: 26px; background: white; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.benefit-img img { width: 12px; height: 12px; aspect-ratio: 1/1; object-fit:cover; }
.benefit-card { display: flex; align-items: center; gap: 8px; align-self: stretch; }
.graph_image_img img { width: 100%; height: auto; object-fit: cover; display: block; }
.faq-section { display: flex; flex-direction: column; align-items: flex-start; gap: 16px; align-self: stretch; padding:0 20px 20px; background:white; margin:0 0 20px; border-radius: 0 0 12px 12px; }
.faq-section * { cursor:pointer !important; }
.faq-item { width: 100%; border-bottom: 1px solid rgba(12, 36, 33, 0.30); cursor:pointer; }
.faq-item:last-child { border:0px; }
button.faq-question { border: 0px; background: transparent; width: 100%; display: flex; justify-content: space-between; padding: 0 0 12px; }
button.faq-question span { color: #0C2421; font-family: "SF Pro"; font-size: 16px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.64px; }
.faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.25s ease, padding 0.2s ease; padding-top: 0; will-change: max-height; }
.faq-item.active .faq-answer { padding-top: 8px; }
.faq-answer * { color: var(--Black, #111); font-family: "SF Pro"; font-size: 12px; font-style: normal; font-weight: 400; line-height: 140%; letter-spacing: -0.24px; text-transform: capitalize; padding:0 0 12px; margin:0px; }
.faq-icon { font-size: 22px; transition: transform 0.3s ease; }
.faq-item.active .faq-icon { transform: rotate(180deg); }
.pharmazoon-section { background:white; padding:20px; border-radius: 10px; margin:0 0 20px; }
.caution-box { display: flex; max-width: 500px; padding: 20px; flex-direction: column; justify-content: center; align-items: flex-start; gap: 20px; border-radius: 12px; background: #FCFCFC; }
.pharma-checkbox-row label { color: var(--Black, #111); font-family: "SF Pro"; font-size: 14px; font-style: normal; line-height: 120%; letter-spacing: -0.14px; font-weight: 400; }
.caution-text { color: var(--Black, #111); font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.14px; margin:0px; }
.pharma-checkbox-row label strong { font-weight: 700; }
.pharma-button { color: #FFF; font-family: "SF Pro"; font-size: 16px; font-style: normal; font-weight: 700; line-height: 120%; text-transform: uppercase; display: flex; padding: 15px 49px; justify-content: center; align-items: center; gap: 15px; flex-shrink: 0; align-self: stretch; border-radius: 45px; background: var(--light-gray-20, #E0E0E0); border:0px; }
.pharmazoon-description * { margin:0px; }
.pharmazoon-description ul { padding-left:20px; display: flex; flex-direction: column; align-items: flex-start; gap: 12px; align-self: stretch; margin: 16px 0 0; }
.pharmazoon-description ul li { color: var(--Black, #111); font-family: "SF Pro"; font-size: 12px; font-style: normal; font-weight: 400; line-height: 120%; text-transform: capitalize; }
.pharmazoon-description strong { color: var(--Black, #111); font-family: "SF Pro"; font-size: 18px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.18px; text-transform: capitalize; padding:0 0; }
.variant-box { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; align-self: stretch; margin:20px 0px; }
.var-label { color: var(--Black, #111); font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 500; line-height: 120%; letter-spacing: -0.14px; margin:0px; }
.per-month-box { display: flex; flex-direction: column; align-items: center; justify-content:center; gap: 8px; align-self: stretch; margin:20px 0; }
.per-month strong { color: var(--Purple, #4C3E79); text-align: center; font-family: "SF Pro"; font-size: 20px; font-style: normal; font-weight: 700; line-height: 120%; text-transform: capitalize; }
.per-month { color: var(--Black, #111); font-family: "SF Pro"; font-size: 16px; font-style: normal; font-weight: 400; line-height: 120%; text-transform: capitalize; margin:0px; }
.per-month-subtext { color: var(--Gray, #545454); text-align: center; font-family: "SF Pro"; font-size: 14px; font-style: normal; font-weight: 500; line-height: 120%; }
.weight-review-box { display: flex; align-items: center; gap: 8.8px; margin-bottom: 15px; }
.weight-review-box p { color: var(--Black, #111); font-family: "SF Pro"; font-size: 13.2px; font-style: normal; font-weight: 700; line-height: 28.6px; margin:0px; display: flex; align-items: center; gap: 8.8px; }
.weight-review-box strong { color: var(--Black, #111); font-family: "SF Pro"; font-size: 13.2px; font-style: normal; font-weight: 700; line-height: 28.6px; }
.weight-review-box span { color: var(--Black, #111); font-family: "SF Pro"; font-size: 13.2px; font-style: normal; font-weight: 400; line-height: 28.6px; }
.benefit-text { color: var(--Gray, #545454); font-family: "SF Pro"; font-size: 15px; font-style: normal; font-weight: 400; line-height: 120%; letter-spacing: -0.12px !important; text-transform: capitalize; }
.pharma-checkbox-row { display: flex; align-items: center; gap: 8px; align-self: stretch; margin:0 0 16px; }
#pgThumbs .swiper-wrapper { align-items: center; }

