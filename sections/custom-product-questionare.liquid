.pharma-popup-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.50);
  z-index: 99999;
  align-items: center;
  justify-content: center;
}
.pharma-popup-overlay.open { display: flex; }
.pharma-popup-box {
  background: #fff;
  border-radius: 24px;
  padding: 60px 32px 40px 32px;
  max-width: 600px;
  width: 100%;
  text-align: center;
 border-radius: 20px;
background: var(--Gradient, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, rgba(244, 239, 253, 0.60) 0.38%, rgba(255, 245, 191, 0.60) 100%), #FFF);
  animation: popupFadeIn 0.22s ease;
}
@keyframes popupFadeIn {
  from { opacity:0; transform: translateY(18px) scale(0.97); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
.pharma-popup-emoji-wrap {
  width: 100px; height: 100px;
  background: linear-gradient(107deg, #F4EFFD 0.38%, #FFF5BF 100%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 38px;
  margin: 0 auto 20px;
  border-radius: 138.372px;
    background: #FFF;
    box-shadow: 0 4px 34px 0 rgba(0, 0, 0, 0.05);
}
.pharma-popup-title {
 color: var(--Black, #111);
text-align: center;
font-family: "SF Pro";
font-size: 32px;
font-style: normal;
font-weight: 590;
line-height: 120%; /* 38.4px */
letter-spacing: -0.32px;
margin: 0px 0px 9px 0px;
}
.pharma-popup-list {
  list-style: none; padding: 18px 20px; margin: 0 0 24px;
  background: #FFFBE8; border-radius: 14px; text-align: left;
  display: flex; flex-direction: column; gap: 10px;
 border-radius: 20px;
    background: radial-gradient(249.22% 76.26% at 55.56% 49.57%, rgba(250, 248, 237, 0.3) 0.4%, rgba(255, 217, 2, 0.4) 100%);
    max-width: 405px;
    margin: 0 auto;
    margin-bottom: 40px;
    padding: 11px 37px;
    width: 100%;
}
.pharma-popup-list li {
  color: var(--Black, #111);
font-family: "SF Pro";
font-size: 16px;
font-style: normal;
font-weight: 500;
line-height: 205%; /* 32.8px */
letter-spacing: 0px;

 
}
.pharma-popup-list li::before {
  content: "•"; color: #000; font-size: 13px; font-weight: 700;
  flex-shrink: 0; line-height: 1.2;
  padding-right: 12px;
}
.pharma-popup-list li strong { font-weight: 700; }
.pharma-popup-continue-btn {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%; padding: 17px;
  background: #4C3E79; color: #fff;
  font-family: "SF Pro"; font-size: 16px; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase;
  border: none; border-radius: 45px; cursor: pointer;
  transition: background 0.2s ease, opacity 0.2s ease;
  max-width: 404px;
    margin: 0 auto;
}
.pharma-popup-continue-btn:hover:not(:disabled) { background: #3a2e5e; }
.pharma-popup-continue-btn:disabled { opacity: 0.75; cursor: not-allowed; }
.pharma-popup-spinner {
  width: 18px; height: 18px;
  border: 2.5px solid rgba(255,255,255,0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: none; flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }
.pharma-popup-continue-btn.loading .pharma-popup-spinner { display: block; }

@media screen and (max-width: 768px) {
  .section-{{ section.id }} { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom: {{ section.settings.padding_bottom_mobile }}px; }
  .media-gallery-grid { grid-template-columns: repeat(2, 1fr); }
  .media-gallery-heading { font-size: 26px; }
  .weight-header-img img {
    max-width: 280px;
    max-height: 324px;
  }
}
@media screen and (max-width: 468px) {
  .weight-header-img { width: 100%; height: 280px; margin: 0 auto; }
  .weight-title { font-size: 28px; }
  .pharmazoon-section, .media-part, .faq-section, .usage-steps, .testimonial-section { padding-right:0px; padding-left:0px; padding-bottom: 8px; margin: 16px 0; background:transparent; }
  .section-{{ section.id }} .page-width { padding: 0 14px; }
  .trust-svg { max-width:80px; }
  .caution-box { padding:14px; gap:16px; }
  .benefits-grid { gap:6px; }
  .faq-icon svg { width: 15px; height: 15px; }
  .testimonial-content { padding: 12px 12px; gap: 10px; }
  .step-box { padding: 12px 4px; }
  .pg-thumbs { margin-top: 0px; display: none; }
  .pharmazoon-section { margin:0px; }
  .pharmazoon-description ul li { font-size: 11px; }
  .pharmazoon-description ul { padding-left: 14px; }
  .pharma-checkbox-row { gap: 4px; }
  .per-month strong { font-size: 16px; }
  .per-month { font-size: 14px; }
  .pharma-checkbox-row label { font-size: 12px; }
  .per-month-box { gap: 6px; }
  .pharma-popup-box { padding: 25px 22px 22px; margin: 0px 10px; }
  .pharma-popup-title { font-size: 22px; },
  .pharma-popup-list li{
    font-size: 14px;
    letter-spacing: 0px;
  }
  .pharma-popup-list {
    padding: 11px 15px;
    gap: 5px;
    margin-bottom: 23px;

  }
  .pharma-popup-list li{
    font-size: 14px;
    gap: 0px;
  }
}
