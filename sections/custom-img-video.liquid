<section
  class="custom-hero-section {%  if section.settings.about-styling %}about-styling{% endif %}"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="page-width">
  <div class="cs-content-wrapper">
  {% if section.settings.desktop_banner != blank %}
    
     {{ section.settings.desktop_banner
        | image_url: width: 1200
        | image_tag:
          class: 'hero-bg hero-bg-image hero-bg-desktop',
          loading: 'eager',
          alt: section.settings.mobile_banner.alt
      }}
    {% else %}
        {% assign video_poster = section.settings.video | image_url   %}
                    {% if section.settings.video != blank %}
                   <div class="play-wrapper">
                    <!-- Video -->
                   <div class="video-slider">
                    {{ section.settings.video | video_tag: 
                        class: 'custom-video-slider des',
                        controls: false,
                        autoplay: false,
                        loop: true,
                        muted: false,
                        playsinline: true,
                        poster: video_poster
                    }}
                    <span class="cs-video-slider-play-butt">{% render 'video-play' %}</span>
                  </div>

                    

                  </div>
                   {% endif %}
    {% endif %}

  {% if section.settings.mobile_banner != blank %}
    <div class="hero-bg hero-bg-mobile">
      {{ section.settings.mobile_banner
        | image_url: width: 1200
        | image_tag:
          class: 'hero-bg-image ',
          loading: 'eager',
          alt: section.settings.mobile_banner.alt
      }}
    </div>

     {% else %}
                {% assign video_poster = section.settings.video | image_url   %}
                    {% if section.settings.video != blank %}

                    <!-- Video -->
                    <div class="video-slider">
                        {{ section.settings.video | video_tag: class: 'custom-video-slider mob', controls: false, muted: false, poster: video_poster }}
                        <span class="cs-video-slider-play-butt {% if section.settings.desktop_banner != blank %}des-hide{% endif %}  {% if section.settings.mobile_banner != blank %}mob-hide{% endif %}">{% render 'video-play' %}</span>
                    </div>
                      

                   {% endif %}


  {% endif %}
   <div class="cs-overlay"></div>


   
    <div class="hero-content
      {% if section.settings.cs-class-work != blank %}main-heading_cheak_how-it{% endif %}
        desktop-v-{{ section.settings.content_vertical_desktop }}
        desktop-h-{{ section.settings.content_horizontal_desktop }}
        mobile-v-{{ section.settings.content_vertical_mobile }}
        mobile-h-{{ section.settings.content_horizontal_mobile }} "
    
        style="
        --desktop-top: {{ section.settings.desktop_top }}px;
        --desktop-bottom: {{ section.settings.desktop_bottom }}px;
        --desktop-left: {{ section.settings.desktop_left }}px;

        --mobile-top: {{ section.settings.mobile_top }}px;
        --mobile-bottom: {{ section.settings.mobile_bottom }}px;
        --mobile-left: {{ section.settings.mobile_left }}px;
        "
    >

      {% if section.settings.img_rat != blank %}
        <div class="hero-rating">
          {% if section.settings.mobile_banner != blank %}
            <img class="desktop-img" src="{{ section.settings.img_rat | image_url }}" alt="img_rat" class="rat-img" loading="eager">
          {% endif %}
          <p class="hero-rating-text">
            {{ section.settings.rating_text }}
            <span class="pipe-text">{{ section.settings.sec_rating_text }}</span>

          </p>
        </div>
      {% endif %}

      <div class="main-heading-img ">
        {% if section.settings.ab_description %}
          <p class="cs-title white">{{ section.settings.ab_description }}</p>
        {% endif %}
        {% if section.settings.heading %}
          <div class="main-heading {% if section.settings.cs-class-cheak != blank %}main-heading_cheak{% endif %}">{{ section.settings.heading }}</div>
        {% endif %}
        <img
          class="b-line"
          src="{{ section.settings.b_line | image_url }}"
          alt="{{ section.settings.title }}"
          width="auto"
          height="auto"
          loading="lazy"
        >
      </div>

      {% if section.settings.description != blank %}
        <p class="main-description">
          {{ section.settings.description }}
        </p>
      {% endif %}
{% if section.settings.primary_button_label != blank %}
      <div class="hero-buttons">
        
          <a
            href="{{ section.settings.primary_button_link }}"
            class="button--primary cs_button_hover"
          >
            {{ section.settings.primary_button_label }}
          </a>
        



    </div>
    {% endif %}
    </div>
  </div>
</div>
</section>


