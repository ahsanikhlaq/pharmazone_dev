<script>
document.addEventListener("DOMContentLoaded", () => {
  const videoWrappers = document.querySelectorAll(".video-slider");

  videoWrappers.forEach((wrapper, index) => {
    const video = wrapper.querySelector(".custom-video-slider");
    const playButton = wrapper.querySelector(".cs-video-slider-play-butt");

    if (!video) return;

    console.log(`[Video ${index}] Ready`, video);

    // Default: paused, button visible
    video.pause();
    if (playButton) playButton.style.display = "flex";

    const togglePlayPause = () => {
      if (video.paused || video.ended) { // <-- include ended
        console.log(`[Video ${index}] Play`);
        video.play();
        if (playButton) playButton.style.display = "none";
      } else {
        console.log(`[Video ${index}] Pause`);
        video.pause();
        if (playButton) playButton.style.display = "flex";
      }
    };

    // Listen to button click
    if (playButton) {
      playButton.addEventListener("click", togglePlayPause);
      console.log(`[Video ${index}] Play button listener added`);
    }

    // Listen to video click
    video.addEventListener("click", togglePlayPause);
    console.log(`[Video ${index}] Video click listener added`);

    // Make sure video is ready before toggling
    video.addEventListener("loadedmetadata", () => {
      console.log(`[Video ${index}] Metadata loaded`);
      video.pause(); // ensure paused by default
      if (playButton) playButton.style.display = "flex";
    });
  });
});
</script>