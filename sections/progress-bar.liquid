{%- style -%}
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
        background: var(--Gradient, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, rgba(244, 239, 253, 0.60) 0.38%, rgba(255, 245, 191, 0.60) 100%), #FFF);
      }
    .new-qes-content {
        max-width: 500px;
        margin: 0 auto;
    }
    .progressbar-first, .progressbar-second{
    flex: 1;
    border-radius: 36px;
    background: #E1DEE9;
    /* max-width: 250px; */
    /* width: 100%; */
    height: 4px;
}
.new-progress-content{
    display: flex;
    gap: 16px;
}
.progressbar-first .progress-bar-active, .progressbar-second .progress-bar-active{
border-radius: 36px;
background: linear-gradient(251deg, #4C3E79 11.21%, #C6B5FC 109.36%), #4C3E79;
width: 40px;
width: 100%;
height: 4px;
}
      @media screen and (min-width: 750px) {
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
        }
        

      }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="page-width">
   <div class="new-qes-content new-progress-content">
     <div class="progressbar-first">
      <div class="progress-bar-active">

      </div>
     </div>
     {% if section.settings.show-2-p %}
      <div class="progressbar-second">
 <div class="progress-bar-active">

      </div>
     </div>
    {% endif %}
   </div>
  </div>
</section>

{% schema %}
{
  "name": "progress bar",
  "settings": [
    {
      "type": "range",
      "id": "btm_spacing",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Header Bottom space",
      "default": 30
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading",
      "default": "Check Our Featured Products And Deals"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "show-2-p",
      "label": "show second bar",
      "default":  true
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "question",
      "settings": [
        
      ]
    }
  ],
  "presets": [
    {
      "name": "progress bar"
    }
  ]
}
{% endschema %}
