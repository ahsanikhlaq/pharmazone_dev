{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--Gradient, linear-gradient(0deg, rgba(255, 255, 255, 0.50) 0%, rgba(255, 255, 255, 0.50) 100%), linear-gradient(107deg, rgba(244, 239, 253, 0.60) 0.38%, rgba(255, 245, 191, 0.60) 100%), #FFF);
  }

  .new-qes-logo img{
    max-width: 160px;
  }
  .new-header-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
}
.new-qes-logo {
    display: flex;
    justify-content: center;
    align-items: center;
}
  @media screen and (max-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .new-qes-logo img {
    max-width: 150px;
}
.qes-back-btn img{
  width: 50px;
}
  }
{%- endstyle -%}






<section class="new-header-questionaire section-{{ section.id }}-padding">
    <div class="page-width">
     <div class="new-header-content">
     <div class="qes-back-btn">
        {% if section.settings.back-img %}
    <img src="{{ section.settings.back-img | image_url }}" width="auto" height="auto">
        {% endif %}
     </div>
      <a class="new-qes-logo" href="/">
        {% if section.settings.logo %}
    <img src="{{ section.settings.logo | image_url }}" width="auto" height="auto">
        {% endif %}
      </a>
     </div>
    </div>
  
</section>



{% schema %}
{
  "name": "new header",
  "settings": [
    {
      "type": "range",
      "id": "btm_spacing",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Header Bottom space",
      "default": 30
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading",
      "default": "Check Our Featured Products And Deals"
    },
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
        "type": "image_picker",
        "id": "back-img",
        "label": "back button svg"
    },
    {
        "type": "image_picker",
        "id": "logo",
        "label": "logo"
    }
  ],
  "blocks": [
    
  ],
  "presets": [
    {
      "name": "new header",
    }
  ]
}
{% endschema %}

