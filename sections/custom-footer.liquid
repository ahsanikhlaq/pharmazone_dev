<script>
document.addEventListener("DOMContentLoaded", function () {
  const footerLinks = document.querySelectorAll(".footer-link-menu");
  const footerToggles = document.querySelectorAll(".footer-links-top");

  function setMinusIcon(icon) {
    icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="8" viewBox="0 0 13 8" fill="none">
      <g transform="scale(1, -1) translate(0, -8)">
        <path d="M6.75028 7.17512C6.57066 7.17512 6.40101 7.11522 6.2613 6.98542L0.772736 2.18305C0.453401 1.91348 0.423464 1.44422 0.702882 1.13471C0.982299 0.825203 1.44134 0.785266 1.7507 1.06482L6.75028 5.4279L11.7499 1.06482C12.0592 0.79525 12.5382 0.825203 12.8077 1.13471C13.0771 1.44422 13.0472 1.92346 12.7378 2.19303L7.23926 6.99541C7.09955 7.11522 6.91993 7.18511 6.75028 7.18511V7.17512Z" fill="white"/>
      </g>
    </svg>`;
  }

  function setPlusIcon(icon) {
    icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="8" viewBox="0 0 13 8" fill="none">
      <path d="M6.75028 7.17512C6.57066 7.17512 6.40101 7.11522 6.2613 6.98542L0.772736 2.18305C0.453401 1.91348 0.423464 1.44422 0.702882 1.13471C0.982299 0.825203 1.44134 0.785266 1.7507 1.06482L6.75028 5.4279L11.7499 1.06482C12.0592 0.79525 12.5382 0.825203 12.8077 1.13471C13.0771 1.44422 13.0472 1.92346 12.7378 2.19303L7.23926 6.99541C7.09955 7.11522 6.91993 7.18511 6.75028 7.18511V7.17512Z" fill="white"/>
    </svg>`;
  }

  /* default sab menus open */
  if (window.innerWidth <= 768) {
    footerLinks.forEach((menu, index) => {
      menu.classList.add("Linlexpanded");
      menu.style.maxHeight = "fit-content";

      const icon = footerToggles[index].querySelector(".footer-link-expand");
      if (icon) setMinusIcon(icon);
    });
  }

  footerToggles.forEach((toggle, index) => {
    toggle.addEventListener("click", function () {

      if (window.innerWidth > 768) return;

      const icon = toggle.querySelector(".footer-link-expand");
      const currentMenu = footerLinks[index];

      if (currentMenu.classList.contains("Linlexpanded")) {
        currentMenu.classList.remove("Linlexpanded");
        currentMenu.style.maxHeight = "0px";
        if (icon) setPlusIcon(icon);
      } else {
        currentMenu.classList.add("Linlexpanded");
        currentMenu.style.maxHeight = "fit-content";
        if (icon) setMinusIcon(icon);
      }
    });
  });

});

</script>