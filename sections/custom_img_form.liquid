{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
{% style %}
.section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}
.cs_form_img_main_image{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
    border-radius: 10px;
    max-height: 637px;
}
.cs_form_img_main{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
}
.cs_form_img_main_form{
    padding: 24px;
    border-radius: 10px;
    background: radial-gradient(circle at center, #FAF7ED 0%, #FAF4D3 35%, #fbec947d 65%, #f5d94c17 100%);
}
.cs_form_title{
    margin: 0;
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 32px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: -0.64px;
    padding-bottom: 24px;
}
.custom-form-isolate{
    display: flex;
    flex-direction: column;
    gap: 24px;
}
.custom-form-isolate .contact__button{
    margin-top: 10px;
}
.custom_field__label{
    color: var(--Black, #111);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 510;
    line-height: normal;
    letter-spacing: 0px;
    display: block;
    padding-bottom: 10px;
}
.custom-form-isolate .field__label{
    color: #757575;
    font-family: var(--custom-fonts);
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 0px;
    text-transform: capitalize;
    left: 14px;
}
.custom-form-isolate .field:after{
    border-radius: 6px;
    border: 1px solid #E2E2E2;
    box-shadow: none;
}
.custom-form-isolate .field__input{
    border-radius: 6px;
}
.custom-form-isolate .text-area{
    min-height: 200px;
}
.custom-form-isolate .field:hover.field:after{
    border-radius: 6px;
}
.custom-form-isolate .button{
    width: 100%;
    border-radius: 75px;
    background: var(--Yellow, #FFD902);
    color: var(--Purple, #4C3E79);
    font-family: var(--custom-fonts);
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: 0px;
    text-transform: capitalize;
    border: none;
}
.custom-form-isolate .button:after{
    border-radius: 75px;
    box-shadow: none;
}

/* Character counter */
.cs_textarea_footer{
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
}
.cs_char_counter{
    color: #757575;
    font-family: var(--custom-fonts);
    font-size: 13px;
    font-weight: 400;
    line-height: 1;
}
.cs_char_counter.cs_char_limit{
    color: #E53935;
    font-weight: 600;
}

@media (max-width: 768px) {
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  .cs_form_img_main{
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .cs_form_img_main_form {
    padding: 24px 12px;
  }
  .cs_form_title {
    font-size: 24px;
    padding-bottom: 24px;
  }
  .custom_field__label {
    font-size: 16px;
  }
  .custom-form-isolate .contact__fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .custom-form-isolate {
    gap: 16px;
  }
  .custom-form-isolate .text-area {
    min-height: 111px;
  }
}
{% endstyle %}


<section class="section-{{ section.id }}">
  <div class="page-width">
    <div class="cs_form_img_main">
        <div class="cs_form_img_main_img">
            {{ section.settings.center_image | image_url: width: 1440 | image_tag:
                class: 'cs_form_img_main_image',
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 1440',
                height: 100,
                width: 100,
                alt: logo_alt,
                loading: "lazy"
            }}
        </div>
        <div class="cs_form_img_main_form">
            <h3 class="cs_form_title">{{ section.settings.title }}</h3>
            {%- liquid
              assign contact_form_class = 'isolate'
              if settings.animations_reveal_on_scroll
                assign contact_form_class = 'custom-form-isolate isolate scroll-trigger animate--slide-in'
              endif
            -%}
            {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}

              {%- if form.posted_successfully? -%}
                <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
                  {{- 'icon-success.svg' | inline_asset_content -}}
                  {{ 'templates.contact.form.post_success' | t }}
                </h2>
              {%- elsif form.errors -%}
                <div class="form__message">
                  <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                    {{- 'icon-error.svg' | inline_asset_content -}}
                    {{ 'templates.contact.form.error_heading' | t }}
                  </h2>
                </div>
                <ul class="form-status-list caption-large" role="list">
                  <li>
                    <a href="#ContactForm-email" class="link">
                      {{ form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email }}
                    </a>
                  </li>
                </ul>
              {%- endif -%}

              <div class="contact__fields">

                
                <div class="custom_field__label_name">
                  <label class="custom_field__label" for="ContactForm-name">
                    Name <span aria-hidden="true">*</span>
                  </label>
                  <div class="field">
                    <input
                      class="field__input"
                      autocomplete="name"
                      type="text"
                      id="ContactForm-name"
                      name="contact[{{ 'templates.contact.form.name' | t }}]"
                      value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                      placeholder="{{ 'templates.contact.form.name' | t }}"
                      aria-required="true"
                      required
                    >
                    <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
                  </div>
                </div>

                
                <div class="custom_field__label_name">
                  <label class="custom_field__label" for="ContactForm-email">
                    Email <span aria-hidden="true">*</span>
                  </label>
                  <div class="field field--with-error">
                    <input
                      autocomplete="email"
                      type="email"
                      id="ContactForm-email"
                      class="field__input"
                      name="contact[email]"
                      spellcheck="false"
                      autocapitalize="off"
                      value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                      aria-required="true"
                      required
                      {% if form.errors contains 'email' %}
                        aria-invalid="true"
                        aria-describedby="ContactForm-email-error"
                      {% endif %}
                      placeholder="{{ 'templates.contact.form.email' | t }}"
                    >
                    <label class="field__label" for="ContactForm-email">
                      {{- 'templates.contact.form.email' | t }}
                      <span aria-hidden="true">*</span>
                    </label>
                    {%- if form.errors contains 'email' -%}
                      <small class="contact__field-error" id="ContactForm-email-error">
                        <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                        <span class="form__message">
                          <span class="svg-wrapper">
                            {{- 'icon-error.svg' | inline_asset_content -}}
                          </span>
                          {{- form.errors.translated_fields.email | capitalize }}
                          {{ form.errors.messages.email -}}
                        </span>
                      </small>
                    {%- endif -%}
                  </div>
                </div>

              </div>

            
              <div class="custom_field__label_name">
                <label class="custom_field__label" for="ContactForm-phone">
                  Phone Number <span aria-hidden="true">*</span>
                </label>
                <div class="field">
                  <input
                    type="tel"
                    id="ContactForm-phone"
                    class="field__input"
                    autocomplete="tel"
                    name="contact[{{ 'templates.contact.form.phone' | t }}]"
                    pattern="[0-9\-]*"
                    value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                    placeholder="{{ 'templates.contact.form.phone' | t }}"
                    aria-required="true"
                    required
                  >
                  <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
                </div>
              </div>

              
              <div class="custom_field__label_name">
                <label class="custom_field__label" for="ContactForm-body">Message</label>
                <div class="field">
                  <textarea
                    rows="10"
                    id="ContactForm-body"
                    class="text-area field__input"
                    name="contact[{{ 'templates.contact.form.comment' | t }}]"
                    placeholder="{{ 'templates.contact.form.comment' | t }}"
                    maxlength="500"
                  >{{- form.body -}}</textarea>
                  <label class="form__label field__label" for="ContactForm-body">
                    Write your message here...
                  </label>
                </div>
                <div class="cs_textarea_footer">
                  <span class="cs_char_counter" id="cs_char_counter_{{ section.id }}">0 / 500</span>
                </div>
              </div>

              <div class="contact__button">
                <button type="submit" class="button">Submit</button>
              </div>

            {%- endform -%}
        </div>
    </div>
  </div>
</section>

<script>
(function () {
  var textarea = document.getElementById('ContactForm-body');
  var counter  = document.getElementById('cs_char_counter_{{ section.id }}');
  if (!textarea || !counter) return;

  var maxLen = 500;

  function updateCounter() {
    var len = textarea.value.length;
    counter.textContent = len + ' / ' + maxLen;
    if (len >= maxLen) {
      counter.classList.add('cs_char_limit');
    } else {
      counter.classList.remove('cs_char_limit');
    }
  }

  // Set initial count if form re-loaded with existing body content
  updateCounter();
  textarea.addEventListener('input', updateCounter);
})();
</script>

{% schema %}
{
  "name": "Image Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60,
      "label": "Padding Top Desktop"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60,
      "label": "Padding Bottom Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40,
      "label": "Padding Top Mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40,
      "label": "Padding Bottom Mobile"
    }
  ],
  "presets": [
    {
      "name": "Image Form"
    }
  ]
}
{% endschema %}
