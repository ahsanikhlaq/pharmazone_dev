    "cs_faq_sec_KbnFmy": {
      "type": "cs_faq_sec",
      "blocks": {
        "best_sellers_Yqt4Tj": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "What is Pharmazon Express?",
            "heading_ans": "<p>Pharmazon Express is a GPhC-registered online pharmacy in the UK dedicated to providing fast, high-quality, and discreet pharmacy delivery services. We deliver treatments like Weight Loss, ED, Hair Care, & other treatments to the patients across the UK, offering a seamless online pharmacy delivery service with same-day delivery in London and next-day delivery across the UK.</p>"
          }
        },
        "best_sellers_tKPrWf": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Is my information safe?",
            "heading_ans": "<p>Your medical records and order history are 100% confidential. Only our secure pharmacy staff, Pharmacists and prescribers can view this information.</p>"
          }
        },
        "best_sellers_yaJbCG": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Is the delivery packaging discreet?",
            "heading_ans": "<p>Yes, 100%. We prioritize your privacy by shipping all orders in plain, unbranded boxes or envelopes. There are no external markings that indicate the contents or our company name (\"Pharmazon Express\")</p>"
          }
        },
        "best_sellers_gxT3pD": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "How does the weight loss process work?",
            "heading_ans": "<p>Start by choosing your weight loss treatment and completing our quick 2-minute online consultation. Our prescriber will review all your answers, and once your treatment is approved, your medicine will be dispatched and delivered quickly and discreetly to your doorstep via Royal Mail.</p>"
          }
        },
        "best_sellers_3fwGrx": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "How much weight can you lose in a month?",
            "heading_ans": "<p>With 2.5 mg starting dose: You can expect to lose about 2–5 lbs (1–2.5 kg) in the first month depending on individual health, diet, and the use of medications.</p>"
          }
        }
      },
