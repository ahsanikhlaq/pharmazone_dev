    "cs_faq_sec_igVimy": {
      "type": "cs_faq_sec",
      "blocks": {
        "best_sellers_mnnnaL": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "How many injections are in a Mounjaro pen?",
            "heading_ans": "<p>Each Mounjaro KwikPen contains 4 doses. You inject one dose per week, so one pen lasts 4 weeks when used as prescribed.</p>"
          }
        },
        "best_sellers_inzVJg": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "How long does Mounjaro injectable pen 2.5 mg (1 pen) last?",
            "heading_ans": "<p>A 2.5 mg Mounjaro KwikPen lasts 4 weeks because it contains four weekly doses.</p>"
          }
        },
        "best_sellers_yxYHwe": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Can you take 2 shots of 2.5 mg Mounjaro to make 5 mg?",
            "heading_ans": "<p>No. You should only take the dose prescribed by your doctor or prescriber. Using two injections or trying to combine doses is not recommended unless specifically advised by a healthcare professional.</p>"
          }
        },
        "best_sellers_TUqz7R": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Can you lose weight on 2.5 mg of Mounjaro?",
            "heading_ans": "<p>Yes, some people begin to lose weight on 2.5 mg, but it is usually a starter dose used to help your body adjust to the medication. More noticeable weight loss typically occurs as the dose increases.</p>"
          }
        },
        "best_sellers_RXK9RA": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Can you stay on Mounjaro 2.5 mg for 8 weeks?",
            "heading_ans": "<p>Yes. Some prescribers may keep patients on 2.5 mg for longer than 4 weeks, particularly if side effects occur. However, the usual schedule is to increase to 5 mg after the first 4 weeks if appropriate.</p>"
          }
        },
        "best_sellers_tnJMHT": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "What should I avoid while taking Mounjaro?",
            "heading_ans": "<p>To help reduce side effects, try to avoid:<br/>- Fatty or fried foods<br/>- Large meals<br/>- Highly processed or sugary foods<br/>- Excess alcohol</p><p>Instead, aim for smaller balanced meals and good hydration.</p>"
          }
        },
        "best_sellers_a9cggb": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "What happens if you eat chocolate on Mounjaro?",
            "heading_ans": "<p>Yes, you can eat chocolate in moderation. However, eating large amounts of sugary or rich foods may increase side effects such as nausea or stomach discomfort.</p>"
          }
        },
        "best_sellers_pEEcbg": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "What are the common mistakes with Mounjaro?",
            "heading_ans": "<p>Common mistakes include:<br/>- Eating large portions or eating too quickly<br/>- Skipping meals and then overeating later<br/>- Not drinking enough water<br/>- Increasing the dose too quickly<br/>- Ignoring persistent side effects instead of speaking to a healthcare professional</p>"
          }
        },
        "best_sellers_hHEY3w": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "Can you drink alcohol on Mounjaro?",
            "heading_ans": "<p>Alcohol can be consumed in moderation, but it may worsen side effects like nausea and may slow weight‑loss progress for some people.</p>"
          }
        },
        "best_sellers_C9j8jb": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "What is the best thing to drink on Mounjaro?",
            "heading_ans": "<p>The best options include:<br/>- Water<br/>- Herbal teas<br/>- Low‑sugar drinks<br/>- Electrolyte drinks if needed</p><p>Staying well hydrated can help reduce side effects.</p>"
          }
        },
        "best_sellers_cwMD7X": {
          "type": "best-sellers",
          "settings": {
            "heading_faq": "How quickly does Mounjaro start working?",
            "heading_ans": "<p>Mounjaro starts working in the body within the first few weeks, helping to reduce appetite and improve blood sugar control. </p><p>Many people begin to notice visible weight loss after about 4–8 weeks, although this varies between individuals.</p>"
          }
        }
      },
