      "type": "custom-image-text",
      "blocks": {
        "faq_r6MJCD": {
          "type": "Faq",
          "settings": {
            "heading_faq": "Is Wegovy Safe?",
            "heading_ans": "<p>Wegovy incorporates both the recommended starting safety profile through extensive clinical trials and professional medical review. It is approved by regulatory agencies worldwide, including the FDA and MHRA. While generally well-tolerated, common side effects include nausea, diarrhea, and constipation, which typically improve over time.<br/><br/>The most common side effects are usually mild and may include nausea, vomiting, diarrhea, constipation, and abdominal pain. These side effects tend to be temporary and decrease over time as your body adjusts to the medication. To minimize side effects, it's recommended to start with a low dose and gradually increase it as directed by your healthcare provider.<br/><br/></p>"
          }
        },
        "faq_q3GFJi": {
          "type": "Faq",
          "settings": {
            "heading_faq": "Possible Side Effects",
            "heading_ans": "<p>Common side effects may include:</p><ul><li>Nausea</li><li>Diarrhoea</li><li>Vomiting</li></ul><p>These effects are usually temporary and improve as your body adjusts to treatment.</p>"
          }
        }
      },
