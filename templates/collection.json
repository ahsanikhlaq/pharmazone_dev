    "custom_liquid_g8cBKj": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% if request.path == '/collections/weight-loss-treatment' %}\n\n<!-- PHARMAZON EXPRESS – Two-Column Weight Loss Slider Calculator -->\n<div id=\"px-wrapper\" style=\"padding:5px 0; font-family:system-ui,Arial;\">\n\n<style>\n    #px-container {\n        max-width:1400px;\n        margin:0 auto;\n        display:flex;\n        gap:60px;\n        align-items:center;\n        padding:0 60px;\n    }\n\n    /* Left calculator card */\n    #px-card {\n        background:#fff;\n        border-radius:15px;\n        width:100%;\n        max-width:700px;\n        box-shadow:0 10px 40px rgba(0,0,0,0.12);\n        overflow:hidden;\n    }\n\n    #px-card-top {\n        padding:30px;\n        text-align:center;\n    }\n\n    #px-card-top h4 {\n        margin:0 0 10px;\n        color:#4f3d76;\n        font-size:18px;\n        font-weight:500;\n    }\n\n    #px-weight {\n        font-size:52px;\n        font-weight:700;\n        color:#4f3d76;\n    }\n\n    #px-unit {\n        font-size:30px;\n        margin-left:5px;\n        color:#4f3d76;\n    }\n\n    #px-slider {\n        width:100%;\n        margin:25px 0 10px;\n        -webkit-appearance:none;\n        height:4px;\n        background:#d7e2ea;\n        border-radius:10px;\n        outline:none;\n    }\n\n    #px-slider::-webkit-slider-thumb {\n        -webkit-appearance:none;\n        height:28px;\n        width:28px;\n        background:#4f3d76;\n        border-radius:50%;\n        cursor:pointer;\n    }\n\n    /* Bottom result area */\n    #px-result-box {\n        padding:20px;\n        background:#bcc1c4;\n        text-align:center;\n        color:#4f3d76;\n    }\n\n    #px-loss {\n        font-size:52px;\n        font-weight:700;\n        display:inline-block;\n    }\n\n    #px-switch {\n        margin:15px 0 20px;\n        text-align:left;\n        padding-left:30px;\n    }\n\n    #px-switch a {\n        color:#0d47a1;\n        text-decoration:underline;\n        cursor:pointer;\n        font-size:14px;\n    }\n\n    /* Right text block */\n    #px-text-side {\n        max-width:500px;\n    }\n\n    #px-text-side h2 {\n        font-size:42px;\n        color:#4f3d76;\n        margin-bottom:5px;\n        line-height:1.2;\n    }\n\n    #px-text-side p {\n        font-size:18px;\n        color:#000000;\n        line-height:1.5;\n    }\n\n    /* Responsive */\n    @media(max-width:900px){\n        #px-container {\n            flex-direction:column;\n            text-align:center;\n        }\n        #px-switch { \n            text-align:center;\n            padding-left:6px;\n        }\n        #px-text-side { text-align:center; }\n        #px-text-side h2 { font-size:32px; }\n    }\n</style>\n\n<div id=\"px-container\">\n\n    <!-- LEFT SIDE CALCULATOR -->\n    <div id=\"px-card\">\n        <div id=\"px-card-top\">\n            <h4>Drag the slider to your start weight</h4>\n\n            <div id=\"px-weight-display\">\n                <span id=\"px-weight\">100</span><span id=\"px-unit\">kg</span>\n            </div>\n\n            <input type=\"range\" id=\"px-slider\" min=\"40\" max=\"200\" value=\"100\">\n\n            <div id=\"px-switch\">\n                <a id=\"px-toggle\">Switch to pounds</a>\n            </div>\n        </div>\n\n        <div id=\"px-result-box\">\n            <div style=\"font-size:17px;margin-bottom:4px;\">\n                In one year, you could lose up to:\n            </div>\n            <div>\n                <span id=\"px-loss\">20</span>\n                <span id=\"px-loss-unit\">kg</span>\n            </div>\n        </div>\n    </div>\n\n    <!-- RIGHT SIDE TEXT -->\n    <div id=\"px-text-side\">\n        <h2>How much weight could you lose?</h2>\n        <p>\n            The <strong>weight loss treatment</strong> offered by \n            <strong>Pharmazon Express</strong> typically leads to an average \n            weight loss of <strong>15%–20%</strong> of initial body weight over \n            <strong>1–1.5 years</strong>. This is significantly faster than results \n            reported in most clinical studies.\n        </p>\n    </div>\n\n</div>\n\n<script>\n(function(){\n    let inKG = true;\n\n    const slider = document.getElementById(\"px-slider\");\n    const weightVal = document.getElementById(\"px-weight\");\n    const lossVal = document.getElementById(\"px-loss\");\n    const unit = document.getElementById(\"px-unit\");\n    const lossUnit = document.getElementById(\"px-loss-unit\");\n    const toggle = document.getElementById(\"px-toggle\");\n\n    function calcLoss(w){\n        return Math.round(w * 0.203); // 20.3% annual weight loss\n    }\n\n    function update(){\n        let val = parseInt(slider.value);\n\n        if(!inKG){\n            let kg = val * 0.453592;\n            weightVal.textContent = val;\n            lossVal.textContent = Math.round(calcLoss(kg) * 2.20462);\n        } else {\n            weightVal.textContent = val;\n            lossVal.textContent = calcLoss(val);\n        }\n    }\n\n    slider.addEventListener(\"input\", update);\n\n    toggle.addEventListener(\"click\", function(){\n\n        if(inKG){\n            inKG = false;\n            unit.textContent = \"lbs\";\n            lossUnit.textContent = \"lbs\";\n            toggle.textContent = \"Switch to kilograms\";\n\n            let kgVal = parseInt(weightVal.textContent);\n            slider.min = 90;\n            slider.max = 440;\n            slider.value = Math.round(kgVal * 2.20462);\n\n        } else {\n            inKG = true;\n            unit.textContent = \"kg\";\n            lossUnit.textContent = \"kg\";\n            toggle.textContent = \"Switch to pounds\";\n\n            let lbVal = parseInt(weightVal.textContent);\n            slider.min = 40;\n            slider.max = 200;\n            slider.value = Math.round(lbVal * 0.453592);\n        }\n\n        update();\n    });\n\n    update();\n})();\n</script>\n\n</div>\n\n{% endif %}",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
