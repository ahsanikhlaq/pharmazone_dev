      "settings": {
        "custom_liquid": "<script>\n// Run only on specific page\nif (window.location.pathname.includes('/collections/weight-loss-treatment')) {\n  document.write(`\n<section class=\"weightloss-section\">\n  <h1>Trusted Weight Loss Treatments in the UK</h1>\n  <p>Discover proven and pharmacy-approved solutions for effective weight loss — including <strong>Mounjaro</strong>, <strong>Wegovy</strong>, <strong>Saxenda</strong>, and trusted <strong>Weight Loss Tablets</strong>. All available with discreet UK delivery.</p>\n\n  <!-- Product Cards -->\n  <div class=\"weightloss-cards\">\n    <div class=\"card\">\n      <h3>💉 <strong>Mounjaro</strong> (Tirzepatide)</h3>\n      <p>A once-weekly <strong>weight loss injection</strong> that supports strong appetite control and improved insulin balance. Safe, effective, and clinically tested.</p>\n    </div>\n\n    <div class=\"card\">\n      <h3>💉 <strong>Wegovy</strong> (Semaglutide)</h3>\n      <p>Reduces hunger and supports gradual, consistent weight loss. Ideal for individuals looking for a convenient weekly injectable treatment.</p>\n    </div>\n\n    <div class=\"card\">\n      <h3>💉 <strong>Saxenda</strong> (Liraglutide)</h3>\n      <p>A daily injection that helps prevent overeating and promotes steady fat reduction. Perfect for long-term weight management.</p>\n    </div>\n\n    <div class=\"card\">\n      <h3>💊 <strong>Weight Loss Tablets</strong></h3>\n      <p>Easy-to-take <strong>weight control pills</strong> that aid metabolism and appetite suppression — a convenient alternative to injectables.</p>\n    </div>\n  </div>\n\n  <!-- Table Section -->\n  <div class=\"table-section\">\n    <h2><b>Compare Our Most Popular Weight Loss Treatments</h2>\n    <table>\n      <thead>\n        <tr>\n          <th>Treatment</th>\n          <th>Type</th>\n          <th>Benefits</th>\n          <th>Common Side Effects</th>\n          <th>Recommended For</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td data-label=\"Treatment\">Mounjaro</td>\n          <td data-label=\"Type\">Weekly Injection</td>\n          <td data-label=\"Benefits\">Strong appetite control, supports insulin function</td>\n          <td data-label=\"Common Side Effects\">Mild nausea, fatigue, or stomach upset</td>\n          <td data-label=\"Recommended For\">People seeking rapid results under medical supervision</td>\n        </tr>\n        <tr>\n          <td data-label=\"Treatment\">Wegovy</td>\n          <td data-label=\"Type\">Weekly Injection</td>\n          <td data-label=\"Benefits\">Controls appetite, helps consistent fat loss</td>\n          <td data-label=\"Common Side Effects\">Temporary nausea or headaches</td>\n          <td data-label=\"Recommended For\">Those seeking gradual, steady results</td>\n        </tr>\n        <tr>\n          <td data-label=\"Treatment\">Saxenda</td>\n          <td data-label=\"Type\">Daily Injection</td>\n          <td data-label=\"Benefits\">Steady appetite reduction, smooth results</td>\n          <td data-label=\"Common Side Effects\">Digestive discomfort, mild tiredness</td>\n          <td data-label=\"Recommended For\">Users preferring daily control</td>\n        </tr>\n        <tr>\n          <td data-label=\"Treatment\">Weight Loss Tablets</td>\n          <td data-label=\"Type\">Oral Tablets</td>\n          <td data-label=\"Benefits\">Simple daily routine, convenient use</td>\n          <td data-label=\"Common Side Effects\">Possible mild digestive effects</td>\n          <td data-label=\"Recommended For\">Those who prefer non-injectable solutions</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <!-- FAQ Section -->\n  <div class=\"faq\">\n    <h2><b>Frequently Asked Questions</h2>\n    <div class=\"faq-item\">\n      <h4>Is Mounjaro safe for weight loss?</h4>\n      <div class=\"faq-answer\">Yes, Mounjaro is clinically tested and considered safe under medical guidance. Side effects like nausea or fatigue are mild and temporary.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <h4>What are Wegovy side effects?</h4>\n      <div class=\"faq-answer\">Wegovy may cause mild nausea or digestive issues initially, but these typically settle as your body adjusts to the medication.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <h4>Which weight loss injection is best in the UK?</h4>\n      <div class=\"faq-answer\">Each treatment has unique benefits. Mounjaro offers strong results, Wegovy provides appetite control, and Saxenda ensures steady progress.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <h4>Can I buy cheap weight loss injections online?</h4>\n      <div class=\"faq-answer\">Yes, but always buy from regulated UK pharmacies like Pharmazon Express to ensure genuine and safe products.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <h4>Do weight loss pills really work?</h4>\n      <div class=\"faq-answer\">Yes, when combined with diet and exercise, weight loss tablets can support metabolism and appetite management effectively.</div>\n    </div>\n  </div>\n\n  <!-- CTA Section -->\n  <div class=\"cta-box\">\n    <h2>Start Your Weight Loss Journey Today</h2>\n    <p>Explore UK-approved treatments including <strong>Mounjaro</strong>, <strong>Wegovy</strong>, and <strong>Saxenda</strong>. 100% genuine, discreetly delivered, and trusted by thousands.</p>\n    <a href=\"/collections/weight-loss-treatment\" class=\"cta-btn\">Explore Weight Loss Treatments</a>\n  </div>\n</section>\n  `);\n\n  // Add CSS dynamically\n  const style = document.createElement('style');\n  style.textContent = `\n  .weightloss-section {\n    background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);\n    border-radius: 20px;\n    padding: 40px 20px;\n    font-family: 'Poppins', sans-serif;\n    color: #1e293b;\n    line-height: 1.7;\n    box-shadow: 0 4px 25px rgba(0,0,0,0.05);\n    max-width: 1100px;\n    margin: 40px auto;\n  }\n  .weightloss-section h1 { font-size:32px; text-align:center; font-weight:700; margin-bottom:15px; background: linear-gradient(90deg,#4c3e79,#4c3e79); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }\n  .weightloss-section h2 { font-size:24px; text-align:center; margin:40px 0 15px; }\n  .weightloss-section h3 { font-size:20px; color:#4c3e79; margin-bottom:10px; text-align:center; }\n  .weightloss-section p { font-size:16px; text-align:center; margin-bottom:20px; }\n\n  .weightloss-cards { display:grid; grid-template-columns:repeat(2,1fr); gap:25px; justify-items:center; margin-top:30px; }\n  .card { background:#fff; border:1px solid #e5e7eb; border-radius:16px; padding:25px; width:100%; box-sizing:border-box; transition:all 0.3s; }\n  .card:hover { box-shadow:0 6px 18px rgba(37,99,235,0.15); transform:translateY(-3px); }\n  .card p { font-size:16px; color:#475569; }\n  .card p strong { font-weight:bold; }\n\n  .table-section { margin-top:40px; overflow-x:auto; }\n  .table-section table { width:100%; border-collapse:collapse; font-size:14px; border:2px solid #e2e8f0; }\n  .table-section th, .table-section td { border:1px solid #e2e8f0; padding:12px; }\n  .table-section th { background:#f1f5f9; font-weight:600; color:#0f172a; }\n  .table-section tr:nth-child(even) { background:#f9fafb; }\n\n  .faq { margin-top:40px; }\n  .faq-item { background:#f8fafc; border-radius:10px; padding:15px 20px; margin-bottom:10px; border:1px solid #e2e8f0; cursor:pointer; position:relative; transition:0.3s; }\n  .faq-item:hover { background:#f1f5f9; }\n  .faq-item h4 { margin:0; font-size:16px; display:flex; justify-content:space-between; align-items:center; }\n  .faq-item h4::after { content:'+'; font-weight:bold; font-size:18px; transition: transform 0.3s;}\n  .faq-item.active h4::after { content:'−'; transform:rotate(180deg); }\n  .faq-answer { max-height:0; overflow:hidden; font-size:15px; color:#475569; margin-top:10px; line-height:1.6; transition:max-height 0.4s ease, padding 0.3s ease; }\n\n  .cta-box { text-align:center; margin-top:50px; background:linear-gradient(90deg,#705f9d,#e1ceff); color:#fff; padding:40px 20px; border-radius:18px; box-shadow:0 4px 20px rgba(0,0,0,0.1);}\n  .cta-box h2 { font-size:24px; margin-bottom:10px; color:#fff; font-weight:700; }\n  .cta-box p { font-size:16px; color:#ffffff; margin-bottom:25px; }\n  .cta-btn { background:#fff; color:#000000; padding:12px 28px; border-radius:30px; font-weight:600; text-decoration:none; transition:0.3s; }\n  .cta-btn:hover { background:#e0f2fe; }\n\n  @media(max-width:1024px){ .weightloss-cards { grid-template-columns:1fr; gap:20px; } }\n  @media(max-width:768px){\n    .table-section table, .table-section thead, .table-section tbody, .table-section th, .table-section td, .table-section tr { display:block; }\n    .table-section thead tr { display:none; }\n    .table-section tr { margin-bottom:15px; border:1px solid #e2e8f0; border-radius:10px; padding:10px; }\n    .table-section td { border:none; padding:5px 10px; position:relative; text-align:left; }\n    .table-section td::before { content: attr(data-label); font-weight:600; display:inline-block; width:120px; color:#0f172a; }\n  }\n  `;\n  document.head.appendChild(style);\n\n  // FAQ toggle\n  document.addEventListener('click', function(e) {\n    if (e.target.closest('.faq-item')) {\n      const item = e.target.closest('.faq-item');\n      const answer = item.querySelector('.faq-answer');\n      if (item.classList.contains('active')) {\n        answer.style.maxHeight = null;\n        item.classList.remove('active');\n      } else {\n        document.querySelectorAll('.faq-item.active').forEach(activeItem => {\n          activeItem.querySelector('.faq-answer').style.maxHeight = null;\n          activeItem.classList.remove('active');\n        });\n        answer.style.maxHeight = answer.scrollHeight + 'px';\n        item.classList.add('active');\n      }\n    }\n  });\n}\n</script>",
